@import "./xl-theme.wxss";

.income-page {
  min-height: 100vh;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ---------- 状态 ---------- */
.income-state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.income-state-text {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.5;
}

.income-state--err .income-state-text {
  color: #b91c1c;
}

/* ---------- 顶部余额 ---------- */
.income-hero {
  margin-bottom: 28rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #312e81 0%, #4338ca 48%, #6366f1 100%);
  box-shadow: 0 16rpx 40rpx rgba(67, 56, 202, 0.32);
}

.income-hero-inner {
  padding: 32rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.income-hero-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: 0.04em;
}

.income-hero-amount-row {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
  gap: 4rpx;
}

.income-hero-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1;
}

.income-hero-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  line-height: 1.1;
}

.income-hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.22);
}

.income-stat {
  flex: 1;
  min-width: 200rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.14);
  box-sizing: border-box;
}

.income-stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 8rpx;
}

.income-stat-val {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  font-variant-numeric: tabular-nums;
}

.income-stat-val--muted {
  color: rgba(255, 255, 255, 0.88);
  font-weight: 600;
}

/* ---------- 提示 ---------- */
.income-hint {
  margin-bottom: 24rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #b45309;
  background: rgba(254, 243, 199, 0.65);
  border: 1rpx solid rgba(245, 158, 11, 0.35);
  box-sizing: border-box;
}

/* ---------- 流水面板 ---------- */
.income-panel {
  padding: 26rpx 24rpx 28rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 250, 255, 0.96) 100%);
  border: 1rpx solid rgba(129, 140, 248, 0.18);
  box-shadow: 0 10rpx 36rpx rgba(79, 70, 229, 0.06);
  box-sizing: border-box;
}

.income-panel-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.income-panel-mark {
  width: 8rpx;
  height: 32rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #6366f1 0%, #4338ca 100%);
}

.income-panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.03em;
}

/* ---------- 空状态 ---------- */
.income-empty {
  padding: 56rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.income-empty-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.1);
  border: 2rpx dashed rgba(129, 140, 248, 0.35);
  box-sizing: border-box;
}

.income-empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
}

.income-empty-tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.45;
}

/* ---------- 流水列表 ---------- */
.income-ledger {
  padding-bottom: 8rpx;
}

.income-ledger-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.85);
  box-sizing: border-box;
}

.income-ledger-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.income-ledger-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
}

.income-ledger-dot.ledger-amt--pos {
  background: #22c55e;
  box-shadow: 0 0 0 6rpx rgba(34, 197, 94, 0.2);
}

.income-ledger-dot.ledger-amt--neg {
  background: #f97316;
  box-shadow: 0 0 0 6rpx rgba(249, 115, 22, 0.18);
}

.income-ledger-body {
  flex: 1;
  min-width: 0;
}

.income-ledger-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.income-ledger-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
}

.income-ledger-amt {
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  line-height: 1.3;
}

.income-ledger-amt.ledger-amt--pos {
  color: #059669;
}

.income-ledger-amt.ledger-amt--neg {
  color: #ea580c;
}

.income-ledger-time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
  font-variant-numeric: tabular-nums;
}

.income-ledger-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.45;
}

.income-load-more {
  margin-top: 20rpx;
  padding: 20rpx;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(99, 102, 241, 0.08);
  border: 1rpx solid rgba(129, 140, 248, 0.22);
  box-sizing: border-box;
}

.income-load-more:active {
  opacity: 0.85;
}

.income-load-more-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #4338ca;
  letter-spacing: 0.04em;
}
