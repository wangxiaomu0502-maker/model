.profile-detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.profile-state {
  padding: 120rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
}

.profile-detail-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  border-radius: 34rpx;
  color: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.16);
}

.profile-hero-avatar-wrap {
  width: 148rpx;
  height: 148rpx;
  border-radius: 36rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.42);
  background: rgba(255, 255, 255, 0.92);
}

.profile-hero-avatar,
.profile-hero-fallback {
  width: 100%;
  height: 100%;
}

.profile-hero-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 900;
}

.profile-hero-kicker,
.profile-hero-name,
.profile-hero-sub {
  display: block;
  text-align: center;
}

.profile-hero-kicker {
  margin-top: 24rpx;
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
  opacity: 0.88;
}

.profile-hero-name {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.profile-hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.profile-card {
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.profile-card-title,
.profile-desc {
  display: block;
}

.profile-card-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #312e81;
}

.profile-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 22rpx;
}

.profile-row-label,
.profile-row-value {
  font-size: 26rpx;
  line-height: 1.5;
}

.profile-row-label {
  flex-shrink: 0;
  color: #64748b;
}

.profile-row-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-weight: 700;
  color: #0f172a;
  word-break: break-all;
}

.profile-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #475569;
}
