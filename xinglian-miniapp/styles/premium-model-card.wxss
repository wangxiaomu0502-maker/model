@keyframes premium-shine-sweep {
  0% {
    transform: translateX(-130%) rotate(16deg);
    opacity: 0;
  }

  18% {
    opacity: 0.85;
  }

  42% {
    transform: translateX(130%) rotate(16deg);
    opacity: 0;
  }

  100% {
    transform: translateX(130%) rotate(16deg);
    opacity: 0;
  }
}

@keyframes premium-glow-pulse {
  0%,
  100% {
    opacity: 0.45;
  }

  50% {
    opacity: 0.95;
  }
}

.premium-model-frame {
  position: absolute;
  inset: 0;
  z-index: 5;
  pointer-events: none;
  border-radius: inherit;
  overflow: hidden;
}

.premium-model-corner {
  position: absolute;
  width: 34rpx;
  height: 34rpx;
  border-style: solid;
  border-width: 0;
}

.premium-model-corner--tl {
  top: 6rpx;
  left: 6rpx;
  border-top-width: 6rpx;
  border-left-width: 6rpx;
  border-top-left-radius: 4rpx;
}

.premium-model-corner--tr {
  top: 6rpx;
  right: 6rpx;
  border-top-width: 6rpx;
  border-right-width: 6rpx;
  border-top-right-radius: 4rpx;
}

.premium-model-corner--bl {
  bottom: 6rpx;
  left: 6rpx;
  border-bottom-width: 6rpx;
  border-left-width: 6rpx;
  border-bottom-left-radius: 4rpx;
}

.premium-model-corner--br {
  right: 6rpx;
  bottom: 6rpx;
  border-right-width: 6rpx;
  border-bottom-width: 6rpx;
  border-bottom-right-radius: 4rpx;
}

.premium-model-edge {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  height: 3rpx;
  border-radius: 999rpx;
  opacity: 0.92;
}

.premium-model-edge--top {
  top: 0;
}

.premium-model-edge--bottom {
  bottom: 0;
}

.premium-model-shine {
  position: absolute;
  top: -20%;
  left: -60%;
  width: 52%;
  height: 140%;
  border-radius: 999rpx;
  transform: rotate(16deg);
  animation: premium-shine-sweep 3.6s ease-in-out infinite;
}

.premium-model-frame--crown .premium-model-corner {
  border-color: #fbbf24;
  box-shadow: 0 0 14rpx rgba(251, 191, 36, 0.75);
}

.premium-model-frame--crown .premium-model-edge {
  background: linear-gradient(90deg, rgba(251, 191, 36, 0), #fde68a 18%, #f59e0b 50%, #fde68a 82%, rgba(251, 191, 36, 0));
}

.premium-model-frame--crown .premium-model-shine {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 251, 235, 0.95), rgba(255, 255, 255, 0));
}

.premium-model-frame--sky .premium-model-corner {
  border-color: #e879f9;
  box-shadow:
    0 0 10rpx rgba(168, 85, 247, 0.8),
    0 0 18rpx rgba(56, 189, 248, 0.45);
}

.premium-model-frame--sky .premium-model-edge {
  background: linear-gradient(90deg, rgba(56, 189, 248, 0), #38bdf8 12%, #a855f7 38%, #ec4899 62%, #f97316 88%, rgba(236, 72, 153, 0));
  animation: premium-glow-pulse 2.4s ease-in-out infinite;
}

.premium-model-frame--sky .premium-model-shine {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(236, 72, 153, 0.55), rgba(56, 189, 248, 0.35), rgba(255, 255, 255, 0));
}

.premium-model-frame--sky-corners-only .premium-model-corner {
  width: 26rpx;
  height: 26rpx;
  border: none;
  box-shadow: none;
  background: transparent;
}

.premium-model-frame--sky-corners-only .premium-model-corner::before,
.premium-model-frame--sky-corners-only .premium-model-corner::after {
  content: "";
  position: absolute;
  background: #a855f7;
  box-shadow: 0 0 8rpx rgba(168, 85, 247, 0.55);
}

.premium-model-frame--sky-corners-only .premium-model-corner--tl::before {
  top: 0;
  left: 0;
  width: 22rpx;
  height: 4rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--tl::after {
  top: 4rpx;
  left: 0;
  width: 4rpx;
  height: 18rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--tr::before {
  top: 0;
  right: 0;
  width: 22rpx;
  height: 4rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--tr::after {
  top: 4rpx;
  right: 0;
  width: 4rpx;
  height: 18rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--bl::before {
  bottom: 0;
  left: 0;
  width: 22rpx;
  height: 4rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--bl::after {
  bottom: 4rpx;
  left: 0;
  width: 4rpx;
  height: 18rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--br::before {
  bottom: 0;
  right: 0;
  width: 22rpx;
  height: 4rpx;
}

.premium-model-frame--sky-corners-only .premium-model-corner--br::after {
  bottom: 4rpx;
  right: 0;
  width: 4rpx;
  height: 18rpx;
}
