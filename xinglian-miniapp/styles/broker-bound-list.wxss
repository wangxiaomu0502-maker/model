@import "./xl-theme.wxss";
@import "./broker-page-hero.wxss";

.search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

.search-go,
.search-clear {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #4f46e5;
  padding: 12rpx 8rpx;
}

.scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.item-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.item-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.av {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #eef2ff, #e0e7ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.av-img {
  width: 100%;
  height: 100%;
  display: block;
}

.av-fallback {
  font-size: 36rpx;
  font-weight: 700;
  color: #4338ca;
}

.item-meta {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.item-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.4;
  word-break: break-all;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.35;
  border: 1rpx solid transparent;
}

.tag--audit-ok {
  color: #047857;
  background: rgba(16, 185, 129, 0.12);
  border-color: rgba(52, 211, 153, 0.35);
}

.tag--audit-pending {
  color: #b45309;
  background: rgba(251, 191, 36, 0.16);
  border-color: rgba(245, 158, 11, 0.32);
}

.tag--audit-bad {
  color: #b91c1c;
  background: rgba(254, 226, 226, 0.9);
  border-color: rgba(248, 113, 113, 0.35);
}

.tag--audit-muted {
  color: #64748b;
  background: rgba(148, 163, 184, 0.14);
  border-color: rgba(148, 163, 184, 0.28);
}

.tag--contract-ok {
  color: #4338ca;
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(129, 140, 248, 0.35);
}

.tag--contract-warn {
  color: #9a3412;
  background: rgba(255, 237, 213, 0.95);
  border-color: rgba(251, 146, 60, 0.35);
}

.tag--order {
  color: #1d4ed8;
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(96, 165, 250, 0.35);
}

.tag--muted {
  color: #475569;
  background: #f1f5f9;
  border-color: #e2e8f0;
}

.item-foot {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f1f5f9;
}

.item-foot-k {
  font-size: 22rpx;
  color: #94a3b8;
}

.item-more {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 600;
  color: #4f46e5;
}

.hint {
  padding: 48rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.55;
}

.hint.empty {
  color: #64748b;
  padding: 32rpx 28rpx 48rpx;
}

.hint.foot {
  padding: 24rpx;
}

.bottom-space {
  height: 32rpx;
}
