.home-page-root {
  min-height: 100vh;
}

.home-page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 122, 201, 0.32) 0, rgba(255, 122, 201, 0) 230rpx),
    radial-gradient(circle at 88% 12%, rgba(56, 189, 248, 0.26) 0, rgba(56, 189, 248, 0) 250rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 330rpx, #f8fbff 100%);
}

.home-bg {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  pointer-events: none;
}

.home-bg--pink {
  top: 128rpx;
  left: -84rpx;
  width: 210rpx;
  height: 210rpx;
  background: rgba(244, 114, 182, 0.22);
}

.home-bg--blue {
  top: 500rpx;
  right: -96rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(99, 102, 241, 0.18);
}

.home-dash {
  position: relative;
  z-index: 1;
}

.home-hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 16% 22%, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0) 160rpx),
    linear-gradient(135deg, #7c3aed 0%, #ec4899 48%, #f97316 100%);
  box-shadow: 0 18rpx 44rpx rgba(236, 72, 153, 0.3);
}

.home-hero-glow {
  position: absolute;
  top: -80rpx;
  right: -42rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
}

.home-hero-main {
  position: relative;
  z-index: 1;
}

.home-kicker {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.18);
}

.home-title {
  display: block;
  margin-top: 20rpx;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 900;
  color: #ffffff;
}

.home-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.86);
}

.home-stat-row {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.home-stat-card {
  flex: 1;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.home-stat-num,
.home-stat-label,
.home-section-title,
.home-section-sub,
.home-business-status,
.home-business-budget,
.home-business-label,
.home-business-name,
.home-model-name,
.home-model-sub,
.home-visitor-title,
.home-visitor-sub {
  display: block;
}

.home-stat-num {
  font-size: 42rpx;
  line-height: 1;
  font-weight: 900;
  color: #ffffff;
}

.home-stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

.home-visitor-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fdf2f8 48%, #eef2ff 100%);
  border: 1rpx solid rgba(236, 72, 153, 0.16);
  box-shadow: 0 16rpx 34rpx rgba(236, 72, 153, 0.12);
}

.home-visitor-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #312e81;
}

.home-visitor-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.home-register-btn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 55%, #f97316 100%);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.3);
}

.home-level-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.home-level-card {
  position: relative;
  flex: 0 0 calc((100% - 28rpx) / 3);
  min-width: 0;
  overflow: hidden;
  padding: 22rpx 16rpx 20rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 16rpx 34rpx rgba(148, 163, 184, 0.18);
  box-sizing: border-box;
}

.home-level-card::after {
  content: "";
  position: absolute;
  top: -52rpx;
  right: -46rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
}

.home-level-card--lv0 {
  background: linear-gradient(145deg, #64748b 0%, #94a3b8 100%);
}

.home-level-card--lv1 {
  background: linear-gradient(145deg, #7c3aed 0%, #ec4899 100%);
}

.home-level-card--lv2 {
  background: linear-gradient(145deg, #2563eb 0%, #06b6d4 100%);
}

.home-level-card--lv3 {
  background: linear-gradient(145deg, #f97316 0%, #f43f5e 100%);
}

.home-level-card--lv4 {
  border: 3rpx solid transparent;
  background:
    linear-gradient(145deg, #b45309 0%, #f59e0b 100%) padding-box,
    linear-gradient(135deg, #f59e0b, #fde68a 48%, #b45309) border-box;
  box-shadow: 0 18rpx 38rpx rgba(180, 83, 9, 0.28);
}

.home-level-card--lv5 {
  border: 3rpx solid transparent;
  background:
    radial-gradient(circle at 20% 10%, rgba(255, 255, 255, 0.34) 0, rgba(255, 255, 255, 0) 74rpx),
    radial-gradient(circle at 84% 18%, rgba(125, 211, 252, 0.45) 0, rgba(125, 211, 252, 0) 92rpx),
    linear-gradient(145deg, #111827 0%, #312e81 44%, #6d28d9 74%, #0f172a 100%) padding-box,
    linear-gradient(135deg, #f59e0b, #fde68a 38%, #7c3aed 72%, #ec4899) border-box;
  box-shadow: 0 18rpx 38rpx rgba(49, 46, 129, 0.3);
}

.home-level-card--lv5::after {
  top: -62rpx;
  right: -36rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(165, 180, 252, 0.28);
  box-shadow: 0 0 36rpx rgba(125, 211, 252, 0.34);
}

.home-level-card--lv5::before {
  content: "";
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  width: 74rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #fef3c7, rgba(254, 243, 199, 0));
}

.home-level-card--lv5 .home-level-name {
  color: #fef3c7;
  text-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.32);
}

.home-level-card--lv5 .home-level-temperament {
  color: rgba(224, 231, 255, 0.86);
}

.home-level-name,
.home-level-temperament {
  position: relative;
  z-index: 1;
  display: block;
  color: #ffffff;
}

.home-level-name {
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
}

.home-level-temperament {
  margin-top: 8rpx;
  min-height: 56rpx;
  font-size: 19rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.78);
}

.home-level-mask {
  position: fixed;
  z-index: 10050;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.46);
}

.home-level-sheet {
  width: 100%;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  padding: 34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at 88% 0%, rgba(236, 72, 153, 0.16) 0, rgba(236, 72, 153, 0) 180rpx),
    #ffffff;
  box-shadow: 0 -18rpx 46rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
}

.home-level-sheet-body {
  height: 52vh;
  max-height: 560rpx;
  box-sizing: border-box;
}

.home-level-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.home-level-sheet-title,
.home-level-sheet-sub,
.home-level-info-label,
.home-level-info-text,
.home-level-permission-text {
  display: block;
}

.home-level-sheet-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #312e81;
}

.home-level-close {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #64748b;
  background: #f1f5f9;
}

.home-level-sheet-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #64748b;
}

.home-level-info-card {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(236, 72, 153, 0.12);
  background: linear-gradient(135deg, #fff7fb 0%, #f8fafc 100%);
}

.home-level-info-label {
  font-size: 22rpx;
  font-weight: 900;
  color: #be185d;
}

.home-level-info-text {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 800;
  color: #334155;
}

.home-level-permission-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 14rpx;
}

.home-level-permission-dot {
  flex-shrink: 0;
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #ec4899;
}

.home-level-permission-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.55;
  color: #475569;
}

.home-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 4rpx;
}

.home-section-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #312e81;
}

.home-section-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.home-section-more {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #db2777;
  background: #fdf2f8;
}

.home-model-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.home-business-swiper {
  height: 492rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.home-business-slide {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  height: 100%;
}

.home-business-card {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 154rpx;
  padding: 18rpx 20rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 95% 8%, rgba(236, 72, 153, 0.12) 0, rgba(236, 72, 153, 0) 120rpx),
    rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 28rpx rgba(124, 58, 237, 0.1);
}

.home-business-top,
.home-business-parties {
  display: flex;
  align-items: center;
}

.home-business-top {
  justify-content: space-between;
  gap: 16rpx;
}

.home-business-status {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #7c3aed;
  background: #eef2ff;
}

.home-business-budget {
  font-size: 24rpx;
  font-weight: 900;
  color: #be185d;
}

.home-business-parties {
  gap: 12rpx;
  margin-top: 12rpx;
}

.home-business-party {
  flex: 1;
  min-width: 0;
}

.home-business-label {
  font-size: 18rpx;
  color: #64748b;
}

.home-business-name {
  margin-top: 3rpx;
  font-size: 23rpx;
  font-weight: 900;
  color: #312e81;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-business-arrow {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed, #ec4899);
}

.home-model-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  width: 100%;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 14rpx 34rpx rgba(124, 58, 237, 0.14);
  box-sizing: border-box;
}

.home-model-card--crown {
  border: 3rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(251, 191, 36, 0.2) 0, rgba(251, 191, 36, 0) 180rpx),
    linear-gradient(#fffbeb, #ffffff) padding-box,
    linear-gradient(135deg, #f59e0b, #fde68a 48%, #b45309) border-box;
  box-shadow: 0 20rpx 48rpx rgba(180, 83, 9, 0.22);
}

.home-model-card--sky {
  border: 3rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(236, 72, 153, 0.24) 0, rgba(236, 72, 153, 0) 190rpx),
    radial-gradient(circle at 0% 12%, rgba(56, 189, 248, 0.18) 0, rgba(56, 189, 248, 0) 170rpx),
    linear-gradient(180deg, #f5f3ff 0%, #fff7fb 100%) padding-box,
    linear-gradient(135deg, #f59e0b, #fde68a 38%, #7c3aed 72%, #ec4899) border-box;
  box-shadow: 0 22rpx 56rpx rgba(88, 28, 135, 0.28);
}

.home-model-cover {
  position: relative;
  overflow: hidden;
  height: 360rpx;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff 52%, #fff7ed);
}

.home-model-card--crown .home-model-cover {
  background: linear-gradient(135deg, #78350f, #f59e0b 52%, #fde68a);
}

.home-model-card--sky .home-model-cover {
  background: linear-gradient(135deg, #020617, #4c1d95 48%, #ec4899);
}

.home-model-premium-aura {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 280rpx;
  height: 280rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.32) 0, rgba(255, 255, 255, 0) 66%);
  pointer-events: none;
}

.home-model-img,
.home-model-fallback {
  width: 100%;
  height: 100%;
}

.home-model-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 900;
  color: #be185d;
}

.home-model-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(88, 28, 135, 0.64) 100%);
}

.home-model-card--crown .home-model-gradient {
  background: linear-gradient(180deg, rgba(120, 53, 15, 0) 0%, rgba(120, 53, 15, 0.72) 100%);
}

.home-model-card--sky .home-model-gradient {
  background: linear-gradient(180deg, rgba(2, 6, 23, 0) 0%, rgba(2, 6, 23, 0.78) 100%);
}

.home-model-premium-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 900;
  z-index: 2;
}

.home-model-premium-badge--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #f59e0b);
  border: 1rpx solid rgba(180, 83, 9, 0.32);
  box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.26);
}

.home-model-premium-badge--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 48%, #ec4899);
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.34);
}

.home-model-price {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  max-width: 210rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #ec4899, #f97316);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-model-body {
  padding: 18rpx;
}

.home-model-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.home-model-name {
  min-width: 0;
  font-size: 27rpx;
  font-weight: 900;
  color: #581c87;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-level-pill {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 900;
  color: #b45309;
  background: #fef3c7;
  border: 1rpx solid rgba(245, 158, 11, 0.28);
}

.model-level-pill--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #fde68a 50%, #f59e0b);
  border-color: rgba(180, 83, 9, 0.34);
  box-shadow: 0 6rpx 16rpx rgba(245, 158, 11, 0.22);
}

.model-level-pill--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 52%, #ec4899);
  border-color: rgba(255, 255, 255, 0.5);
  box-shadow: 0 6rpx 18rpx rgba(124, 58, 237, 0.3);
}

.home-model-sub {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-model-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.home-model-tag {
  max-width: 160rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #be185d;
  background: #fdf2f8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
