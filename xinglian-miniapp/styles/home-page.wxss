/* ── 页面背景 ── */
.home-page-root {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
  padding-bottom: calc(152rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 沉浸式页面上滑时，防止内容穿透到状态栏 */
.home-status-bar-shield {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  pointer-events: none;
  background: transparent;
  box-sizing: border-box;
  transition: background 0.18s ease, height 0.18s ease;
}

.home-status-bar-shield--solid {
  background: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(15, 23, 42, 0.08);
}

.home-status-bar-shield-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.home-status-bar-shield-title {
  margin-top: 0;
  line-height: 1;
}

/* ── 沉浸式顶部背景 ── */
.home-immersive-bg-wrap {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 642rpx;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}

.home-immersive-bg {
  display: block;
  width: 100%;
  height: 642rpx;
}

/* 各内容模块独立层级，高于顶部背景图 */
.home-section {
  position: relative;
  z-index: 3;
  padding-left: 25rpx;
  padding-right: 25rpx;
  box-sizing: border-box;
}

/* ── 沉浸式顶部内容 ── */
.home-immersive-head {
  position: relative;
  z-index: 3;
  width: 100%;
  overflow: hidden;
}

.home-immersive-inner {
  position: relative;
  z-index: 1;
  padding: 0 25rpx;
  box-sizing: border-box;
}

/* ── 自定义导航栏 ── */
.home-custom-nav {
  width: 100%;
  box-sizing: border-box;
}

.home-nav-row {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.home-nav-title-wrap {
  margin-top: 12rpx;
}

.home-nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  line-height: 20rpx;
  text-align: center;
}

/* ── 搜索栏 ── */
.home-top-search {
  margin-top: 24rpx;
  margin-bottom: 36rpx;
}

.home-search-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.home-search-bar {
  flex-shrink: 0;
  width: 595rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 28rpx;
  border-radius: 40rpx;
  background: #ffffff;
  border: 2rpx solid #78d608;
  box-sizing: border-box;
}

.home-search-placeholder {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.3;
  color: #94a3b8;
}

.home-search-icon {
  flex-shrink: 0;
  display: block;
  width: 33rpx;
  height: 33rpx;
}

.home-scan-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 85rpx;
  height: 85rpx;
  background: transparent;
}

.home-scan-btn--active {
  opacity: 0.72;
}

.home-scan-icon-img {
  display: block;
  width: 85rpx;
  height: 85rpx;
}

.home-scan-icon-fallback {
  position: relative;
  width: 52rpx;
  height: 52rpx;
}

.home-scan-corner {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-color: #1e293b;
  border-style: solid;
  border-width: 0;
}

.home-scan-corner--tl {
  top: 0;
  left: 0;
  border-top-width: 4rpx;
  border-left-width: 4rpx;
}

.home-scan-corner--tr {
  top: 0;
  right: 0;
  border-top-width: 4rpx;
  border-right-width: 4rpx;
}

.home-scan-corner--bl {
  bottom: 0;
  left: 0;
  border-bottom-width: 4rpx;
  border-left-width: 4rpx;
}

.home-scan-corner--br {
  right: 0;
  bottom: 0;
  border-right-width: 4rpx;
  border-bottom-width: 4rpx;
}

.home-scan-line {
  position: absolute;
  top: 50%;
  left: 6rpx;
  right: 6rpx;
  height: 3rpx;
  margin-top: -1rpx;
  border-radius: 999rpx;
  background: #1e293b;
}

/* ── 等级 Tab ── */
.home-level-tabs {
  display: flex;
  width: 100%;
  min-height: 61rpx;
  margin-bottom: 0;
  align-items: flex-end;
  padding-left: 50rpx;
  padding-right: 50rpx;
}

.home-level-tab {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 18rpx;
  box-sizing: border-box;
}

.home-level-tab--active {
  height: 61rpx;
  padding-bottom: 0;
  align-items: center;
  background: #333333;
  border-radius: 20rpx 20rpx 0 0;
}

.home-level-tab--pressed {
  opacity: 0.82;
}

.home-level-tab-name {
  font-family: "PingFang SC", sans-serif;
  font-weight: 500;
  font-size: 26rpx;
  color: #333333;
  line-height: 20rpx;
  text-align: center;
}

.home-level-tab--active .home-level-tab-name {
  color: #cafc8f;
}

/* ── Banner ── */
.home-banner-wrap {
  position: relative;
  margin-top: 0;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.home-banner-swiper {
  height: 280rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.home-banner-dots {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.home-banner-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #333333;
  opacity: 0.2;
}

.home-banner-dot--active {
  width: 18rpx;
  height: 6rpx;
  border-radius: 3rpx;
  opacity: 1;
}

.home-banner-media,
.home-banner-hit {
  display: block;
  width: 100%;
  height: 280rpx;
}

.home-banner-slide {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.home-banner-kicker,
.home-banner-title,
.home-banner-sub {
  display: block;
  position: relative;
  z-index: 1;
}

.home-banner-kicker {
  margin-bottom: 8rpx;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 0.14em;
  color: rgba(255, 255, 255, 0.82);
}

.home-banner-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #ffffff;
}

.home-banner-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.home-banner-slide--pink {
  background:
    radial-gradient(circle at 88% 18%, rgba(255, 255, 255, 0.22) 0, rgba(255, 255, 255, 0) 120rpx),
    linear-gradient(135deg, #ec4899 0%, #f97316 100%);
}

.home-banner-slide--violet {
  background:
    radial-gradient(circle at 12% 22%, rgba(255, 255, 255, 0.18) 0, rgba(255, 255, 255, 0) 130rpx),
    linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
}

.home-banner-slide--cyan {
  background:
    radial-gradient(circle at 82% 12%, rgba(255, 255, 255, 0.2) 0, rgba(255, 255, 255, 0) 120rpx),
    linear-gradient(135deg, #06b6d4 0%, #6366f1 100%);
}

/* ── 快捷入口 ── */
.home-quick-section {
  margin-top: 36rpx;
  margin-bottom: 20rpx;
}

.home-quick-nav {
  display: flex;
  flex-wrap: nowrap;
}

.home-quick-nav--primary {
  margin-bottom: 16rpx;
}

.home-quick-item {
  flex: 0 0 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.home-quick-item--active {
  opacity: 0.82;
  transform: scale(0.94);
}

.home-quick-item--primary {
  gap: 14rpx;
  padding: 8rpx 0 12rpx;
}

.home-quick-item--secondary {
  gap: 12rpx;
  padding: 6rpx 0 10rpx;
}

.home-quick-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.home-quick-icon-wrap--primary {
  width: 97rpx;
  height: 97rpx;
  border-radius: 24rpx;
}

.home-quick-icon-wrap--secondary {
  min-height: 58rpx;
}

.home-quick-icon {
  display: block;
}

.home-quick-icon--primary {
  width: 97rpx;
  height: 97rpx;
  border-radius: 24rpx;
}

.home-quick-icon--secondary {
  display: block;
}

.home-quick-label {
  max-width: 100%;
  padding: 0 4rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-quick-label--primary {
  font-size: 26rpx;
  line-height: 26rpx;
  font-weight: 500;
  color: #333333;
}

.home-quick-label--secondary {
  font-size: 26rpx;
  line-height: 26rpx;
  font-weight: 500;
  color: #333333;
}

/* ── 商单滚动条 ── */
.home-business-ticker-section {
  margin-bottom: 40rpx;
}

.home-business-ticker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 80rpx;
  padding: 0 16rpx 0 12rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 99rpx 7rpx rgba(182, 186, 193, 0.24);
  box-sizing: border-box;
}

.home-business-ticker-leading {
  flex-shrink: 0;
}

.home-business-ticker-leading-icon {
  display: block;
  width: 70rpx;
  height: 51rpx;
  transform: translateY(-4rpx);
}

.home-business-ticker-swiper {
  flex: 1;
  min-width: 0;
  height: 80rpx;
}

.home-business-ticker-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 80rpx;
  min-width: 0;
}

.home-business-ticker-status {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.3;
}

.home-business-ticker-status--new {
  color: #3f6212;
  background: #d4f57a;
}

.home-business-ticker-status--matched {
  color: #047857;
  background: #ecfdf5;
}

.home-business-ticker-status--active {
  color: #1d4ed8;
  background: #eff6ff;
}

.home-business-ticker-status--pending {
  color: #b45309;
  background: #fffbeb;
}

.home-business-ticker-status--talk {
  color: #7c3aed;
  background: #f5f3ff;
}

.home-business-ticker-status--default {
  color: #475569;
  background: #f1f5f9;
}

.home-business-ticker-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  font-weight: 500;
  color: #475569;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-business-ticker-more-icon {
  display: block;
  flex-shrink: 0;
  width: 10rpx;
  height: 18rpx;
}

/* ── 推荐模特区块 ── */
.home-models-section {
  padding-bottom: 8rpx;
}

.home-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.home-section-title-img {
  flex-shrink: 0;
  width: 285rpx;
  height: 79rpx;
  display: block;
}

.home-section-more {
  flex-shrink: 0;
  width: 73rpx;
  height: 43rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 22rpx;
  color: #333333;
  background: rgba(51, 51, 51, 0);
  border: 1rpx solid #333333;
}

/* ── 模特卡片 ── */
.home-model-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.home-model-card {
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 0 0 calc((100% - 16rpx) / 2);
  min-width: 0;
  border-radius: 20rpx;
  background: #ffffff;
  /* box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06); */
  box-sizing: border-box;
}

.home-model-cover {
  position: relative;
  overflow: hidden;
  height: 400rpx;
  border-radius: 10rpx;
  background: rgba(51, 51, 51, 0);
  box-sizing: border-box;
}

.home-model-img,
.home-model-fallback {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.home-model-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 900;
  color: #64748b;
  background: rgba(51, 51, 51, 0);
}

.home-model-premium-badge-img {
  position: absolute;
  top: -2rpx;
  right: -1rpx;
  width: 144rpx;
  height: 63rpx;
  z-index: 10;
  pointer-events: none;
  display: block;
}

.home-model-premium-badge {
  position: absolute;
  top: -2rpx;
  right: -1rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
  z-index: 10;
  pointer-events: none;
}

.home-model-premium-badge--crown {
  color: #78350f;
  background: #fde68a;
}

.home-model-body {
  padding: 16rpx 14rpx 18rpx;
}

.home-model-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.home-model-name {
  min-width: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #333333;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 6rpx;
}

.home-model-level-badge {
  position: relative;
  flex-shrink: 0;
  width: 127rpx;
  height: 28rpx;
  overflow: hidden;
}

.home-model-level-badge-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.home-model-level-badge-text {
  position: relative;
  z-index: 1;
  display: block;
  box-sizing: border-box;
  height: 28rpx;
  padding-top: 4rpx;
  padding-left: 38rpx;
  font-weight: bold;
  font-size: 24rpx;
  color: #333333;
  line-height: 24rpx;
  font-style: italic;
}

.model-level-pill {
  flex-shrink: 0;
  max-width: 120rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #64748b;
  background: #f1f5f9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-model-location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
  min-width: 0;
}

.home-model-location-icon {
  flex-shrink: 0;
  width: 23rpx;
  height: 26rpx;
  display: block;
}

.home-model-location-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  font-weight: 500;
  color: #999999;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.home-model-price-text {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
}

.home-model-price-symbol {
  font-size: 22rpx;
  font-weight: bold;
  color: #333333;
  line-height: 32rpx;
}

.home-model-price-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  line-height: 32rpx;
}

.home-model-price-unit {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  line-height: 26rpx;
}

.home-model-price-fallback {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  line-height: 32rpx;
}

/* ── 加载 / 空态 ── */
.home-load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 36rpx;
}

.home-load-more-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #94a3b8;
}

.home-empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  min-height: 180rpx;
  padding: 28rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx dashed rgba(203, 213, 225, 0.8);
}

.home-empty-ring {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid rgba(132, 204, 22, 0.16);
  border-top-color: #84cc16;
  border-radius: 999rpx;
  animation: home-empty-spin 0.9s linear infinite;
}

.home-empty-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  text-align: center;
}

@keyframes home-empty-spin {
  to {
    transform: rotate(360deg);
  }
}

/* ── Banner 视频弹层 ── */
.home-banner-video-modal {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.88);
}

.home-banner-video-panel {
  width: 100%;
  max-width: 680rpx;
}

.home-banner-video-player {
  display: block;
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  background: #000000;
}

.home-banner-video-close {
  margin-top: 28rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ── 底部注册栏（home-intro 复用） ── */
.home-intro-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
}

.home-intro-bottom-bar-inner {
  padding-left: 25rpx;
  padding-right: 25rpx;
  box-sizing: border-box;
}

.home-intro-register-btn {
  width: 100%;
  height: 100rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: #1e293b;
  background: linear-gradient(90deg, #c6fa87, #effd9f);
}

.home-intro-register-btn--active {
  opacity: 0.92;
}
