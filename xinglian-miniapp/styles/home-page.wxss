.home-page-root {
  min-height: 100vh;
}

.home-page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 122, 201, 0.32) 0, rgba(255, 122, 201, 0) 230rpx),
    radial-gradient(circle at 88% 12%, rgba(56, 189, 248, 0.26) 0, rgba(56, 189, 248, 0) 250rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 330rpx, #f8fbff 100%);
}

.home-bg {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  pointer-events: none;
}

.home-bg--pink {
  top: 128rpx;
  left: -84rpx;
  width: 210rpx;
  height: 210rpx;
  background: rgba(244, 114, 182, 0.22);
}

.home-bg--blue {
  top: 500rpx;
  right: -96rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(99, 102, 241, 0.18);
}

.home-dash {
  position: relative;
  z-index: 1;
}

.home-search-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(124, 58, 237, 0.08);
}

.home-search-icon {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #7c3aed;
  background: #f5f3ff;
}

.home-search-placeholder {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #94a3b8;
}

.home-section-title,
.home-section-sub,
.home-business-status,
.home-business-budget,
.home-business-label,
.home-business-name,
.home-model-name,
.home-model-sub,
.home-visitor-title,
.home-visitor-sub {
  display: block;
}

.home-visitor-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fdf2f8 48%, #eef2ff 100%);
  border: 1rpx solid rgba(236, 72, 153, 0.16);
  box-shadow: 0 16rpx 34rpx rgba(236, 72, 153, 0.12);
}

.home-visitor-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #312e81;
}

.home-visitor-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.home-register-btn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 55%, #f97316 100%);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.3);
}

.home-level-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.home-level-card {
  position: relative;
  flex: 0 0 calc((100% - 20rpx) / 3);
  min-width: 0;
  overflow: hidden;
  padding: 14rpx 12rpx 14rpx 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(148, 163, 184, 0.13);
  box-sizing: border-box;
}

.home-level-card::before {
  content: "";
  position: absolute;
  top: 14rpx;
  bottom: 14rpx;
  left: 0;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #94a3b8;
}

.home-level-card::after {
  content: "";
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #94a3b8;
  opacity: 0.18;
}

.home-level-card--lv1::before,
.home-level-card--lv1::after {
  background: #ec4899;
}

.home-level-card--lv2::before,
.home-level-card--lv2::after {
  background: #06b6d4;
}

.home-level-card--lv3::before,
.home-level-card--lv3::after {
  background: #f97316;
}

.home-level-card--lv4::before,
.home-level-card--lv4::after {
  background: #f59e0b;
}

.home-level-card--lv5 {
  border-color: rgba(124, 58, 237, 0.18);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(245, 243, 255, 0.9) 100%);
}

.home-level-card--lv5::before,
.home-level-card--lv5::after {
  background: #7c3aed;
}

.home-level-card--lv5 .home-level-name {
  color: #4c1d95;
}

.home-level-card--lv5 .home-level-temperament {
  color: #7c3aed;
}

.home-level-name,
.home-level-temperament {
  position: relative;
  z-index: 1;
  display: block;
  color: #0f172a;
}

.home-level-name {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
}

.home-level-temperament {
  margin-top: 5rpx;
  min-height: 44rpx;
  font-size: 18rpx;
  line-height: 1.32;
  color: #64748b;
}

.home-level-mask {
  position: fixed;
  z-index: 10050;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.46);
}

.home-level-sheet {
  width: 100%;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  padding: 34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at 88% 0%, rgba(236, 72, 153, 0.16) 0, rgba(236, 72, 153, 0) 180rpx),
    #ffffff;
  box-shadow: 0 -18rpx 46rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
}

.home-level-sheet-body {
  height: 52vh;
  max-height: 560rpx;
  box-sizing: border-box;
}

.home-level-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.home-level-sheet-title,
.home-level-sheet-sub,
.home-level-info-label,
.home-level-info-text,
.home-level-permission-text {
  display: block;
}

.home-level-sheet-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #312e81;
}

.home-level-close {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #64748b;
  background: #f1f5f9;
}

.home-level-sheet-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #64748b;
}

.home-level-info-card {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(236, 72, 153, 0.12);
  background: linear-gradient(135deg, #fff7fb 0%, #f8fafc 100%);
}

.home-level-info-label {
  font-size: 22rpx;
  font-weight: 900;
  color: #be185d;
}

.home-level-info-text {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 800;
  color: #334155;
}

.home-level-permission-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 14rpx;
}

.home-level-permission-dot {
  flex-shrink: 0;
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #ec4899;
}

.home-level-permission-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.55;
  color: #475569;
}

.home-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
}

.home-section-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #312e81;
}

.home-section-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.home-section-more {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #db2777;
  background: #fdf2f8;
}

.home-entry-head {
  margin-top: 22rpx;
}

.home-quick-panel {
  position: relative;
  overflow: hidden;
  margin-top: 0;
  padding: 28rpx 22rpx 24rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(236, 72, 153, 0.1) 0, rgba(236, 72, 153, 0) 220rpx),
    radial-gradient(circle at 0% 100%, rgba(99, 102, 241, 0.08) 0, rgba(99, 102, 241, 0) 200rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 251, 254, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    0 22rpx 50rpx rgba(124, 58, 237, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.home-quick-panel-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.home-quick-panel-accent {
  flex-shrink: 0;
  width: 8rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #7c3aed 0%, #ec4899 100%);
  box-shadow: 0 4rpx 12rpx rgba(236, 72, 153, 0.28);
}

.home-quick-panel-titles {
  flex: 1;
  min-width: 0;
}

.home-quick-panel-kicker,
.home-quick-panel-title {
  display: block;
}

.home-quick-panel-kicker {
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.08em;
  color: #c084fc;
}

.home-quick-panel-title {
  margin-top: 4rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #312e81;
  letter-spacing: 0.02em;
}

.home-quick-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.home-quick-item {
  flex: 0 0 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0 16rpx;
  box-sizing: border-box;
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.home-quick-item:nth-child(n + 5) {
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(226, 232, 240, 0.72);
}

.home-quick-item--active {
  opacity: 0.82;
  transform: scale(0.94);
}

.home-quick-icon-wrap {
  position: relative;
  padding: 5rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
  box-shadow:
    0 10rpx 24rpx rgba(15, 23, 42, 0.07),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.home-quick-icon {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 22rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 900;
  color: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}

.home-quick-item--model .home-quick-icon-wrap {
  background: linear-gradient(145deg, #fff1f8 0%, #ffffff 100%);
}

.home-quick-item--model .home-quick-icon {
  background: linear-gradient(145deg, #f472b6 0%, #a855f7 100%);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.32);
}

.home-quick-item--actor .home-quick-icon-wrap {
  background: linear-gradient(145deg, #eff6ff 0%, #ffffff 100%);
}

.home-quick-item--actor .home-quick-icon {
  background: linear-gradient(145deg, #60a5fa 0%, #6366f1 100%);
  box-shadow: 0 8rpx 18rpx rgba(99, 102, 241, 0.28);
}

.home-quick-item--broker .home-quick-icon-wrap {
  background: linear-gradient(145deg, #ecfeff 0%, #ffffff 100%);
}

.home-quick-item--broker .home-quick-icon {
  background: linear-gradient(145deg, #22d3ee 0%, #0891b2 100%);
  box-shadow: 0 8rpx 18rpx rgba(8, 145, 178, 0.28);
}

.home-quick-item--merchant .home-quick-icon-wrap {
  background: linear-gradient(145deg, #fff7ed 0%, #ffffff 100%);
}

.home-quick-item--merchant .home-quick-icon {
  background: linear-gradient(145deg, #fb923c 0%, #ea580c 100%);
  box-shadow: 0 8rpx 18rpx rgba(234, 88, 12, 0.28);
}

.home-quick-item--shoot .home-quick-icon-wrap {
  background: linear-gradient(145deg, #eff6ff 0%, #f5f3ff 100%);
}

.home-quick-item--shoot .home-quick-icon {
  background: linear-gradient(145deg, #3b82f6 0%, #7c3aed 100%);
  box-shadow: 0 8rpx 18rpx rgba(124, 58, 237, 0.28);
}

.home-quick-item--training .home-quick-icon-wrap {
  background: linear-gradient(145deg, #f0fdf4 0%, #ffffff 100%);
}

.home-quick-item--training .home-quick-icon {
  background: linear-gradient(145deg, #4ade80 0%, #16a34a 100%);
  box-shadow: 0 8rpx 18rpx rgba(22, 163, 74, 0.28);
}

.home-quick-item--star .home-quick-icon-wrap {
  background: linear-gradient(145deg, #fffbeb 0%, #ffffff 100%);
}

.home-quick-item--star .home-quick-icon {
  background: linear-gradient(145deg, #fbbf24 0%, #d97706 100%);
  box-shadow: 0 8rpx 18rpx rgba(217, 119, 6, 0.28);
}

.home-quick-item--orders .home-quick-icon-wrap {
  background: linear-gradient(145deg, #fff1f2 0%, #ffffff 100%);
}

.home-quick-item--orders .home-quick-icon {
  background: linear-gradient(145deg, #fb7185 0%, #e11d48 100%);
  box-shadow: 0 8rpx 18rpx rgba(225, 29, 72, 0.28);
}

.home-quick-label {
  max-width: 100%;
  padding: 0 4rpx;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #475569;
  text-align: center;
}

.home-entry-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.home-entry-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  overflow: hidden;
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(124, 58, 237, 0.12);
}

.home-entry-card::after {
  content: "";
  position: absolute;
  top: -70rpx;
  right: -60rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 999rpx;
  opacity: 0.18;
}

.home-entry-card--levels::after {
  background: #ec4899;
}

.home-entry-card--shoot::after {
  background: #06b6d4;
}

.home-entry-icon {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  width: 78rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 26rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%);
  box-shadow: 0 10rpx 22rpx rgba(236, 72, 153, 0.24);
}

.home-entry-card--shoot .home-entry-icon {
  background: linear-gradient(135deg, #06b6d4 0%, #2563eb 100%);
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.22);
}

.home-entry-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.home-entry-title,
.home-entry-desc {
  display: block;
}

.home-entry-title {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #312e81;
}

.home-entry-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #64748b;
}

.home-entry-arrow {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 900;
  color: #c4b5fd;
}

.home-category-head {
  margin-top: 10rpx;
}

.home-category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.home-category-card {
  position: relative;
  flex: 0 0 calc((100% - 12rpx) / 2);
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 24rpx rgba(124, 58, 237, 0.08);
  box-sizing: border-box;
}

.home-category-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #ec4899;
  box-shadow: 0 0 0 8rpx rgba(236, 72, 153, 0.1);
}

.home-category-name {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 900;
  color: #312e81;
}

.home-category-arrow {
  flex-shrink: 0;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 900;
  color: #c4b5fd;
}

.home-category-card--gold .home-category-dot {
  background: #f59e0b;
  box-shadow: 0 0 0 8rpx rgba(245, 158, 11, 0.12);
}

.home-category-card--fashion .home-category-dot {
  background: #ec4899;
}

.home-category-card--product .home-category-dot {
  background: #06b6d4;
  box-shadow: 0 0 0 8rpx rgba(6, 182, 212, 0.12);
}

.home-category-card--film .home-category-dot {
  background: #7c3aed;
  box-shadow: 0 0 0 8rpx rgba(124, 58, 237, 0.12);
}

.home-category-card--event .home-category-dot {
  background: #f97316;
  box-shadow: 0 0 0 8rpx rgba(249, 115, 22, 0.12);
}

.home-category-card--special .home-category-dot {
  background: #10b981;
  box-shadow: 0 0 0 8rpx rgba(16, 185, 129, 0.12);
}

.home-category-card--actor .home-category-dot {
  background: #2563eb;
  box-shadow: 0 0 0 8rpx rgba(37, 99, 235, 0.12);
}

.home-category-card--foreign .home-category-dot {
  background: #64748b;
  box-shadow: 0 0 0 8rpx rgba(100, 116, 139, 0.12);
}

.home-business-toggle {
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.22);
}

.home-model-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.home-business-swiper {
  border-radius: 28rpx;
  overflow: hidden;
}

.home-business-swiper--collapsed {
  height: 186rpx;
}

.home-business-swiper--expanded {
  height: 480rpx;
}

.home-business-slide {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  height: 100%;
}

.home-business-card {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 152rpx;
  padding: 18rpx 20rpx 16rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  background:
    linear-gradient(90deg, rgba(124, 58, 237, 0.08), rgba(236, 72, 153, 0.04)),
    rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 26rpx rgba(124, 58, 237, 0.1);
}

.home-business-card::before {
  content: "";
  position: absolute;
  top: 18rpx;
  bottom: 18rpx;
  left: 0;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #7c3aed, #ec4899);
}

.home-business-top,
.home-business-parties {
  display: flex;
  align-items: center;
}

.home-business-top {
  justify-content: space-between;
  gap: 16rpx;
}

.home-business-status {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #be185d;
  background: #fdf2f8;
}

.home-business-budget {
  font-size: 24rpx;
  font-weight: 900;
  color: #be185d;
}

.home-business-content {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  font-size: 22rpx;
  line-height: 1.35;
  color: #475569;
}

.home-business-parties {
  gap: 12rpx;
  margin-top: 10rpx;
}

.home-business-party {
  flex: 1;
  min-width: 0;
}

.home-business-label {
  font-size: 18rpx;
  color: #64748b;
}

.home-business-name {
  margin-top: 3rpx;
  font-size: 23rpx;
  font-weight: 900;
  color: #312e81;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-business-arrow {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed, #ec4899);
}

.home-model-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 0 0 calc((100% - 16rpx) / 2);
  min-width: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(124, 58, 237, 0.12);
  box-sizing: border-box;
}

.home-model-card--crown {
  border: 3rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(251, 191, 36, 0.2) 0, rgba(251, 191, 36, 0) 180rpx),
    linear-gradient(#fffbeb, #ffffff) padding-box,
    linear-gradient(135deg, #f59e0b, #fde68a 48%, #b45309) border-box;
  box-shadow: 0 20rpx 48rpx rgba(180, 83, 9, 0.22);
}

.home-model-card--sky {
  border: 3rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(236, 72, 153, 0.24) 0, rgba(236, 72, 153, 0) 190rpx),
    radial-gradient(circle at 0% 12%, rgba(56, 189, 248, 0.18) 0, rgba(56, 189, 248, 0) 170rpx),
    linear-gradient(180deg, #f5f3ff 0%, #fff7fb 100%) padding-box,
    linear-gradient(135deg, #f59e0b, #fde68a 38%, #7c3aed 72%, #ec4899) border-box;
  box-shadow: 0 22rpx 56rpx rgba(88, 28, 135, 0.28);
}

.home-model-cover {
  position: relative;
  overflow: hidden;
  height: 430rpx;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff 52%, #fff7ed);
}

.home-model-card--crown .home-model-cover {
  background: linear-gradient(135deg, #78350f, #f59e0b 52%, #fde68a);
}

.home-model-card--sky .home-model-cover {
  background: linear-gradient(135deg, #020617, #4c1d95 48%, #ec4899);
}

.home-model-premium-aura {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 280rpx;
  height: 280rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.32) 0, rgba(255, 255, 255, 0) 66%);
  pointer-events: none;
}

.home-model-img,
.home-model-fallback {
  width: 100%;
  height: 100%;
}

.home-model-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 900;
  color: #be185d;
}

.home-model-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(88, 28, 135, 0.64) 100%);
}

.home-model-card--crown .home-model-gradient {
  background: linear-gradient(180deg, rgba(120, 53, 15, 0) 0%, rgba(120, 53, 15, 0.72) 100%);
}

.home-model-card--sky .home-model-gradient {
  background: linear-gradient(180deg, rgba(2, 6, 23, 0) 0%, rgba(2, 6, 23, 0.78) 100%);
}

.home-model-premium-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 900;
  z-index: 2;
}

.home-model-premium-badge--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #f59e0b);
  border: 1rpx solid rgba(180, 83, 9, 0.32);
  box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.26);
}

.home-model-premium-badge--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 48%, #ec4899);
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.34);
}

.home-model-price {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  max-width: 230rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #ec4899, #f97316);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-model-body {
  padding: 14rpx;
}

.home-model-name-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.home-model-name {
  min-width: 0;
  font-size: 24rpx;
  font-weight: 900;
  color: #581c87;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-level-pill {
  flex-shrink: 0;
  max-width: 112rpx;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  font-weight: 900;
  color: #b45309;
  background: #fef3c7;
  border: 1rpx solid rgba(245, 158, 11, 0.28);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-level-pill--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #fde68a 50%, #f59e0b);
  border-color: rgba(180, 83, 9, 0.34);
  box-shadow: 0 6rpx 16rpx rgba(245, 158, 11, 0.22);
}

.model-level-pill--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 52%, #ec4899);
  border-color: rgba(255, 255, 255, 0.5);
  box-shadow: 0 6rpx 18rpx rgba(124, 58, 237, 0.3);
}

.home-model-sub {
  margin-top: 6rpx;
  font-size: 19rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-model-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 10rpx;
}

.home-model-tag {
  max-width: 132rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  color: #be185d;
  background: #fdf2f8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
