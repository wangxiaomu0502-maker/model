.wallet-hero {
  padding: 36rpx 32rpx 32rpx;
  margin-bottom: 28rpx;
}

.hero-label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  letter-spacing: 1rpx;
}

.hero-amount {
  display: block;
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.hero-pending-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(129, 140, 248, 0.25);
}

.pending-k {
  font-size: 26rpx;
  color: #475569;
}

.pending-v {
  font-size: 32rpx;
  font-weight: 700;
  color: #4338ca;
}

.muted {
  color: #94a3b8;
}

.hint-banner {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #b45309;
  background: rgba(251, 191, 36, 0.15);
  border: 1rpx solid rgba(245, 158, 11, 0.35);
}

.section-head {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.empty-ledger {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #475569;
}

.empty-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}

.ledger-list {
  padding-bottom: 24rpx;
}

.ledger-item {
  padding: 24rpx 26rpx;
  margin-bottom: 18rpx;
}

.ledger-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.ledger-title {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
  line-height: 1.4;
}

.ledger-amt {
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ledger-amt--pos {
  color: #059669;
}

.ledger-amt--neg {
  color: #c2410c;
}

.ledger-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.ledger-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.load-more {
  margin: 12rpx auto 0;
  display: block;
  background: transparent;
  border: none;
  color: #6366f1;
  font-size: 26rpx;
}

.load-more::after {
  border: none;
}

.state-block {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
}
