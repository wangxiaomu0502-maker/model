/* 统计看板 + 商家模特列表共用样式（原 pages/home/home.wxss） */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef4ff 0%, #f7f9fd 220rpx, #f7f9fd 100%);
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ----- 商家首页 · 模特列表（复用 model-dash / dash-hero / stats-card / stat-*） ----- */
.dash-hero--merchant {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.dash-hero-count {
  flex-shrink: 0;
  min-width: 120rpx;
  height: 96rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  color: #ffffff;
}

.dash-hero-count-num {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.dash-hero-count-unit {
  margin-left: 6rpx;
  font-size: 24rpx;
  line-height: 1;
}

.merchant-empty-card {
  text-align: center;
}

.merchant-empty-hint {
  display: block;
  margin-top: 0;
}

.model-list-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 8rpx 4rpx 0;
}

.model-list-toolbar-title {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
}

.model-list-mode-switch {
  flex: 1;
  display: flex;
  max-width: 420rpx;
  margin-left: auto;
  padding: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e2e8f0;
}

.model-list-mode-item {
  flex: 1;
  text-align: center;
  padding: 13rpx 0;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #64748b;
}

.model-list-mode-item--on {
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  box-shadow: 0 6rpx 16rpx rgba(79, 70, 229, 0.28);
}

.merchant-item:active {
  opacity: 0.92;
}

.merchant-item {
  padding: 18rpx 18rpx;
  border-radius: 18rpx;
}

.merchant-item-head {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.merchant-av--media {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #eef2ff;
}

.merchant-av-img {
  width: 100%;
  height: 100%;
  display: block;
}

.merchant-av-fallback {
  display: block;
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #4338ca;
}

.merchant-item-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.merchant-item-name {
  font-size: 27rpx;
  font-weight: 600;
  color: #111827;
}

.merchant-item-sub {
  font-size: 22rpx;
  color: #64748b;
  font-variant-numeric: tabular-nums;
}

.merchant-chip-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.merchant-chip {
  font-size: 20rpx;
  color: #64748b;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid #e2e8f0;
}

.merchant-chip--muted {
  color: #94a3b8;
  border-style: dashed;
}

.merchant-model-card {
  margin-top: 10rpx;
  padding: 12rpx 12rpx 10rpx;
  border-radius: 14rpx;
  background: linear-gradient(165deg, #fafbff 0%, #f4f6ff 100%);
  border: 1rpx solid rgba(99, 102, 241, 0.14);
  box-shadow: 0 4rpx 14rpx rgba(67, 56, 202, 0.05);
}

.merchant-model-card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.merchant-model-card-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #312e81;
  letter-spacing: 0.06em;
}

.merchant-model-card-sub {
  font-size: 18rpx;
  color: #94a3b8;
  font-weight: 500;
}

.merchant-card-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.merchant-card-thumb {
  display: inline-block;
  vertical-align: top;
  width: 108rpx;
  height: 144rpx;
  margin-right: 8rpx;
  border-radius: 10rpx;
  background: #e2e8f0;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}

.merchant-card-measure-wrap {
  padding-top: 2rpx;
}

.merchant-card-measure-title {
  display: block;
  font-size: 18rpx;
  font-weight: 600;
  color: #64748b;
  letter-spacing: 0.02em;
  margin-bottom: 6rpx;
}

.merchant-card-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx 8rpx;
}

.merchant-card-chip {
  font-size: 19rpx;
  line-height: 1.35;
  color: #4338ca;
  padding: 5rpx 9rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(99, 102, 241, 0.22);
  font-variant-numeric: tabular-nums;
}

.merchant-price-row {
  margin-top: 12rpx;
}

.merchant-intro-clamp {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.merchant-item-foot {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(129, 140, 248, 0.15);
  display: flex;
  justify-content: flex-end;
}

.merchant-item-more {
  font-size: 22rpx;
  font-weight: 600;
  color: #6366f1;
}

.model-large-grid {
  display: flex;
  flex-wrap: wrap;
  column-gap: 9rpx;
  row-gap: 12rpx;
}

.model-large-card {
  flex: 0 0 32%;
  width: 32%;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.96);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.07);
}

.model-large-card:active {
  opacity: 0.92;
  transform: scale(0.99);
}

.model-large-cover {
  position: relative;
  height: 236rpx;
  background: linear-gradient(135deg, #e0e7ff, #f5f3ff);
  overflow: hidden;
}

.model-large-cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.model-large-cover-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 800;
  color: #4f46e5;
}

.model-large-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 86rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.4) 100%);
  pointer-events: none;
}

.model-large-count {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  padding: 4rpx 9rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(15, 23, 42, 0.45);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.model-large-body {
  padding: 10rpx 10rpx 12rpx;
}

.model-large-name {
  display: block;
  font-size: 23rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-large-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-large-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5rpx;
  margin-top: 8rpx;
  max-height: 40rpx;
  overflow: hidden;
}

.model-large-tag {
  max-width: 90rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  color: #4f46e5;
  background: #eef2ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ----- 模特首页数据看板 ----- */
.model-dash {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dash-hero {
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #312e81 0%, #4338ca 48%, #6366f1 100%);
  box-shadow: 0 14rpx 32rpx rgba(67, 56, 202, 0.35);
}

.dash-hero-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dash-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.04em;
}

.dash-desc {
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.82);
}

.period-tabs {
  display: flex;
  gap: 12rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid #e2e8f0;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  border-radius: 999rpx;
}

.period-tab-on {
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  box-shadow: 0 6rpx 16rpx rgba(79, 70, 229, 0.35);
}

.stats-card {
  padding: 26rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e8eef7;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.stat-row {
  display: flex;
  align-items: stretch;
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 4rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  font-variant-numeric: tabular-nums;
}

.stat-money {
  font-size: 36rpx;
}

.merchant-item .merchant-price-num.stat-value {
  font-size: 28rpx;
}

.stat-currency {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
}

.stat-unit {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 6rpx;
}

.stat-divider {
  width: 1rpx;
  margin: 0 16rpx;
  background: #f1f5f9;
}

.stat-pending {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-pending-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.stat-pending-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #c2410c;
  font-variant-numeric: tabular-nums;
}

.stat-pending-secondary {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e2e8f0;
}

.stat-pending-secondary .stat-pending-value {
  color: #b45309;
}

.stats-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #94a3b8;
}

.trend-card {
  padding: 24rpx 20rpx 28rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e8eef7;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.trend-head {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.dash-loading,
.dash-error {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #64748b;
}

.dash-error {
  color: #b91c1c;
}

.trend-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 8rpx;
}

.trend-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.trend-amount {
  font-size: 18rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  font-variant-numeric: tabular-nums;
}

.trend-bar-track {
  width: 100%;
  height: 168rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.trend-bar {
  width: 100%;
  border-radius: 12rpx;
  min-height: 8rpx;
  background: linear-gradient(180deg, #a5b4fc 0%, #6366f1 55%, #4f46e5 100%);
}

.trend-day {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #94a3b8;
}
