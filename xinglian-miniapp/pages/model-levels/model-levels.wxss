.model-level-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 28rpx 24rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 122, 201, 0.28) 0, rgba(255, 122, 201, 0) 230rpx),
    radial-gradient(circle at 88% 12%, rgba(56, 189, 248, 0.24) 0, rgba(56, 189, 248, 0) 250rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 330rpx, #f8fbff 100%);
}

.model-level-bg {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  pointer-events: none;
}

.model-level-bg--pink {
  top: 150rpx;
  left: -80rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(244, 114, 182, 0.18);
}

.model-level-bg--blue {
  top: 620rpx;
  right: -96rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(99, 102, 241, 0.16);
}

.model-level-hero,
.model-level-list {
  position: relative;
  z-index: 1;
}

.model-level-hero {
  overflow: hidden;
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 52%, #f97316 100%);
  box-shadow: 0 18rpx 44rpx rgba(236, 72, 153, 0.3);
}

.model-level-kicker,
.model-level-title,
.model-level-desc,
.model-level-code,
.model-level-name,
.model-level-temperament,
.model-level-intro,
.model-level-label,
.model-level-text,
.model-level-permission-text {
  display: block;
}

.model-level-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.18);
}

.model-level-title {
  margin-top: 20rpx;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 900;
  color: #ffffff;
}

.model-level-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.86);
}

.model-level-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.model-level-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(124, 58, 237, 0.1);
}

.model-level-card::before {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 8rpx;
  background: #94a3b8;
}

.model-level-card--lv1::before {
  background: #ec4899;
}

.model-level-card--lv2::before {
  background: #06b6d4;
}

.model-level-card--lv3::before {
  background: #f97316;
}

.model-level-card--lv4::before {
  background: #f59e0b;
}

.model-level-card--lv5 {
  border-color: rgba(124, 58, 237, 0.18);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(245, 243, 255, 0.94) 100%);
}

.model-level-card--lv5::before {
  background: #7c3aed;
}

.model-level-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.model-level-code {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 900;
  color: #db2777;
}

.model-level-name {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #312e81;
}

.model-level-temperament {
  flex-shrink: 0;
  max-width: 250rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
  color: #be185d;
  background: #fdf2f8;
}

.model-level-intro {
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #475569;
}

.model-level-info {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff7fb 0%, #f8fafc 100%);
}

.model-level-label {
  font-size: 22rpx;
  font-weight: 900;
  color: #be185d;
}

.model-level-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 800;
  color: #334155;
}

.model-level-permission {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 14rpx;
}

.model-level-dot {
  flex-shrink: 0;
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #ec4899;
}

.model-level-permission-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.55;
  color: #475569;
}
