@import "../../styles/xl-theme.wxss";

.section {
  padding: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 14rpx;
}

.field + .field {
  margin-top: 14rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 23rpx;
  color: #4b5563;
}

.input {
  width: 100%;
  height: 72rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
}

.save-btn {
  margin-top: 28rpx;
  margin-bottom: 24rpx;
}
