@import "../../styles/xl-theme.wxss";

.page.page-themed-root {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

/* 顶部状态：毛玻璃条内自动换行，无横向滚动 */
.tabs-bar {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(129, 140, 248, 0.22);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 14rpx 40rpx rgba(79, 70, 229, 0.08);
  box-sizing: border-box;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.tabs-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
  padding: 2rpx 2rpx 4rpx;
  box-sizing: border-box;
}

.tab {
  position: relative;
  flex-shrink: 0;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.35;
  background: rgba(248, 250, 252, 0.95);
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  box-sizing: border-box;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.tab:active {
  transform: scale(0.97);
  opacity: 0.92;
}

.tab-label {
  display: inline-block;
  vertical-align: middle;
  white-space: nowrap;
}

.tab-badge-dot {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #ef4444;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.5);
}

.tab-on {
  color: #312e81;
  font-weight: 700;
  border-color: transparent;
  background: linear-gradient(135deg, rgba(238, 242, 255, 0.98) 0%, rgba(224, 231, 255, 0.95) 45%, rgba(237, 233, 254, 0.92) 100%);
  box-shadow:
    0 0 0 2rpx rgba(99, 102, 241, 0.35),
    0 10rpx 28rpx rgba(79, 70, 229, 0.18);
}

.order-card {
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.order-card-header {
  margin-bottom: 12rpx;
}

.order-no {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.35;
  border: 1rpx solid transparent;
}

/* 订单状态 order_status */
.tag--os1 {
  color: #4338ca;
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(129, 140, 248, 0.35);
}

.tag--os2 {
  color: #1d4ed8;
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(96, 165, 250, 0.38);
}

.tag--os3 {
  color: #b45309;
  background: rgba(251, 191, 36, 0.16);
  border-color: rgba(245, 158, 11, 0.32);
}

.tag--os4 {
  color: #047857;
  background: rgba(16, 185, 129, 0.12);
  border-color: rgba(52, 211, 153, 0.32);
}

.tag--os9 {
  color: #64748b;
  background: rgba(148, 163, 184, 0.14);
  border-color: rgba(148, 163, 184, 0.32);
}

/* 支付 payment_status */
.tag--ps0 {
  color: #b45309;
  background: rgba(254, 243, 199, 0.85);
  border-color: rgba(245, 158, 11, 0.35);
}

.tag--ps1 {
  color: #047857;
  background: rgba(209, 250, 229, 0.75);
  border-color: rgba(52, 211, 153, 0.35);
}

.tag--ps2 {
  color: #1e40af;
  background: rgba(219, 234, 254, 0.9);
  border-color: rgba(96, 165, 250, 0.35);
}

.tag--ps3 {
  color: #64748b;
  background: rgba(241, 245, 249, 0.95);
  border-color: rgba(148, 163, 184, 0.35);
}

.line {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  margin-bottom: 6rpx;
}

.counterpart {
  color: #475569;
}

.row-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(129, 140, 248, 0.15);
}

.amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.more {
  font-size: 24rpx;
  color: #94a3b8;
}

.hint {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  padding: 40rpx 0;
}

.hint.empty {
  padding-top: 80rpx;
}

.hint.foot {
  padding: 24rpx 0 40rpx;
}

.bottom-space {
  height: 48rpx;
}
