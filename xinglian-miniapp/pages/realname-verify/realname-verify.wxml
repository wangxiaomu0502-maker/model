<view class="page-root">
  <view class="scroll-body">
    <view class="hero">
      <view class="hero-blob hero-blob-1"></view>
      <view class="hero-blob hero-blob-2"></view>
      <view class="hero-grid"></view>
      <view class="hero-inner">
        <text class="hero-kicker">账户安全</text>
        <text class="hero-title">实名认证</text>
        <text class="hero-subtitle" wx:if="{{isBoundModelMode && realnameCompleted}}">您已完成实名认证，以下为已登记的证件信息。</text>
        <text class="hero-subtitle" wx:elif="{{isBoundModelMode}}">平台已为您开通账号，请上传身份证正反面并完成识别。</text>
        <text class="hero-subtitle" wx:else>完成昵称、头像、手机号与身份证识别后即可提交注册。</text>
        <text class="hero-tip" wx:if="{{isBoundModelMode && realnameCompleted}}">证件信息仅供本人查看</text>
        <text class="hero-tip" wx:elif="{{isBoundModelMode}}">账号手机号已绑定，请完成身份证 OCR</text>
        <text class="hero-tip" wx:elif="{{isBrokerRole}}">请先选择经纪人类型，再按顺序完成以下 4 步</text>
        <text class="hero-tip" wx:else>请按顺序完成以下 4 步</text>
      </view>
    </view>

    <view wx:if="{{isBrokerRole}}" class="card broker-kind-card">
      <view class="step-head">
        <view class="step-num-wrap step-num-wrap-accent"><text class="step-num">★</text></view>
        <text class="step-title">经纪人类型</text>
      </view>
      <text class="step-tip">专业经纪人需上传经纪人证；兼职经纪人无需上传。单张照片不能超过5M。</text>
      <view class="broker-kind-row">
        <view
          class="broker-kind-opt {{brokerKind === 'professional' ? 'broker-kind-opt-active' : ''}}"
          data-kind="professional"
          bindtap="onBrokerKindTap"
        >
          <text class="broker-kind-opt-title">专业经纪人</text>
          <text class="broker-kind-opt-sub">需上传经纪人证</text>
        </view>
        <view
          class="broker-kind-opt {{brokerKind === 'part-time' ? 'broker-kind-opt-active' : ''}}"
          data-kind="part-time"
          bindtap="onBrokerKindTap"
        >
          <text class="broker-kind-opt-title">兼职经纪人</text>
          <text class="broker-kind-opt-sub">无需上传证件</text>
        </view>
      </view>

      <view wx:if="{{brokerKind === 'professional'}}" class="broker-license-block">
        <text class="broker-license-label">经纪人证</text>
        <view
          class="broker-license-upload"
          bindtap="onPickBrokerLicense"
          hover-class="broker-license-upload-hover"
        >
          <image
            wx:if="{{brokerLicensePreviewUrl}}"
            class="broker-license-img"
            src="{{brokerLicensePreviewUrl}}"
            mode="aspectFit"
          />
          <view wx:else class="broker-license-placeholder">
            <text class="broker-license-ph-main">点击上传经纪人证</text>
            <text class="broker-license-ph-sub">支持相册或拍照</text>
          </view>
        </view>
        <text class="mini-muted upload-size-tip">单张照片不能超过5M</text>
        <text wx:if="{{brokerLicenseStoredUrl}}" class="mini-success">经纪人证已上传</text>
        <text wx:elif="{{brokerLicenseUploading}}" class="mini-muted">上传中…</text>
      </view>
    </view>

    <!-- 1 昵称 -->
    <view class="card" wx:if="{{!isBoundModelMode}}">
      <view class="step-head">
        <view class="step-num-wrap"><text class="step-num">1</text></view>
        <text class="step-title">填写昵称</text>
      </view>
      <text class="step-tip">使用微信昵称填写能力，便于展示与联系。</text>
      <input
        class="nickname-input"
        type="nickname"
        value="{{nickname}}"
        placeholder="请输入昵称"
        maxlength="50"
        placeholder-class="input-ph"
        bind:input="onNicknameInput"
      />
    </view>

    <!-- 2 头像 -->
    <view class="card" wx:if="{{!isBoundModelMode}}">
      <view class="step-head">
        <view class="step-num-wrap"><text class="step-num">2</text></view>
        <text class="step-title">设置头像</text>
      </view>
      <text class="step-tip">可从相册或拍照选择，选择后将自动上传并保存。单张照片不能超过5M。</text>
      <view class="step-visual-center">
        <view
          class="avatar-btn"
          bindtap="onPickAvatar"
          hover-class="avatar-btn-hover"
        >
          <view class="avatar-circle">
            <image
              wx:if="{{avatarPreviewUrl}}"
              class="avatar-img"
              src="{{avatarPreviewUrl}}"
              mode="aspectFill"
            />
            <view wx:else class="avatar-placeholder">
              <text class="avatar-ph-main">点击选择头像</text>
            </view>
          </view>
        </view>
      </view>
      <text wx:if="{{avatarStoredUrl}}" class="mini-success">头像已上传</text>
    </view>

    <!-- 3 手机号 -->
    <view class="card">
      <view class="step-head">
        <view class="step-num-wrap"><text class="step-num">{{isBoundModelMode ? '1' : '3'}}</text></view>
        <text class="step-title">{{isBoundModelMode ? '已绑定手机号' : '手机号授权'}}</text>
      </view>
      <text class="step-tip" wx:if="{{isBoundModelMode}}">后管创建账号时已登记，无需重复授权。</text>
      <text class="step-tip" wx:else>用于账号安全校验与后续联系。</text>
      <view wx:if="{{!isBoundModelMode && !phoneAuthorized}}" class="step-inline-actions">
        <button
          class="primary-btn primary-btn-compact"
          hover-class="primary-btn-hover"
          hover-stay-time="70"
          open-type="getPhoneNumber"
          bind:getphonenumber="onGetPhoneNumber"
          loading="{{phoneLoading}}"
          disabled="{{phoneLoading}}"
        >
          授权手机号
        </button>
      </view>
      <view wx:elif="{{phoneAuthorized}}" class="phone-auth-success">
        <text class="phone-success-title">{{isBoundModelMode ? '账号已绑定' : '已完成手机号授权'}}</text>
        <text class="phone-success-line">手机号：{{phoneNumber}}</text>
      </view>
      <view wx:else class="phone-auth-success">
        <text class="phone-success-title">未绑定手机号</text>
        <text class="phone-success-line">请联系平台管理员补全手机号</text>
      </view>
    </view>

    <!-- 4 OCR -->
    <view class="card card-last">
      <view class="step-head">
        <view class="step-num-wrap"><text class="step-num">{{isBoundModelMode ? '2' : '4'}}</text></view>
        <text class="step-title">身份证 OCR 识别</text>
      </view>
      <text class="step-tip" wx:if="{{realnameCompleted}}">已登记的身份证正反面照片。</text>
      <text class="step-tip" wx:else>请分别上传人像面与国徽面，两张就绪后点击「开始识别」。单张照片不能超过5M。</text>
      <view class="upload-grid">
        <view
          class="upload-item {{realnameCompleted ? 'upload-item-readonly' : ''}}"
          bindtap="onChooseIdCardFrontImage"
          hover-class="{{realnameCompleted ? '' : 'upload-item-hover'}}"
        >
          <image
            wx:if="{{idCardFrontImageLocalPath}}"
            class="preview"
            src="{{idCardFrontImageLocalPath}}"
            mode="aspectFill"
          />
          <view wx:else class="placeholder-wrap">
            <text class="placeholder-title">人像面</text>
            <text class="placeholder-subtitle">拍照或相册</text>
          </view>
        </view>
        <view
          class="upload-item {{realnameCompleted ? 'upload-item-readonly' : ''}}"
          bindtap="onChooseIdCardBackImage"
          hover-class="{{realnameCompleted ? '' : 'upload-item-hover'}}"
        >
          <image
            wx:if="{{idCardBackImageLocalPath}}"
            class="preview"
            src="{{idCardBackImageLocalPath}}"
            mode="aspectFill"
          />
          <view wx:else class="placeholder-wrap">
            <text class="placeholder-title">国徽面</text>
            <text class="placeholder-subtitle">拍照或相册</text>
          </view>
        </view>
      </view>
      <view wx:if="{{!realnameCompleted && idCardFrontImageLocalPath && idCardBackImageLocalPath}}" class="step-inline-actions">
        <button
          class="primary-btn primary-btn-compact"
          hover-class="primary-btn-hover"
          hover-stay-time="70"
          bindtap="onRunOcr"
          loading="{{ocrFrontLoading || ocrBackLoading}}"
          disabled="{{ocrFrontLoading || ocrBackLoading}}"
        >
          开始识别
        </button>
      </view>
      <view wx:if="{{ocrFrontDone}}" class="result-box">
        <text class="result-title">人像面识别结果</text>
        <text class="result-line">姓名：{{realName}}</text>
        <text class="result-line">身份证号：{{idCardNo}}</text>
      </view>
      <view wx:if="{{ocrBackDone}}" class="result-box">
        <text class="result-title">国徽面识别结果</text>
        <text class="result-line">签发机关：{{issueAuthority}}</text>
        <text class="result-line">有效期：{{validDate}}</text>
      </view>
      <view wx:if="{{!realnameCompleted && ocrFrontDone && ocrBackDone}}" class="step-inline-actions">
        <button
          class="primary-btn primary-btn-compact"
          hover-class="primary-btn-hover"
          hover-stay-time="70"
          bindtap="onStartFaceVerify"
          loading="{{faceVerifyLoading}}"
          disabled="{{faceVerifyLoading}}"
        >
          {{eidVerified ? '人脸核身已完成' : '开始人脸核身'}}
        </button>
      </view>
      <text wx:if="{{eidVerified}}" class="mini-success">E证通人脸核身已通过</text>
    </view>

    <view class="scroll-spacer"></view>
  </view>

  <view class="bottom-bar">
    <button
      class="next-btn"
      hover-class="next-btn-hover"
      hover-stay-time="70"
      bindtap="goNext"
      loading="{{submitLoading}}"
      disabled="{{submitLoading}}"
    >
      {{realnameCompleted ? '返回' : (isBoundModelMode ? '完成实名认证' : '下一步：签署协议')}}
    </button>
  </view>
</view>
