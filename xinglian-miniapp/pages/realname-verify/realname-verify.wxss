/* 与 Intro / 身份选择页统一的 Indigo → Violet 主题 */

.page-root {
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef4ff 0%, #f7f9fd 28%, #f3f6fc 100%);
}

.scroll-body {
  padding: 24rpx 28rpx 0;
  padding-bottom: calc(32rpx + 92rpx + 48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 36rpx 28rpx 34rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #4338ca 48%, #7c3aed 100%);
  box-shadow: 0 18rpx 44rpx rgba(67, 56, 202, 0.3), 0 6rpx 16rpx rgba(15, 23, 42, 0.06);
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-blob-1 {
  width: 260rpx;
  height: 260rpx;
  top: -130rpx;
  right: -72rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, transparent 68%);
}

.hero-blob-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -60rpx;
  left: -48rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 72%);
}

.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.07;
  background-image: linear-gradient(rgba(255, 255, 255, 0.95) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.95) 1rpx, transparent 1rpx);
  background-size: 42rpx 42rpx;
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 2;
}

.hero-kicker {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255, 255, 255, 0.92);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: #ffffff;
  line-height: 1.2;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.88);
}

.hero-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.card {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 26rpx 24rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06), 0 2rpx 10rpx rgba(15, 23, 42, 0.03);
}

.card-last {
  margin-bottom: 8rpx;
}

/* 序号与标题同一行居中，下方正文铺满卡片宽度 */
.step-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.step-num-wrap {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #6366f1 0%, #4f46e5 100%);
  box-shadow: 0 8rpx 18rpx rgba(79, 70, 229, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.step-title {
  font-size: 32rpx;
  color: #0f172a;
  font-weight: 700;
  line-height: 1.25;
  text-align: center;
}

.step-tip {
  display: block;
  margin-top: 16rpx;
  padding: 0 8rpx;
  font-size: 25rpx;
  color: #64748b;
  line-height: 1.55;
  text-align: center;
}

.step-visual-center {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.nickname-input {
  margin-top: 20rpx;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(199, 210, 254, 0.95);
  background: linear-gradient(180deg, #fafbff 0%, #f8fafc 100%);
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.input-ph {
  color: #94a3b8;
}

.avatar-btn {
  margin-top: 0;
  padding: 0;
  width: 168rpx;
  height: 168rpx;
  min-width: 168rpx;
  max-width: 168rpx;
  border-radius: 84rpx;
  overflow: hidden;
  background: transparent;
  border: none;
  display: inline-flex;
  flex: 0 0 168rpx;
  align-items: center;
  justify-content: center;
  line-height: 0;
  font-size: 0;
  box-sizing: border-box;
}

.avatar-btn-hover {
  opacity: 0.92;
}

.avatar-btn::after {
  border: none;
}

.avatar-circle {
  width: 100%;
  height: 100%;
  border-radius: 84rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #eef2ff 0%, #f8fafc 100%);
  border: 3rpx dashed rgba(99, 102, 241, 0.45);
  box-sizing: border-box;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 84rpx;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  box-sizing: border-box;
}

.avatar-ph-main {
  font-size: 24rpx;
  font-weight: 600;
  color: #4338ca;
  text-align: center;
  line-height: 1.4;
}

.mini-success {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #15803d;
  font-weight: 600;
  text-align: center;
}

.upload-grid {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  max-width: 600rpx;
  margin-left: auto;
  margin-right: auto;
}

.upload-item {
  flex: 1;
  height: 228rpx;
  border: 2rpx dashed rgba(99, 102, 241, 0.35);
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fafbff 0%, #f8fafc 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-item-hover {
  opacity: 0.92;
  background: #f1f5f9;
}

.placeholder-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx;
}

.placeholder-title {
  color: #4338ca;
  font-size: 28rpx;
  font-weight: 700;
}

.placeholder-subtitle {
  color: #94a3b8;
  font-size: 22rpx;
}

.preview {
  width: 100%;
  height: 100%;
}

.step-inline-actions {
  display: flex;
  justify-content: center;
  margin-top: 22rpx;
}

.primary-btn {
  margin-top: 22rpx;
  width: 100%;
  height: 92rpx;
  border-radius: 999rpx;
  border: none;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.04em;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 45%, #7c3aed 100%);
  box-shadow: 0 14rpx 32rpx rgba(79, 70, 229, 0.32);
}

.primary-btn-compact {
  margin-top: 0;
  width: auto;
  min-width: 200rpx;
  padding: 0 32rpx;
  height: 64rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.22);
}

.primary-btn-hover {
  opacity: 0.92;
}

.primary-btn::after {
  border: none;
}

.result-box {
  margin-top: 22rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #f5f3ff 0%, #eef2ff 50%, #f8fafc 100%);
  border: 1rpx solid rgba(199, 210, 254, 0.95);
}

.result-title {
  display: block;
  font-size: 26rpx;
  color: #4338ca;
  font-weight: 700;
}

.result-line {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #334155;
  line-height: 1.45;
}

.phone-auth-success {
  margin-top: 22rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #f0fdf4 0%, #ecfdf5 100%);
  border: 1rpx solid #bbf7d0;
  text-align: center;
}

.phone-success-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #166534;
}

.phone-success-line {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #15803d;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 -8rpx 28rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.next-btn {
  width: 100%;
  height: 92rpx;
  line-height: 1;
  padding: 0;
  border-radius: 999rpx;
  border: none;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 45%, #7c3aed 100%);
  box-shadow: 0 14rpx 36rpx rgba(79, 70, 229, 0.33);
}

.next-btn-hover {
  opacity: 0.92;
}

.next-btn::after {
  border: none;
}

.scroll-spacer {
  height: 12rpx;
}

.broker-kind-card {
  margin-bottom: 4rpx;
}

.step-num-wrap-accent {
  background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
}

.broker-kind-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.broker-kind-opt {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.45);
  background: rgba(248, 250, 252, 0.9);
  box-sizing: border-box;
}

.broker-kind-opt-active {
  border-color: #4f46e5;
  background: linear-gradient(180deg, rgba(238, 242, 255, 0.95) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.12);
}

.broker-kind-opt-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.broker-kind-opt-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.broker-license-block {
  margin-top: 28rpx;
}

.broker-license-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 16rpx;
}

.broker-license-upload {
  min-height: 280rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(99, 102, 241, 0.45);
  background: rgba(248, 250, 252, 0.85);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.broker-license-upload-hover {
  opacity: 0.88;
}

.broker-license-img {
  width: 100%;
  max-height: 420rpx;
}

.broker-license-placeholder {
  padding: 40rpx 24rpx;
  text-align: center;
}

.broker-license-ph-main {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4f46e5;
}

.broker-license-ph-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.mini-muted {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.upload-size-tip {
  text-align: center;
}
