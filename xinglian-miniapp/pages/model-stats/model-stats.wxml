<view class="container">
  <view class="model-dash">
    <view class="dash-hero">
      <view class="dash-hero-main">
        <text class="dash-title">接单概览</text>
        <text class="dash-desc">接单数、收入与待结算按北京时间统计</text>
      </view>
    </view>

    <view class="period-tabs">
      <view class="period-tab {{periodTab === 'today' ? 'period-tab-on' : ''}}" data-tab="today" bindtap="onPeriodTab">今日</view>
      <view class="period-tab {{periodTab === 'week' ? 'period-tab-on' : ''}}" data-tab="week" bindtap="onPeriodTab">本周</view>
      <view class="period-tab {{periodTab === 'month' ? 'period-tab-on' : ''}}" data-tab="month" bindtap="onPeriodTab">本月</view>
    </view>

    <view class="stats-card">
      <view class="stat-row">
        <view class="stat-block">
          <text class="stat-label">接单数</text>
          <view class="stat-value-row"><text class="stat-value">{{currentStats.orderCount}}</text><text class="stat-unit">笔</text></view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-block">
          <text class="stat-label">收入</text>
          <view class="stat-value-row"><text class="stat-currency">¥</text><text class="stat-value stat-money">{{currentStats.incomeYuan}}</text></view>
        </view>
      </view>
      <view class="stat-pending">
        <text class="stat-pending-label">待结算金额</text>
        <text class="stat-pending-value">¥{{currentStats.pendingYuan}}</text>
      </view>
      <text class="stats-hint">收入：已分账到账（按分账日）。待结算：在途(1～2)与已付未分账(3～4 且未后台分账)的模特实收预估。</text>
    </view>

    <view class="trend-card">
      <text class="trend-head">近7日收入趋势</text>
      <view wx:if="{{dashboardLoading}}" class="dash-loading">加载中…</view>
      <text wx:elif="{{dashboardError}}" class="dash-error">{{dashboardError}}</text>
      <view wx:else class="trend-chart">
        <view wx:for="{{trend7dDisplay}}" wx:key="date" class="trend-col">
          <text class="trend-amount">¥{{item.incomeText}}</text>
          <view class="trend-bar-track"><view class="trend-bar" style="height: {{item.barPct}}%;"></view></view>
          <text class="trend-day">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
