@import "../../styles/xl-theme.wxss";

/* —— 顶部引导（紧凑，不过分抢眼）—— */

.head-banner {
  position: relative;
  overflow: hidden;
  border-radius: 26rpx;
  padding: 28rpx 26rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(125deg, #3730a3 0%, #4f46e5 38%, #7c3aed 100%);
  box-shadow: 0 14rpx 36rpx rgba(79, 70, 229, 0.22);
}

.head-banner::after {
  content: "";
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  right: -72rpx;
  top: -88rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18) 0%, transparent 65%);
  pointer-events: none;
}

.head-kicker {
  position: relative;
  z-index: 1;
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255, 255, 255, 0.92);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.head-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 18rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 0.02em;
}

.head-desc {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.78);
}

/* —— 主体卡片 —— */

.body-card {
  padding: 28rpx 26rpx 30rpx;
}

.sec-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.sec-mark {
  width: 6rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #818cf8, #4f46e5);
  flex-shrink: 0;
}

.sec-mark--soft {
  background: linear-gradient(180deg, #c4b5fd, #8b5cf6);
}

.sec-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.sec-sub {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: #94a3b8;
  margin-bottom: 18rpx;
}

.pill-wrap {
  margin-bottom: 18rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.25;
}

.pill--on {
  color: #047857;
  background: rgba(16, 185, 129, 0.11);
  border: 1rpx solid rgba(16, 185, 129, 0.28);
}

.pill--off {
  color: #a16207;
  background: rgba(251, 191, 36, 0.12);
  border: 1rpx solid rgba(245, 158, 11, 0.32);
}

.divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(148, 163, 184, 0.45) 20%,
    rgba(148, 163, 184, 0.45) 80%,
    transparent
  );
}

.kv {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.kv:first-of-type {
  border-top: none;
  padding-top: 0;
}

.kv-last {
  padding-bottom: 4rpx;
}

.kv-k {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #64748b;
}

.kv-v {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  word-break: break-all;
}

.kv-mono {
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.03em;
}

/* 未绑定：占位胶囊，避免「— / 未绑定」的生硬感 */
.kv-ph {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  min-width: 0;
}

.kv-ph-text {
  max-width: 100%;
  padding: 10rpx 22rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #94a3b8;
  line-height: 1.35;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  border: 1rpx dashed rgba(148, 163, 184, 0.55);
  box-sizing: border-box;
}

.kv-ph-text--mono {
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.06em;
}

/* 输入：固定高度，避免与主题叠加后异常 */
.field {
  margin-top: 4rpx;
  margin-bottom: 8rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #64748b;
}

.page-themed-root .field .input {
  width: 100%;
  box-sizing: border-box;
  height: 84rpx;
  line-height: normal;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #111827;
}

.actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 28rpx;
}

.ghost-btn {
  flex-shrink: 0;
  min-width: 160rpx;
  height: 80rpx;
  margin: 0;
  padding: 0 24rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #64748b;
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.ghost-btn::after {
  border: none;
}

.ghost-btn--hover {
  opacity: 0.85;
}

.main-btn {
  flex: 1;
  height: 80rpx;
  margin: 0;
  padding: 0;
  line-height: 80rpx;
  border-radius: 40rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #6366f1 0%, #7c3aed 52%, #8b5cf6 100%);
  box-shadow: 0 12rpx 32rpx rgba(79, 70, 229, 0.28);
}

.main-btn::after {
  border: none;
}

.main-btn[disabled] {
  opacity: 0.55;
}

.main-btn--hover {
  opacity: 0.92;
}

.note {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(99, 102, 241, 0.06);
  border: 1rpx solid rgba(129, 140, 248, 0.22);
}

.note-inner {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

/* —— 加载占位 —— */

.load-card {
  padding: 32rpx 26rpx;
}

.sk-line {
  height: 26rpx;
  border-radius: 10rpx;
  margin-bottom: 22rpx;
  background: #eef2f7;
}

.sk-line:last-child {
  margin-bottom: 0;
}

.sk-line--w70 {
  width: 70%;
}

.sk-line--w85 {
  width: 85%;
}

/* —— 不可用 —— */

.state-card {
  padding: 40rpx 32rpx;
  text-align: center;
}

.state-lead {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.state-msg {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #94a3b8;
}
