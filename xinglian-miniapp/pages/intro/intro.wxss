/* 主题与「我的」顶部卡、首页客户区对齐：indigo → violet 渐变 + slate 中性色 */

.page-root {
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef4ff 0%, #f7f9fd 28%, #f3f6fc 100%);
}

.scroll-inner {
  padding: 0 28rpx;
  /* 为底部悬浮按钮留出空间：按钮高度 + bar 内边距 */
  padding-bottom: calc(24rpx + 92rpx + 28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav {
  position: relative;
  padding-bottom: 16rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-back {
  position: absolute;
  left: 28rpx;
  bottom: 14rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 56rpx;
  padding: 0 20rpx 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(199, 210, 254, 0.95);
  box-shadow: 0 8rpx 22rpx rgba(67, 56, 202, 0.08);
  box-sizing: border-box;
}

.nav-back:active {
  opacity: 0.86;
}

.nav-back-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #4338ca;
  transform: translateY(-1rpx);
}

.nav-back-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #4338ca;
  letter-spacing: 0.04em;
}

.nav-badge {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #4338ca;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(199, 210, 254, 0.95);
  box-shadow: 0 8rpx 22rpx rgba(67, 56, 202, 0.08);
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 44rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #4338ca 48%, #7c3aed 100%);
  box-shadow: 0 18rpx 48rpx rgba(67, 56, 202, 0.35), 0 8rpx 20rpx rgba(15, 23, 42, 0.08);
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-blob-1 {
  width: 280rpx;
  height: 280rpx;
  top: -140rpx;
  right: -80rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, transparent 68%);
}

.hero-blob-2 {
  width: 220rpx;
  height: 220rpx;
  bottom: -72rpx;
  left: -56rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.14) 0%, transparent 72%);
}

.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.08;
  background-image: linear-gradient(rgba(255, 255, 255, 0.95) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.95) 1rpx, transparent 1rpx);
  background-size: 44rpx 44rpx;
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 2;
}

.hero-label {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 0.14em;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.title {
  display: block;
  margin-top: 28rpx;
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 0.06em;
  color: #ffffff;
  line-height: 1.15;
}

.subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.94);
  letter-spacing: 0.06em;
}

.hero-desc {
  display: block;
  margin-top: 22rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.78);
}

.section {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 26rpx;
  padding: 30rpx 28rpx 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06), 0 2rpx 10rpx rgba(15, 23, 42, 0.03);
}

.section-last {
  margin-bottom: 8rpx;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.section-accent {
  width: 8rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #6366f1 0%, #4f46e5 45%, #7c3aed 100%);
  flex-shrink: 0;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.03em;
}

.item {
  display: block;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.75;
}

.item-gap {
  margin-top: 18rpx;
}

.role-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.role-card {
  width: 100%;
  border-radius: 20rpx;
  padding: 22rpx 22rpx 22rpx 26rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  border-left-width: 8rpx;
}

.role-tone-0 {
  background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
  border-left-color: #6366f1;
  border-color: rgba(199, 210, 254, 0.65);
}

.role-tone-1 {
  background: linear-gradient(135deg, #fafbff 0%, #eff6ff 100%);
  border-left-color: #3b82f6;
  border-color: rgba(191, 219, 254, 0.75);
}

.role-tone-2 {
  background: linear-gradient(135deg, #faf5ff 0%, #f5f3ff 100%);
  border-left-color: #9333ea;
  border-color: rgba(233, 213, 255, 0.85);
}

.role-tone-3 {
  background: linear-gradient(135deg, #fdf4ff 0%, #fce7f3 35%, #f8fafc 100%);
  border-left-color: #c026d3;
  border-color: rgba(251, 207, 232, 0.65);
}

.role-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.role-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.65;
  color: #64748b;
}

.feature-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.feature-row:last-child {
  margin-bottom: 0;
}

.feature-icon-wrap {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: linear-gradient(145deg, #e0e7ff 0%, #ddd6fe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-num {
  font-size: 22rpx;
  font-weight: 800;
  color: #4338ca;
}

.feature-text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.7;
  color: #334155;
  padding-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
}

.action-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 999rpx;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 31rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 45%, #7c3aed 100%);
  box-shadow: 0 14rpx 36rpx rgba(79, 70, 229, 0.38);
}

.action-btn-bar {
  margin: 0;
}

.action-btn-hover {
  opacity: 0.92;
}

.action-btn::after {
  border: none;
}

.scroll-bottom-spacer {
  height: 16rpx;
}
