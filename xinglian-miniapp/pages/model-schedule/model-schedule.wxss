@import "../../styles/xl-theme.wxss";

.section {
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
}

.hint {
  margin-top: 8rpx;
  display: block;
  font-size: 22rpx;
  color: #6b7280;
}

.mode-switch {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.mode-item {
  flex: 1;
  height: 66rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3f1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
}

.status-list {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.status-item {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #334155;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.calendar-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.day-item {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 12rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: #475569;
}

.status {
  margin-top: 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  line-height: 22rpx;
}

.status.none {
  color: #64748b;
  background: #f1f5f9;
}

.status.available {
  color: #15803d;
  background: #dcfce7;
}

.status.full {
  color: #b91c1c;
  background: #fee2e2;
}

.status.rest {
  color: #4b5563;
  background: #e5e7eb;
}
