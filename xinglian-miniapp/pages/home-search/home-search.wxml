<view class="page home-search-page">
  <view class="search card home-search-toolbar">
    <input
      class="search-input"
      placeholder="搜索模特/经纪人/商家"
      value="{{searchDraft}}"
      focus="{{inputFocus}}"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
    <text wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">清除</text>
    <text wx:else class="search-go" bindtap="onSearchConfirm">搜索</text>
  </view>

  <scroll-view scroll-y class="scroll" enhanced show-scrollbar="{{false}}">
    <view wx:if="{{!keyword}}" class="hint">输入名称后搜索模特、经纪人或商家</view>
    <view wx:elif="{{loading}}" class="hint">搜索中…</view>
    <view wx:elif="{{loadError}}" class="hint empty">{{loadError}}</view>
    <view wx:elif="{{list.length === 0}}" class="hint empty">未找到相关结果</view>

    <view
      wx:for="{{list}}"
      wx:key="userNo"
      class="card item-card"
      data-type="{{item.type}}"
      data-user-no="{{item.userNo}}"
      bindtap="onItemTap"
    >
      <view class="item-head">
        <view class="av av--{{item.type}}">
          <image wx:if="{{item.showAvatarImg}}" class="av-img" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="av-fallback">{{item.avatarText}}</text>
        </view>
        <view class="item-meta">
          <view class="item-name-row">
            <text class="item-name">{{item.nickname}}</text>
            <text class="type-tag type-tag--{{item.type}}">{{item.typeLabel}}</text>
          </view>
          <text class="item-sub">{{item.subtitle}}</text>
        </view>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
