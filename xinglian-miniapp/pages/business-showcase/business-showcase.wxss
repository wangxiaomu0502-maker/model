.business-showcase-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 10% 6%, rgba(167, 139, 250, 0.24) 0, rgba(167, 139, 250, 0) 280rpx),
    linear-gradient(180deg, #faf5ff 0%, #fdf2f8 320rpx, #f8fafc 100%);
}

.showcase-hero {
  padding: 40rpx 32rpx 36rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background:
    radial-gradient(circle at 84% 16%, rgba(255, 255, 255, 0.26) 0, rgba(255, 255, 255, 0) 180rpx),
    linear-gradient(135deg, #6d28d9 0%, #7c3aed 46%, #db2777 100%);
  box-shadow: 0 18rpx 46rpx rgba(124, 58, 237, 0.28);
}

.showcase-kicker,
.showcase-title,
.showcase-desc {
  display: block;
}

.showcase-kicker {
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
  opacity: 0.88;
}

.showcase-title {
  margin-top: 16rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.showcase-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.65;
  opacity: 0.92;
}

.showcase-stat-row {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.showcase-stat {
  flex: 1;
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  text-align: center;
}

.showcase-stat-num,
.showcase-stat-label {
  display: block;
}

.showcase-stat-num {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.showcase-stat-label {
  margin-top: 6rpx;
  font-size: 21rpx;
  font-weight: 700;
  opacity: 0.9;
}

.showcase-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 38rpx rgba(148, 163, 184, 0.14);
}

.showcase-card--flow {
  background: linear-gradient(180deg, #fff 0%, #faf5ff 100%);
}

.showcase-card-head {
  margin-bottom: 8rpx;
}

.showcase-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #6d28d9;
}

.showcase-section-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.point-card {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(124, 58, 237, 0.1);
}

.point-card:last-child {
  border-bottom: 0;
}

.point-title,
.point-desc {
  display: block;
}

.point-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.point-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #64748b;
}

.order-card {
  position: relative;
  margin-top: 16rpx;
  padding: 20rpx 20rpx 18rpx 24rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(90deg, rgba(124, 58, 237, 0.06), rgba(236, 72, 153, 0.03)),
    #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 10rpx 24rpx rgba(124, 58, 237, 0.08);
}

.order-card::before {
  content: "";
  position: absolute;
  top: 18rpx;
  bottom: 18rpx;
  left: 0;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #7c3aed, #ec4899);
}

.order-card-top,
.order-parties {
  display: flex;
  align-items: center;
}

.order-card-top {
  justify-content: space-between;
  gap: 16rpx;
}

.order-status {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.order-status--matched {
  color: #047857;
  background: #d1fae5;
}

.order-status--active {
  color: #1d4ed8;
  background: #dbeafe;
}

.order-status--pending {
  color: #b45309;
  background: #fef3c7;
}

.order-status--talk {
  color: #7c3aed;
  background: #ede9fe;
}

.order-status--new {
  color: #db2777;
  background: #fce7f3;
}

.order-status--default {
  color: #475569;
  background: #f1f5f9;
}

.order-budget {
  font-size: 28rpx;
  font-weight: 900;
  color: #7c3aed;
}

.order-content {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #334155;
}

.order-parties {
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx dashed rgba(148, 163, 184, 0.35);
}

.order-party {
  flex: 1;
  min-width: 0;
}

.order-label,
.order-name,
.order-city {
  display: block;
}

.order-label {
  font-size: 20rpx;
  color: #94a3b8;
}

.order-name {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-arrow {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #c084fc;
  font-weight: 900;
}

.order-city {
  margin-top: 12rpx;
  font-size: 21rpx;
  color: #94a3b8;
}

.flow-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(124, 58, 237, 0.08);
}

.flow-row:last-child {
  border-bottom: 0;
}

.flow-step {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #7c3aed;
  background: #ede9fe;
}

.flow-body {
  flex: 1;
  min-width: 0;
}

.flow-title,
.flow-desc {
  display: block;
}

.flow-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.flow-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}
