.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  color: #222222;
  font-weight: 600;
}

.subtitle {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #666666;
}
