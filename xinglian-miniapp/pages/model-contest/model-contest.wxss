.promo-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 16% 5%, rgba(244, 114, 182, 0.34) 0, rgba(244, 114, 182, 0) 250rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 360rpx, #f8fbff 100%);
}

.promo-bg {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.promo-bg--a {
  top: 120rpx;
  right: -80rpx;
  width: 250rpx;
  height: 250rpx;
  background: rgba(236, 72, 153, 0.18);
}

.promo-bg--b {
  bottom: 120rpx;
  left: -90rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(124, 58, 237, 0.16);
}

.promo-hero,
.promo-card {
  position: relative;
  z-index: 1;
}

.promo-hero {
  padding: 40rpx 32rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background:
    radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.34) 0, rgba(255, 255, 255, 0) 170rpx),
    linear-gradient(135deg, #7c3aed 0%, #ec4899 50%, #f97316 100%);
  box-shadow: 0 18rpx 46rpx rgba(236, 72, 153, 0.3);
}

.promo-kicker,
.promo-title,
.promo-desc {
  display: block;
}

.promo-kicker {
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
  opacity: 0.88;
}

.promo-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.promo-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.65;
  opacity: 0.9;
}

.promo-hero-badge {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.promo-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 38rpx rgba(148, 163, 184, 0.16);
}

.promo-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #581c87;
  margin-bottom: 18rpx;
}

.promo-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.promo-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #be185d;
  background: #fdf2f8;
  border: 1rpx solid rgba(244, 114, 182, 0.22);
}

.promo-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.promo-step-index {
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 50%;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed, #ec4899);
}

.promo-step-text,
.promo-body {
  font-size: 26rpx;
  line-height: 1.7;
  color: #475569;
}
