@import "../../styles/xl-theme.wxss";

.order-detail-page.page-themed-root {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.detail-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
  box-sizing: border-box;
}

/* ---------- 顶部 Hero ---------- */
.hero {
  padding: 28rpx 26rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 248, 255, 0.96) 100%);
  border: 1rpx solid rgba(129, 140, 248, 0.28);
  box-shadow: 0 20rpx 48rpx rgba(79, 70, 229, 0.08);
}

.hero-eyebrow {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  letter-spacing: 0.02em;
  margin-bottom: 10rpx;
}

.hero-order-no {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.04em;
  font-family: ui-monospace, monospace;
  word-break: break-all;
  line-height: 1.35;
  margin-bottom: 16rpx;
}

.hero-tags {
  margin-top: 4rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.35;
  border: 1rpx solid transparent;
}

.tag--os1 {
  color: #4338ca;
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(129, 140, 248, 0.35);
}

.tag--os2 {
  color: #1d4ed8;
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(96, 165, 250, 0.38);
}

.tag--os3 {
  color: #b45309;
  background: rgba(251, 191, 36, 0.16);
  border-color: rgba(245, 158, 11, 0.32);
}

.tag--os4 {
  color: #047857;
  background: rgba(16, 185, 129, 0.12);
  border-color: rgba(52, 211, 153, 0.32);
}

.tag--os9 {
  color: #64748b;
  background: rgba(148, 163, 184, 0.14);
  border-color: rgba(148, 163, 184, 0.32);
}

.tag--ps0 {
  color: #b45309;
  background: rgba(254, 243, 199, 0.85);
  border-color: rgba(245, 158, 11, 0.35);
}

.tag--ps1 {
  color: #047857;
  background: rgba(209, 250, 229, 0.75);
  border-color: rgba(52, 211, 153, 0.35);
}

.tag--ps2 {
  color: #1e40af;
  background: rgba(219, 234, 254, 0.9);
  border-color: rgba(96, 165, 250, 0.35);
}

.tag--ps3 {
  color: #64748b;
  background: rgba(241, 245, 249, 0.95);
  border-color: rgba(148, 163, 184, 0.35);
}

/* ---------- 金额面板 ---------- */
.amount-panel {
  padding: 26rpx 26rpx 22rpx;
  margin-bottom: 20rpx;
}

.amount-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 24rpx;
}

.amount-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
}

.amount-total {
  display: flex;
  align-items: baseline;
  color: #4f46e5;
}

.amount-currency {
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 4rpx;
}

.amount-num {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1;
}

.amount-divider {
  height: 1rpx;
  margin: 22rpx 0 18rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(129, 140, 248, 0.35) 20%,
    rgba(129, 140, 248, 0.35) 80%,
    transparent 100%
  );
}

.detail-rows {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-rows--tight {
  gap: 12rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.detail-k {
  font-size: 26rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.detail-v {
  font-size: 26rpx;
  color: #334155;
  text-align: right;
  line-height: 1.45;
}

.detail-v--strong {
  font-weight: 700;
  color: #0f172a;
}

.detail-v--mono {
  font-family: ui-monospace, monospace;
  font-size: 24rpx;
}

.detail-v--tags {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* ---------- 信息卡片 ---------- */
.info-card {
  padding: 24rpx 26rpx 26rpx;
  margin-bottom: 20rpx;
}

.card-cap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.cap-dot {
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #6366f1 0%, #8b5cf6 100%);
}

.cap-dot--violet {
  background: linear-gradient(180deg, #7c3aed 0%, #a78bfa 100%);
}

.cap-dot--green {
  background: linear-gradient(180deg, #059669 0%, #34d399 100%);
}

.cap-dot--amber {
  background: linear-gradient(180deg, #d97706 0%, #fbbf24 100%);
}

.cap-dot--slate {
  background: linear-gradient(180deg, #64748b 0%, #94a3b8 100%);
}

.cap-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.remark-box {
  margin-top: 8rpx;
  padding: 18rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(241, 245, 249, 0.85);
  border: 1rpx solid rgba(148, 163, 184, 0.25);
}

.remark-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.remark-body {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.55;
}

.remark-block {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.55;
  padding: 8rpx 0 4rpx;
  word-break: break-word;
}

/* ---------- 参与方 ---------- */
.party-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.party-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 8rpx 0;
}

.party-split {
  height: 1rpx;
  margin: 16rpx 0;
  background: rgba(226, 232, 240, 0.95);
}

.party-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  flex-shrink: 0;
}

.party-avatar--m {
  background: linear-gradient(145deg, #6366f1 0%, #4f46e5 100%);
  box-shadow: 0 10rpx 24rpx rgba(79, 70, 229, 0.28);
}

.party-avatar--f {
  background: linear-gradient(145deg, #a855f7 0%, #7c3aed 100%);
  box-shadow: 0 10rpx 24rpx rgba(124, 58, 237, 0.28);
}

.party-meta {
  flex: 1;
  min-width: 0;
}

.party-role {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.party-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.35;
  word-break: break-all;
}

.party-no {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  font-family: ui-monospace, monospace;
}

.bottom-space {
  height: 24rpx;
}

/* ---------- 加载 / 空 ---------- */
.loading-panel {
  padding: 48rpx 24rpx 80rpx;
}

.loading-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.sk-line {
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #e2e8f0 0%, #f1f5f9 50%, #e2e8f0 100%);
  background-size: 200% 100%;
  margin-bottom: 18rpx;
}

.sk-line--long {
  width: 100%;
}

.sk-line--med {
  width: 72%;
}

.sk-line--short {
  width: 44%;
  margin-bottom: 0;
}

.loading-text {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}

.hint {
  text-align: center;
  padding: 120rpx 32rpx;
  font-size: 28rpx;
  color: #94a3b8;
}

/* ---------- 底部按钮间距 ---------- */
.bottom-bar--stack .save-btn + .save-btn {
  margin-top: 14rpx;
}

.bottom-bar--stack .ghost-btn {
  margin-top: 14rpx;
}

.bottom-bar--dual {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 20rpx;
}

.bottom-bar--dual .bar-btn--dual {
  flex: 1;
  width: auto !important;
  min-width: 0;
  margin-top: 0 !important;
}

.bottom-bar--dual .save-btn + .save-btn,
.bottom-bar--dual .ghost-btn + .ghost-btn {
  margin-top: 0;
}

.ghost-btn {
  width: 100%;
  height: 88rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #b91c1c;
  background: rgba(254, 226, 226, 0.9);
  border: 1rpx solid rgba(248, 113, 113, 0.45);
}

.ghost-btn::after {
  border: none;
}

.page-themed-root .bottom-bar .ghost-btn {
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1.2;
}

/* ---------- 模特取消原因弹层 ---------- */
.reason-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2000;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
}

.reason-sheet {
  width: 100%;
  max-width: 640rpx;
  padding: 32rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.reason-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.reason-hint {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  margin-bottom: 20rpx;
}

.reason-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.5;
  color: #334155;
  background: rgba(248, 250, 252, 0.95);
  border: 1rpx solid rgba(148, 163, 184, 0.35);
  border-radius: 20rpx;
  margin-bottom: 28rpx;
}

.reason-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.ghost-btn--sheet,
.save-btn--sheet {
  flex: 1;
  width: auto !important;
  height: 80rpx !important;
  font-size: 28rpx !important;
  margin: 0 !important;
  box-shadow: none !important;
}

.ghost-btn--sheet {
  border-radius: 999rpx !important;
}
