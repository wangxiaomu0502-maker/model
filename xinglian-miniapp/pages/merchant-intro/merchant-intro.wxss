.merchant-intro-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 88% 8%, rgba(52, 211, 153, 0.22) 0, rgba(52, 211, 153, 0) 280rpx),
    linear-gradient(180deg, #ecfdf5 0%, #f0fdfa 320rpx, #f8fafc 100%);
}

.intro-hero {
  padding: 40rpx 32rpx 36rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.28) 0, rgba(255, 255, 255, 0) 180rpx),
    linear-gradient(135deg, #047857 0%, #059669 45%, #0e7490 100%);
  box-shadow: 0 18rpx 46rpx rgba(5, 150, 105, 0.28);
}

.intro-kicker,
.intro-title,
.intro-desc {
  display: block;
}

.intro-kicker {
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
  opacity: 0.88;
}

.intro-title {
  margin-top: 16rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.intro-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.65;
  opacity: 0.92;
}

.intro-hero-stat {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 28rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.intro-hero-stat-num {
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.intro-hero-stat-label {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.92;
}

.intro-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 38rpx rgba(148, 163, 184, 0.14);
}

.intro-card--ethics {
  background: linear-gradient(180deg, #fff 0%, #ecfdf5 100%);
}

.intro-card-head {
  margin-bottom: 8rpx;
}

.intro-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #047857;
}

.intro-section-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.intro-loading {
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #94a3b8;
}

.region-list {
  margin-top: 12rpx;
}

.region-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(5, 150, 105, 0.1);
}

.region-row:last-child {
  border-bottom: 0;
}

.region-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.region-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1e293b;
}

.region-count {
  font-size: 24rpx;
  font-weight: 800;
  color: #059669;
}

.region-bar-track {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #d1fae5;
  overflow: hidden;
}

.region-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #34d399 0%, #059669 100%);
}

.intro-footnote {
  display: block;
  margin-top: 16rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: #94a3b8;
}

.point-card {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(5, 150, 105, 0.1);
}

.point-card:last-child {
  border-bottom: 0;
}

.point-title,
.point-desc {
  display: block;
}

.point-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.point-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #64748b;
}

.intro-ethics-lead {
  display: block;
  margin-top: 4rpx;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  line-height: 1.65;
  color: #475569;
}

.ethics-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 10rpx 0;
}

.ethics-dot {
  flex-shrink: 0;
  font-size: 28rpx;
  line-height: 1.5;
  color: #059669;
  font-weight: 900;
}

.ethics-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.65;
  color: #334155;
}
