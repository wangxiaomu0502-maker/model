@import "../../styles/xl-theme.wxss";

.section {
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 10rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.row-text {
  font-size: 26rpx;
  color: #111827;
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

/* 原生 switch 尺寸偏大，缩小视觉与占位（scale 后右侧留白略收） */
.switch-shrink {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  transform: scale(0.68);
  transform-origin: right center;
  margin-right: -6rpx;
}

.hint {
  margin-top: 10rpx;
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}

.chip-list {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dbe3f1;
  background: #f8fafc;
  color: #4b5563;
  font-size: 24rpx;
}

.empty {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.btn-wrap {
  margin-top: 12rpx;
}
