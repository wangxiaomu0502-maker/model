.page {
  min-height: 100vh;
  background: #f3f6fc;
  padding: 24rpx;
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 弹窗打开时与 page-meta 配合，避免底层列表仍能被拖动 */
.page--modal-open {
  overflow: hidden;
  height: 100vh;
  box-sizing: border-box;
}

.top-card {
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 48rpx rgba(37, 99, 235, 0.14), 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}

.top-hero {
  position: relative;
  padding: 36rpx 28rpx 36rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #4338ca 52%, #7c3aed 100%);
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-blob-1 {
  width: 260rpx;
  height: 260rpx;
  top: -120rpx;
  right: -72rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, transparent 68%);
}

.hero-blob-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -56rpx;
  left: -48rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.14) 0%, transparent 70%);
}

.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.07;
  background-image: linear-gradient(rgba(255, 255, 255, 0.9) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.9) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  pointer-events: none;
}

.profile-row {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

.avatar-shell {
  flex-shrink: 0;
  padding: 6rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.12));
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  overflow: hidden;
  display: block;
  background: #e8eefc;
}

.profile-info {
  flex: 1;
  margin-left: 22rpx;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.nickname-tap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 4rpx 0;
}

.nickname-tap-hover {
  opacity: 0.88;
}

.nickname {
  flex: 1;
  min-width: 0;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.02em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nickname-edit-icon {
  flex-shrink: 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1;
}

.nickname-edit-sheet .nickname-edit-tip {
  display: block;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.nickname-edit-input {
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
  font-size: 30rpx;
  color: #0f172a;
}

.nickname-edit-ph {
  color: #94a3b8;
}

.title-inline {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.identity-chip {
  font-size: 20rpx;
  font-weight: 700;
  color: #3730a3;
  background: rgba(255, 255, 255, 0.94);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.center-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.72);
}

.avatar-upload-tip {
  position: relative;
  z-index: 2;
  display: block;
  margin-top: 18rpx;
  padding-left: 140rpx;
  font-size: 21rpx;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.68);
}

.hero-meta-strip {
  position: relative;
  z-index: 2;
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.hero-meta-strip + .hero-meta-strip {
  margin-top: 14rpx;
}

.hero-meta-strip-accent {
  background: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.38);
}

.hero-meta-status-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  min-width: 0;
}

.hero-meta-status-wrap .hero-meta-status {
  flex: 0 1 auto;
}

.audit-reject-hint {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
}

.audit-reject-hint-hover {
  opacity: 0.85;
}

.audit-reject-hint-mark {
  font-size: 22rpx;
  font-weight: 700;
  color: #fffbeb;
  line-height: 1;
}

.hero-audit-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  min-width: 0;
}

/* mini 按钮 + 覆盖默认体量；flex 解决内置样式导致文字纵向偏移 */
.audit-submit-btn {
  flex-shrink: 0;
  margin: 0 !important;
  padding: 0 18rpx !important;
  min-height: 0 !important;
  height: 48rpx !important;
  box-sizing: border-box !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  line-height: 1 !important;
  font-size: 20rpx !important;
  font-weight: 600;
  color: #4338ca !important;
  background: rgba(255, 255, 255, 0.92) !important;
  border-radius: 999rpx !important;
  border: 1rpx solid rgba(255, 255, 255, 0.65) !important;
  box-shadow: none;
}

.audit-submit-btn::after {
  border: none;
}

.audit-submit-btn-hover {
  opacity: 0.9;
  filter: brightness(0.98);
}

.audit-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(15, 23, 42, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
}

.audit-modal-sheet {
  width: 100%;
  max-width: 560rpx;
  max-height: 78vh;
  overflow-y: auto;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 28rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.98);
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.16), 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.audit-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 18rpx;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.audit-modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.02em;
}

.audit-modal-close {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 500;
  color: #64748b;
  padding: 8rpx 4rpx;
}

.audit-modal-loading {
  padding: 56rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}

.audit-modal-progress-card {
  background: linear-gradient(145deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 14rpx;
  padding: 18rpx 18rpx 14rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #e8eef4;
}

.audit-modal-progress-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.audit-modal-progress-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.audit-modal-progress-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  font-variant-numeric: tabular-nums;
}

.audit-modal-percent-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #94a3b8;
  text-align: right;
}

.audit-modal-progress-bar {
  height: 8rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.audit-modal-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #3b82f6, #6366f1);
  transition: width 0.2s ease-out;
}

.audit-modal-list {
  border-radius: 14rpx;
  background: #fafbfc;
  padding: 6rpx 0;
  margin-bottom: 16rpx;
  border: 1rpx solid #eef2f7;
}

.audit-modal-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.audit-modal-row:last-child {
  border-bottom: none;
}

.audit-modal-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e2e8f0;
  border: 2rpx solid #cbd5e1;
  box-sizing: border-box;
}

.audit-modal-dot.on {
  background: #22c55e;
  border-color: #16a34a;
}

.audit-modal-name {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

.audit-modal-flag {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
}

.audit-modal-flag.done {
  color: #15803d;
}

.audit-modal-flag.todo {
  color: #b45309;
}

.audit-modal-hint {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.55;
  margin-bottom: 8rpx;
  padding: 0 4rpx;
}

.audit-modal-submit {
  width: 100%;
  margin: 28rpx 0 18rpx;
  height: 76rpx;
  box-sizing: border-box;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  line-height: 1 !important;
  border-radius: 12rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: #4f46e5;
}

.audit-modal-submit[disabled] {
  background: #cbd5e1 !important;
  color: #f8fafc !important;
}

.audit-modal-submit::after {
  border: none;
}

.audit-modal-submit-hover {
  opacity: 0.94;
}

.hero-meta-k {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.78);
}

.hero-meta-value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  min-width: 0;
}

.hero-meta-v {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  word-break: break-all;
  min-width: 0;
}

.hero-meta-status {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 700;
  color: #fefce8;
  text-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.15);
}

.hero-copy-btn {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  padding: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
}

.hero-copy-btn-hover {
  opacity: 0.85;
}

.hero-copy-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

/* ---------- 常用功能（四列金刚区） ---------- */
.menu-panel {
  margin-top: 28rpx;
  padding: 26rpx 8rpx 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 10rpx 40rpx rgba(67, 56, 202, 0.07), 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
}

.menu-panel-head {
  padding: 0 20rpx 22rpx;
  margin: 0 8rpx 6rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.04em;
}

.menu-kingkong {
  display: flex;
  flex-wrap: wrap;
  padding-top: 12rpx;
}

.menu-kk-item {
  width: 25%;
  box-sizing: border-box;
}

.menu-kk-hit {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 6rpx 22rpx;
  border-radius: 18rpx;
}

.menu-kk-orb-wrap {
  position: relative;
  overflow: visible;
}

.menu-kk-badge-dot {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 5;
  width: 20rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #ef4444;
  border: 2rpx solid #ffffff;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.55);
}

.menu-kk-item-hover .menu-kk-hit {
  background: rgba(241, 245, 249, 0.95);
}

.menu-kk-orb {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.06);
}

.menu-kk-char {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.kk-tone-0 {
  background: #eef2ff;
}
.kk-tone-0 .menu-kk-char {
  color: #4338ca;
}

.kk-tone-1 {
  background: #faf5ff;
}
.kk-tone-1 .menu-kk-char {
  color: #7c3aed;
}

.kk-tone-2 {
  background: #ecfeff;
}
.kk-tone-2 .menu-kk-char {
  color: #0e7490;
}

.kk-tone-3 {
  background: #fdf4ff;
}
.kk-tone-3 .menu-kk-char {
  color: #a21caf;
}

.kk-tone-4 {
  background: #fff7ed;
}
.kk-tone-4 .menu-kk-char {
  color: #c2410c;
}

.kk-tone-5 {
  background: #f0fdf4;
}
.kk-tone-5 .menu-kk-char {
  color: #15803d;
}

.menu-kk-label {
  margin-top: 14rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #475569;
  text-align: center;
  line-height: 1.35;
  max-width: 100%;
  padding: 0 2rpx;
}
