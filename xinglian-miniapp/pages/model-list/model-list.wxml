<page-meta page-style="{{categoryFilterPopupVisible ? 'overflow: hidden;' : ''}}" />
<view class="container model-list-page">
  <view class="model-list-bg model-list-bg--pink"></view>
  <view class="model-list-bg model-list-bg--blue"></view>
  <view class="model-dash">
    <view class="model-entry-row">
      <view class="model-entry-card model-entry-card--contest" data-url="/pages/model-contest/model-contest" bindtap="goEntryPage">
        <text class="model-entry-icon">赛</text>
        <text class="model-entry-title">模特大赛</text>
        <text class="model-entry-sub">报名展示</text>
      </view>
      <view class="model-entry-card model-entry-card--training" data-url="/pages/model-training/model-training" bindtap="goEntryPage">
        <text class="model-entry-icon">训</text>
        <text class="model-entry-title">模特培训</text>
        <text class="model-entry-sub">形体课程</text>
      </view>
      <view class="model-entry-card model-entry-card--shoot" data-url="/pages/model-card-shoot/model-card-shoot" bindtap="goEntryPage">
        <text class="model-entry-icon">拍</text>
        <text class="model-entry-title">模卡拍摄</text>
        <text class="model-entry-sub">形象升级</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="stats-card merchant-empty-card">
      <text class="stats-hint merchant-empty-hint">模特列表加载中…</text>
    </view>
    <view wx:elif="{{loadError}}" class="stats-card merchant-empty-card">
      <text class="stats-hint merchant-empty-hint">{{loadError}}</text>
    </view>

    <block wx:else>
      <view class="model-filter-card">
        <view class="model-filter-head" bindtap="toggleFilterExpanded">
          <view class="model-filter-title-wrap">
            <text class="model-filter-title">筛选方式</text>
            <text class="model-filter-badge" wx:if="{{activeFilterCount > 0}}">{{activeFilterCount}}</text>
          </view>
          <view class="model-filter-actions">
            <text class="model-filter-reset" wx:if="{{activeFilterCount > 0}}" catchtap="resetFilters">重置</text>
            <text class="model-filter-toggle">{{filterExpanded ? "收起" : "展开"}}</text>
          </view>
        </view>
        <view wx:if="{{filterExpanded}}" class="model-filter-grid">
          <picker
            mode="multiSelector"
            range="{{filterOptions.regionColumns}}"
            value="{{filterState.regionIndex}}"
            bindcolumnchange="onRegionColumnChange"
            bindchange="onRegionChange"
          >
            <view class="model-filter-item">
              <text class="model-filter-label">地域</text>
              <text class="model-filter-value">{{regionFilterText}}</text>
            </view>
          </picker>
          <picker mode="selector" range="{{filterOptions.genders}}" value="{{filterState.genderIndex}}" data-key="gender" bindchange="onFilterChange">
            <view class="model-filter-item">
              <text class="model-filter-label">性别</text>
              <text class="model-filter-value">{{filterOptions.genders[filterState.genderIndex]}}</text>
            </view>
          </picker>
          <picker mode="selector" range="{{filterOptions.prices}}" value="{{filterState.priceIndex}}" data-key="price" bindchange="onFilterChange">
            <view class="model-filter-item">
              <text class="model-filter-label">价格</text>
              <text class="model-filter-value">{{filterOptions.prices[filterState.priceIndex]}}</text>
            </view>
          </picker>
          <picker mode="selector" range="{{filterOptions.ratings}}" value="{{filterState.ratingIndex}}" data-key="rating" bindchange="onFilterChange">
            <view class="model-filter-item">
              <text class="model-filter-label">评分</text>
              <text class="model-filter-value">{{filterOptions.ratings[filterState.ratingIndex]}}</text>
            </view>
          </picker>
          <picker mode="selector" range="{{filterOptions.levels}}" value="{{filterState.levelIndex}}" data-key="level" bindchange="onFilterChange">
            <view class="model-filter-item">
              <text class="model-filter-label">模特等级</text>
              <text class="model-filter-value">{{filterOptions.levels[filterState.levelIndex]}}</text>
            </view>
          </picker>
          <view class="model-filter-item model-filter-item--wide model-filter-item--tap" bindtap="openCategoryFilterPopup">
            <text class="model-filter-label">类型</text>
            <text class="model-filter-value">{{categoryFilterText}}</text>
          </view>
        </view>
        <scroll-view
          wx:if="{{appliedCategoryOptions.length > 0}}"
          scroll-x
          class="model-filter-applied-scroll"
          enhanced
          show-scrollbar="{{false}}"
          enable-flex
        >
          <view class="model-filter-applied-row">
            <text wx:for="{{appliedCategoryOptions}}" wx:key="id" class="model-filter-applied-chip">{{item.name}}</text>
          </view>
        </scroll-view>
        <text class="model-filter-count">共 {{filteredModelList.length}} 位符合条件 · 当前评分均为 5.0</text>
      </view>

      <view wx:if="{{filteredModelList.length === 0}}" class="stats-card merchant-empty-card">
        <text class="stats-hint merchant-empty-hint">{{activeFilterCount > 0 ? '暂无符合筛选条件的模特' : '暂无可展示模特'}}</text>
      </view>

      <block wx:elif="{{filteredModelList.length > 0}}">
      <view class="model-list-toolbar">
        <text class="model-list-toolbar-title">展示方式</text>
        <view class="model-list-mode-switch">
          <view class="model-list-mode-item {{modelListMode === 'list' ? 'model-list-mode-item--on' : ''}}" data-mode="list" bindtap="onModelListModeChange">传统列表</view>
          <view class="model-list-mode-item {{modelListMode === 'large' ? 'model-list-mode-item--on' : ''}}" data-mode="large" bindtap="onModelListModeChange">大图展示</view>
        </view>
      </view>

      <block wx:if="{{modelListMode === 'list'}}">
        <view
          wx:for="{{filteredModelList}}"
          wx:key="userNo"
          class="stats-card merchant-item model-list-card {{item.modelLevel.level === 5 ? 'model-list-card--sky' : ''}} {{item.modelLevel.level === 4 ? 'model-list-card--crown' : ''}}"
          data-user-no="{{item.userNo}}"
          bindtap="goModelDetail"
        >
          <view class="model-list-card-shine"></view>
          <view wx:if="{{item.modelLevel.level >= 4}}" class="model-list-premium-aura"></view>
          <view class="merchant-item-head">
            <view class="merchant-av merchant-av--media">
              <image wx:if="{{item.showAvatarImg}}" class="merchant-av-img" src="{{item.avatarDisplayUrl}}" mode="aspectFill" />
              <text wx:else class="merchant-av-fallback">{{item.avatarText}}</text>
            </view>
            <view class="merchant-item-meta">
              <view class="model-list-name-row">
                <text class="merchant-item-name">{{item.nickname}}</text>
                <text class="model-level-pill model-level-pill--small {{item.modelLevel.level === 5 ? 'model-level-pill--sky' : ''}} {{item.modelLevel.level === 4 ? 'model-level-pill--crown' : ''}}">{{item.modelLevelText}}</text>
                <text wx:if="{{item.genderLabel}}" class="model-gender-pill {{item.genderLabel === '男' ? 'model-gender-pill--male' : 'model-gender-pill--female'}}">{{item.genderLabel}}</text>
              </view>
              <text class="merchant-item-sub">所在 {{item.city || "未填写"}}</text>
            </view>
            <view class="model-list-card-badge {{item.modelLevel.level === 5 ? 'model-list-card-badge--sky' : ''}} {{item.modelLevel.level === 4 ? 'model-list-card-badge--crown' : ''}}">{{item.modelLevel.level === 5 ? "天幕优选" : item.modelLevel.level === 4 ? "皇冠认证" : "推荐"}}</view>
          </view>

          <view class="merchant-chip-row" wx:if="{{item.categories && item.categories.length > 0}}">
            <text wx:for="{{item.categories}}" wx:key="*this" class="merchant-chip">{{item}}</text>
          </view>
          <view class="merchant-chip-row" wx:else>
            <text class="merchant-chip merchant-chip--muted">暂无类型标签</text>
          </view>

          <view wx:if="{{item.hasCardSection}}" class="merchant-model-card">
            <view class="merchant-model-card-head">
              <text class="merchant-model-card-label">模卡</text>
              <text wx:if="{{item.cardThumbUrls.length}}" class="merchant-model-card-sub">照片</text>
            </view>
            <scroll-view wx:if="{{item.cardThumbUrls.length}}" scroll-x class="merchant-card-scroll" enhanced show-scrollbar="{{false}}" enable-flex>
              <image wx:for="{{item.cardThumbUrls}}" wx:for-index="idx" wx:key="idx" class="merchant-card-thumb" src="{{item}}" mode="aspectFill" />
            </scroll-view>
            <view wx:if="{{item.cardMeasureChips.length}}" class="merchant-card-measure-wrap">
              <text class="merchant-card-measure-title">身材数据</text>
              <view class="merchant-card-chip-row">
                <text wx:for="{{item.cardMeasureChips}}" wx:for-item="chip" wx:key="key" class="merchant-card-chip">{{chip.text}}</text>
              </view>
            </view>
          </view>

          <view class="stat-row merchant-price-row">
            <view class="stat-block"><text class="stat-label">小时</text><view class="stat-value-row"><text class="stat-value stat-money merchant-price-num">{{item.hourlyText}}</text></view></view>
            <view class="stat-divider"></view>
            <view class="stat-block"><text class="stat-label">半天</text><view class="stat-value-row"><text class="stat-value stat-money merchant-price-num">{{item.halfDayText}}</text></view></view>
            <view class="stat-divider"></view>
            <view class="stat-block"><text class="stat-label">全天</text><view class="stat-value-row"><text class="stat-value stat-money merchant-price-num">{{item.fullDayText}}</text></view></view>
          </view>
          <text class="stats-hint merchant-intro-clamp">简介：{{item.intro || "暂无简介"}}</text>
          <view class="merchant-item-foot"><text class="merchant-item-more">查看详情</text></view>
        </view>
      </block>

      <view wx:else class="model-large-grid">
        <view
          wx:for="{{filteredModelList}}"
          wx:key="userNo"
          class="model-large-card model-large-card--fancy {{item.modelLevel.level === 5 ? 'model-large-card--sky' : ''}} {{item.modelLevel.level === 4 ? 'model-large-card--crown' : ''}}"
          data-user-no="{{item.userNo}}"
          bindtap="goModelDetail"
        >
          <view class="model-large-cover">
            <image wx:if="{{item.showCoverImage}}" class="model-large-cover-img" src="{{item.coverImageUrl}}" mode="aspectFill" />
            <view wx:else class="model-large-cover-fallback">{{item.avatarText}}</view>
            <view class="model-large-spotlight"></view>
            <view wx:if="{{item.modelLevel.level >= 4}}" class="model-large-premium-aura"></view>
            <view class="model-large-gradient"></view>
            <view class="model-large-count" wx:if="{{item.cardThumbUrls.length}}">{{item.cardThumbUrls.length}} 张</view>
            <text class="model-level-pill model-large-level-pill {{item.modelLevel.level === 5 ? 'model-level-pill--sky' : ''}} {{item.modelLevel.level === 4 ? 'model-level-pill--crown' : ''}}">{{item.modelLevelText}}</text>
            <view wx:if="{{item.modelLevel.level >= 4}}" class="model-large-premium-badge {{item.modelLevel.level === 5 ? 'model-large-premium-badge--sky' : 'model-large-premium-badge--crown'}}">{{item.modelLevel.level === 5 ? "天幕优选" : "皇冠认证"}}</view>
            <view class="model-large-price-pill">{{item.hourlyText}}/小时</view>
          </view>
          <view class="model-large-body">
            <view class="model-large-name-row">
              <text class="model-large-name">{{item.nickname}}</text>
              <text wx:if="{{item.genderLabel}}" class="model-gender-pill model-gender-pill--small {{item.genderLabel === '男' ? 'model-gender-pill--male' : 'model-gender-pill--female'}}">{{item.genderLabel}}</text>
            </view>
            <text class="model-large-sub">{{item.city || "未填写"}} · {{item.hourlyText}}/小时</text>
            <view class="model-large-tags" wx:if="{{item.categories && item.categories.length > 0}}">
              <text wx:for="{{item.categories}}" wx:for-item="tag" wx:key="*this" class="model-large-tag">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
      </block>
    </block>
  </view>
</view>

<view wx:if="{{categoryFilterPopupVisible}}" class="category-filter-mask" bindtap="onCategoryFilterMaskTap" catchtouchmove="preventTouchMove">
  <view class="category-filter-panel" catchtap="preventCategoryFilterBubble">
    <view class="category-filter-head">
      <text class="category-filter-title">选择类型</text>
      <text class="category-filter-clear" catchtap="clearDraftCategoryFilter">清空</text>
    </view>

    <view class="category-filter-selected">
      <view class="category-filter-selected-head">
        <text class="category-filter-selected-title">已选 {{draftSelectedCount}} 项</text>
        <text class="category-filter-selected-tip">可多选，匹配任意一个</text>
      </view>
      <scroll-view
        wx:if="{{draftSelectedOptions.length > 0}}"
        scroll-x
        class="category-filter-selected-scroll"
        enhanced
        show-scrollbar="{{false}}"
        enable-flex
      >
        <view class="category-filter-selected-row">
          <view
            class="category-filter-selected-chip"
            wx:for="{{draftSelectedOptions}}"
            wx:key="id"
            data-value="{{item.id}}"
            bindtap="onCategoryFilterDraftRemove"
          >
            <text>{{item.name}}</text>
            <text class="category-filter-selected-close">×</text>
          </view>
        </view>
      </scroll-view>
      <text wx:else class="category-filter-selected-tip">点击下方分类进行选择</text>
    </view>

    <view class="category-filter-tabs">
      <view
        class="category-filter-tab {{categoryCurrentTab === item.key ? 'category-filter-tab--on' : ''}}"
        wx:for="{{categoryTabs}}"
        wx:key="key"
        data-tab="{{item.key}}"
        bindtap="onCategoryFilterTabTap"
      >
        {{item.label}}
      </view>
    </view>

    <scroll-view
      wx:if="{{majorGroups.length > 0}}"
      scroll-x
      class="category-filter-major-scroll"
      enhanced
      show-scrollbar="{{false}}"
      enable-flex
    >
      <view class="category-filter-major-row">
        <view
          class="category-filter-major-tab {{activeMajorGroup.id === item.id ? 'category-filter-major-tab--on' : ''}}"
          wx:for="{{majorGroups}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onCategoryFilterMajorTap"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>

    <scroll-view scroll-y class="category-filter-body" enhanced show-scrollbar="{{false}}">
      <view wx:if="{{!activeMajorGroup}}" class="category-filter-empty">暂无分类数据</view>
      <view wx:elif="{{categoryCurrentTab === 'main'}}" class="category-filter-panel-inner">
        <view class="category-filter-sub-block" wx:for="{{activeMajorGroup.children}}" wx:key="id">
          <text class="category-filter-sub-title">{{item.name}}</text>
          <view class="category-filter-chip-grid">
            <view
              class="category-filter-chip {{draftSelectedMap[optionNode.id] ? 'category-filter-chip--on' : ''}}"
              wx:for="{{item.children}}"
              wx:for-item="optionNode"
              wx:key="id"
              data-value="{{optionNode.id}}"
              bindtap="onCategoryFilterChipTap"
            >
              {{optionNode.name}}
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="category-filter-panel-inner">
        <view class="category-filter-chip-grid">
          <view
            class="category-filter-chip {{draftSelectedMap[optionNode.id] ? 'category-filter-chip--on' : ''}}"
            wx:for="{{activeMajorGroup.children}}"
            wx:for-item="optionNode"
            wx:key="id"
            data-value="{{optionNode.id}}"
            bindtap="onCategoryFilterChipTap"
          >
            {{optionNode.name}}
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="category-filter-foot">
      <view class="category-filter-btn category-filter-btn--ghost" catchtap="closeCategoryFilterPopup">取消</view>
      <view class="category-filter-btn category-filter-btn--primary" catchtap="confirmCategoryFilter">确定</view>
    </view>
  </view>
</view>
