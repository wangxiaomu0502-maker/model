@import "../../styles/model-dash-page.wxss";
@import "../../styles/model-category-filter-popup.wxss";

.container {
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
}

.model-list-page {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 122, 201, 0.34) 0, rgba(255, 122, 201, 0) 230rpx),
    radial-gradient(circle at 88% 12%, rgba(56, 189, 248, 0.28) 0, rgba(56, 189, 248, 0) 250rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 330rpx, #f8fbff 100%);
}

.model-list-bg {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  filter: blur(2rpx);
  pointer-events: none;
}

.model-list-bg--pink {
  top: 118rpx;
  left: -84rpx;
  width: 210rpx;
  height: 210rpx;
  background: rgba(244, 114, 182, 0.22);
}

.model-list-bg--blue {
  top: 430rpx;
  right: -96rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(99, 102, 241, 0.18);
}

.model-list-page .model-dash {
  position: relative;
  z-index: 1;
}

.model-list-hero {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0) 150rpx),
    linear-gradient(135deg, #7c3aed 0%, #ec4899 46%, #f97316 100%);
  box-shadow: 0 18rpx 44rpx rgba(236, 72, 153, 0.32);
}

.model-list-hero-glow {
  position: absolute;
  top: -78rpx;
  right: -50rpx;
  width: 230rpx;
  height: 230rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  pointer-events: none;
}

.model-list-hero-kicker {
  align-self: flex-start;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 0.08em;
  background: rgba(255, 255, 255, 0.18);
}

.model-list-hero-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fef08a;
  box-shadow: 0 0 18rpx rgba(254, 240, 138, 0.95);
}

.model-list-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 2rpx;
}

.model-list-hero-tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.model-list-page .dash-hero-count {
  position: relative;
  min-width: 132rpx;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
}

.model-entry-row {
  display: flex;
  gap: 14rpx;
}

.model-entry-card {
  position: relative;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  padding: 22rpx 10rpx 18rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 16rpx 34rpx rgba(148, 163, 184, 0.18);
}

.model-entry-card::after {
  content: "";
  position: absolute;
  top: -52rpx;
  right: -46rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
}

.model-entry-card:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.model-entry-card--contest {
  background: linear-gradient(145deg, #7c3aed 0%, #ec4899 100%);
}

.model-entry-card--training {
  background: linear-gradient(145deg, #2563eb 0%, #06b6d4 100%);
}

.model-entry-card--shoot {
  background: linear-gradient(145deg, #f97316 0%, #f43f5e 100%);
}

.model-entry-icon {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin: 0 auto 12rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.model-entry-title,
.model-entry-sub {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  color: #ffffff;
}

.model-entry-title {
  font-size: 25rpx;
  font-weight: 800;
  letter-spacing: 0.02em;
}

.model-entry-sub {
  margin-top: 6rpx;
  font-size: 19rpx;
  font-weight: 600;
  opacity: 0.86;
}

.model-filter-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(148, 163, 184, 0.16);
}

.model-filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.model-filter-title-wrap,
.model-filter-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.model-filter-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #581c87;
}

.model-filter-badge {
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #ec4899, #f97316);
}

.model-filter-reset {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #db2777;
  background: #fdf2f8;
}

.model-filter-toggle {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.08);
}

.model-filter-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.model-filter-grid picker {
  width: calc((100% - 12rpx) / 2);
}

.model-filter-item--wide {
  width: 100%;
}

.model-filter-applied-scroll {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.model-filter-applied-row {
  display: inline-flex;
  gap: 10rpx;
}

.model-filter-applied-chip {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #4338ca;
  background: rgba(99, 102, 241, 0.1);
  border: 1rpx solid rgba(99, 102, 241, 0.2);
}

.model-filter-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff7fb 0%, #eef2ff 100%);
  border: 1rpx solid rgba(244, 114, 182, 0.16);
  box-sizing: border-box;
}

.model-filter-label {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 800;
  color: #be185d;
}

.model-filter-value {
  min-width: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #475569;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-filter-count {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #64748b;
}

.model-list-page .model-list-toolbar {
  padding: 12rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 12rpx 28rpx rgba(148, 163, 184, 0.16);
}

.model-list-page .model-list-toolbar-title {
  color: #7c3aed;
  font-weight: 800;
}

.model-list-page .model-list-mode-switch {
  border: 0;
  background: rgba(124, 58, 237, 0.08);
}

.model-list-page .model-list-mode-item--on {
  background: linear-gradient(135deg, #7c3aed, #ec4899 58%, #f97316);
  box-shadow: 0 8rpx 22rpx rgba(236, 72, 153, 0.3);
}

.model-list-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  background:
    linear-gradient(#ffffff, #ffffff) padding-box,
    linear-gradient(135deg, rgba(236, 72, 153, 0.45), rgba(99, 102, 241, 0.3)) border-box;
  box-shadow: 0 16rpx 38rpx rgba(148, 163, 184, 0.18);
}

.model-list-card-shine {
  position: absolute;
  top: -48rpx;
  right: -42rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: rgba(236, 72, 153, 0.12);
  pointer-events: none;
}

.model-list-card-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 800;
  color: #be185d;
  background: linear-gradient(135deg, #fdf2f8, #fff7ed);
  border: 1rpx solid rgba(244, 114, 182, 0.34);
}

.model-list-name-row,
.model-large-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.model-gender-pill {
  flex-shrink: 0;
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
}

.model-gender-pill--small {
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 8rpx;
  font-size: 18rpx;
}

.model-gender-pill--female {
  color: #be185d;
  background: #fdf2f8;
  border: 1rpx solid rgba(244, 114, 182, 0.38);
}

.model-gender-pill--male {
  color: #1d4ed8;
  background: #eff6ff;
  border: 1rpx solid rgba(96, 165, 250, 0.4);
}

.model-list-page .merchant-av--media {
  width: 76rpx;
  height: 76rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(236, 72, 153, 0.18);
}

.model-list-page .merchant-av-fallback {
  height: 76rpx;
  line-height: 76rpx;
  color: #be185d;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff);
}

.model-list-page .merchant-chip {
  color: #7c3aed;
  background: rgba(245, 243, 255, 0.92);
  border-color: rgba(167, 139, 250, 0.28);
}

.model-list-page .merchant-model-card {
  background: linear-gradient(135deg, rgba(253, 242, 248, 0.9), rgba(238, 242, 255, 0.9));
  border-color: rgba(236, 72, 153, 0.16);
}

.model-list-page .merchant-item-more {
  color: #db2777;
}

.model-large-card--fancy {
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(124, 58, 237, 0.14);
}

.model-large-card--fancy:nth-child(3n + 1) {
  box-shadow: 0 14rpx 34rpx rgba(236, 72, 153, 0.17);
}

.model-large-card--fancy:nth-child(3n + 2) {
  box-shadow: 0 14rpx 34rpx rgba(14, 165, 233, 0.16);
}

.model-list-page .model-large-cover {
  background: linear-gradient(135deg, #fdf2f8, #eef2ff 52%, #fff7ed);
}

.model-large-spotlight {
  position: absolute;
  left: -30rpx;
  top: -40rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  pointer-events: none;
}

.model-list-page .model-large-gradient {
  height: 118rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(88, 28, 135, 0.64) 100%);
}

.model-list-page .model-large-count {
  top: 8rpx;
  right: 8rpx;
  bottom: auto;
  background: rgba(255, 255, 255, 0.82);
  color: #7c3aed;
}

.model-large-price-pill {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  max-width: 180rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #ec4899, #f97316);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.28);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-list-page .model-large-body {
  background: linear-gradient(180deg, #ffffff 0%, #fff7fb 100%);
}

.model-list-page .model-large-name {
  color: #581c87;
}

.model-list-page .model-large-tag {
  color: #be185d;
  background: #fdf2f8;
}
