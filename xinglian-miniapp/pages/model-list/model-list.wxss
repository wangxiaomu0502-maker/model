@import "../../styles/model-dash-page.wxss";
@import "../../styles/model-category-filter-popup.wxss";
@import "../../styles/premium-model-card.wxss";
@import "../../styles/home-page.wxss";

.model-list-page-root {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.model-list-page-root .home-status-bar-shield--solid .model-list-shield-nav {
  pointer-events: auto;
}

.model-list-immersive-bg-wrap {
  height: 320rpx;
}

.model-list-immersive-bg {
  height: 320rpx;
}

.model-list-immersive-head .home-immersive-inner {
  padding-bottom: 8rpx;
}

.model-list-nav-row {
  position: relative;
}

.model-list-shield-nav {
  position: relative;
}

.model-list-nav-back {
  position: absolute;
  left: 0;
  top: 50%;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 56rpx;
  padding: 0 20rpx 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(199, 210, 254, 0.95);
  box-shadow: 0 8rpx 22rpx rgba(67, 56, 202, 0.08);
  box-sizing: border-box;
  transform: translateY(-50%);
}

.model-list-nav-back--compact {
  left: 16rpx;
  height: 48rpx;
  padding: 0 16rpx;
  transform: translateY(-50%);
}

.model-list-nav-back--active {
  opacity: 0.86;
}

.model-list-nav-back-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #4338ca;
  transform: translateY(-1rpx);
}

.model-list-nav-back-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #4338ca;
  letter-spacing: 0.04em;
}

.container {
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
}

.model-list-page--guest {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.model-list-load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 12rpx;
}

.model-list-load-more-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #94a3b8;
}

.model-list-guest-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
}

.model-list-guest-bar-inner {
  padding-left: 25rpx;
  padding-right: 25rpx;
  box-sizing: border-box;
}

.model-list-guest-register-btn {
  width: 100%;
  height: 100rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed, #ec4899 58%, #f97316);
  box-shadow: 0 10rpx 24rpx rgba(236, 72, 153, 0.28);
}

.model-list-guest-register-btn--active {
  opacity: 0.92;
}

.model-list-page {
  position: relative;
  z-index: 3;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 122, 201, 0.34) 0, rgba(255, 122, 201, 0) 230rpx),
    radial-gradient(circle at 88% 12%, rgba(56, 189, 248, 0.28) 0, rgba(56, 189, 248, 0) 250rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 330rpx, #f8fbff 100%);
}

.model-list-bg {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  filter: blur(2rpx);
  pointer-events: none;
}

.model-list-bg--pink {
  top: 24rpx;
  left: -84rpx;
  width: 210rpx;
  height: 210rpx;
  background: rgba(244, 114, 182, 0.22);
}

.model-list-bg--blue {
  top: 336rpx;
  right: -96rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(99, 102, 241, 0.18);
}

.model-list-page .model-dash {
  position: relative;
  z-index: 1;
}

.model-list-hero {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0) 150rpx),
    linear-gradient(135deg, #7c3aed 0%, #ec4899 46%, #f97316 100%);
  box-shadow: 0 18rpx 44rpx rgba(236, 72, 153, 0.32);
}

.model-list-hero-glow {
  position: absolute;
  top: -78rpx;
  right: -50rpx;
  width: 230rpx;
  height: 230rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  pointer-events: none;
}

.model-list-hero-kicker {
  align-self: flex-start;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 0.08em;
  background: rgba(255, 255, 255, 0.18);
}

.model-list-hero-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fef08a;
  box-shadow: 0 0 18rpx rgba(254, 240, 138, 0.95);
}

.model-list-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 2rpx;
}

.model-list-hero-tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.model-list-page .dash-hero-count {
  position: relative;
  min-width: 132rpx;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
}

.model-entry-row {
  display: flex;
  gap: 14rpx;
}

.model-entry-card {
  position: relative;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  padding: 22rpx 10rpx 18rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 16rpx 34rpx rgba(148, 163, 184, 0.18);
}

.model-entry-card::after {
  content: "";
  position: absolute;
  top: -52rpx;
  right: -46rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
}

.model-entry-card:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.model-entry-card--contest {
  background: linear-gradient(145deg, #7c3aed 0%, #ec4899 100%);
}

.model-entry-card--training {
  background: linear-gradient(145deg, #2563eb 0%, #06b6d4 100%);
}

.model-entry-card--shoot {
  background: linear-gradient(145deg, #f97316 0%, #f43f5e 100%);
}

.model-entry-icon {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin: 0 auto 12rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.model-entry-title,
.model-entry-sub {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  color: #ffffff;
}

.model-entry-title {
  font-size: 25rpx;
  font-weight: 800;
  letter-spacing: 0.02em;
}

.model-entry-sub {
  margin-top: 6rpx;
  font-size: 19rpx;
  font-weight: 600;
  opacity: 0.86;
}

.model-filter-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(148, 163, 184, 0.16);
}

.model-filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.model-filter-title-wrap,
.model-filter-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.model-filter-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #581c87;
}

.model-filter-badge {
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #ec4899, #f97316);
}

.model-filter-reset {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #db2777;
  background: #fdf2f8;
}

.model-filter-toggle {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.08);
}

.model-filter-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.model-filter-grid picker {
  width: calc((100% - 12rpx) / 2);
}

.model-filter-item--wide {
  width: 100%;
}

.model-filter-applied-scroll {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.model-filter-applied-row {
  display: inline-flex;
  gap: 10rpx;
}

.model-filter-applied-chip {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #4338ca;
  background: rgba(99, 102, 241, 0.1);
  border: 1rpx solid rgba(99, 102, 241, 0.2);
}

.model-filter-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff7fb 0%, #eef2ff 100%);
  border: 1rpx solid rgba(244, 114, 182, 0.16);
  box-sizing: border-box;
}

.model-filter-label {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 800;
  color: #be185d;
}

.model-filter-value {
  min-width: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #475569;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-filter-count {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #64748b;
}

.model-list-page .model-list-toolbar {
  padding: 12rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 12rpx 28rpx rgba(148, 163, 184, 0.16);
}

.model-list-page .model-list-toolbar-title {
  color: #7c3aed;
  font-weight: 800;
}

.model-list-page .model-list-mode-switch {
  border: 0;
  background: rgba(124, 58, 237, 0.08);
}

.model-list-page .model-list-mode-item--on {
  background: linear-gradient(135deg, #7c3aed, #ec4899 58%, #f97316);
  box-shadow: 0 8rpx 22rpx rgba(236, 72, 153, 0.3);
}

.model-list-card {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  background:
    linear-gradient(#ffffff, #ffffff) padding-box,
    linear-gradient(135deg, rgba(236, 72, 153, 0.45), rgba(99, 102, 241, 0.3)) border-box;
  box-shadow: 0 16rpx 38rpx rgba(148, 163, 184, 0.18);
}

.model-list-card--crown {
  border: 5rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(251, 191, 36, 0.28) 0, rgba(251, 191, 36, 0) 200rpx),
    radial-gradient(circle at 0% 100%, rgba(245, 158, 11, 0.16) 0, rgba(245, 158, 11, 0) 180rpx),
    linear-gradient(#fffdf6, #ffffff) padding-box,
    linear-gradient(135deg, #b45309, #fbbf24 22%, #fde68a 50%, #f59e0b 78%, #b45309) border-box;
  box-shadow:
    0 0 0 2rpx rgba(251, 191, 36, 0.42),
    0 0 30rpx rgba(245, 158, 11, 0.34),
    0 22rpx 52rpx rgba(180, 83, 9, 0.28);
}

.model-list-card--sky {
  border: 5rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(236, 72, 153, 0.3) 0, rgba(236, 72, 153, 0) 200rpx),
    radial-gradient(circle at 0% 12%, rgba(56, 189, 248, 0.24) 0, rgba(56, 189, 248, 0) 180rpx),
    linear-gradient(135deg, #fff7fb 0%, #ffffff 48%, #f5f3ff 100%) padding-box,
    linear-gradient(135deg, #38bdf8, #a855f7 28%, #ec4899 58%, #f97316 82%, #7c3aed) border-box;
  box-shadow:
    0 0 0 2rpx rgba(192, 132, 252, 0.48),
    0 0 34rpx rgba(124, 58, 237, 0.38),
    0 0 52rpx rgba(236, 72, 153, 0.24),
    0 24rpx 58rpx rgba(88, 28, 135, 0.32);
}

.model-list-card-shine {
  position: absolute;
  top: -48rpx;
  right: -42rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: rgba(236, 72, 153, 0.12);
  pointer-events: none;
}

.model-list-card--crown .model-list-card-shine {
  background: rgba(245, 158, 11, 0.24);
  box-shadow: 0 0 60rpx rgba(251, 191, 36, 0.38);
}

.model-list-card--sky .model-list-card-shine {
  background: rgba(124, 58, 237, 0.22);
  box-shadow:
    0 0 48rpx rgba(168, 85, 247, 0.34),
    0 0 72rpx rgba(236, 72, 153, 0.22);
}

.model-list-premium-aura {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.56) 0, rgba(255, 255, 255, 0) 68%);
  pointer-events: none;
}

.model-list-card-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 800;
  color: #be185d;
  background: linear-gradient(135deg, #fdf2f8, #fff7ed);
  border: 1rpx solid rgba(244, 114, 182, 0.34);
}

.model-list-card-badge--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #fde68a 42%, #f59e0b);
  border: 2rpx solid rgba(251, 191, 36, 0.72);
  box-shadow:
    0 0 16rpx rgba(245, 158, 11, 0.42),
    0 8rpx 20rpx rgba(245, 158, 11, 0.28);
  letter-spacing: 0.04em;
}

.model-list-card-badge--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 38%, #ec4899 72%, #38bdf8);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow:
    0 0 18rpx rgba(124, 58, 237, 0.48),
    0 8rpx 24rpx rgba(236, 72, 153, 0.34);
  letter-spacing: 0.04em;
}

.model-list-name-row,
.model-large-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.model-level-pill {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 900;
  color: #b45309;
  background: #fef3c7;
  border: 1rpx solid rgba(245, 158, 11, 0.28);
}

.model-level-pill--small {
  padding: 3rpx 9rpx;
  font-size: 17rpx;
}

.model-level-pill--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #fde68a 50%, #f59e0b);
  border: 2rpx solid rgba(251, 191, 36, 0.55);
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.28);
}

.model-level-pill--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 52%, #ec4899);
  border: 2rpx solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 0 14rpx rgba(124, 58, 237, 0.38);
}

.model-gender-pill {
  flex-shrink: 0;
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
}

.model-gender-pill--small {
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 8rpx;
  font-size: 18rpx;
}

.model-gender-pill--female {
  color: #be185d;
  background: #fdf2f8;
  border: 1rpx solid rgba(244, 114, 182, 0.38);
}

.model-gender-pill--male {
  color: #1d4ed8;
  background: #eff6ff;
  border: 1rpx solid rgba(96, 165, 250, 0.4);
}

.model-list-page .merchant-av--media {
  width: 76rpx;
  height: 76rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(236, 72, 153, 0.18);
}

.model-list-page .merchant-av-fallback {
  height: 76rpx;
  line-height: 76rpx;
  color: #be185d;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff);
}

.model-list-page .merchant-chip {
  color: #7c3aed;
  background: rgba(245, 243, 255, 0.92);
  border-color: rgba(167, 139, 250, 0.28);
}

.model-list-page .merchant-model-card {
  background: linear-gradient(135deg, rgba(253, 242, 248, 0.9), rgba(238, 242, 255, 0.9));
  border-color: rgba(236, 72, 153, 0.16);
}

.model-list-page .merchant-item-more {
  color: #db2777;
}

.model-large-card--fancy {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(124, 58, 237, 0.14);
}

.model-large-card--fancy:nth-child(3n + 1) {
  box-shadow: 0 14rpx 34rpx rgba(236, 72, 153, 0.17);
}

.model-large-card--fancy:nth-child(3n + 2) {
  box-shadow: 0 14rpx 34rpx rgba(14, 165, 233, 0.16);
}

.model-large-card--crown {
  border: 5rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(251, 191, 36, 0.28) 0, rgba(251, 191, 36, 0) 200rpx),
    linear-gradient(#fffbeb, #ffffff) padding-box,
    linear-gradient(135deg, #b45309, #fbbf24 22%, #fde68a 50%, #f59e0b 78%, #b45309) border-box;
  box-shadow:
    0 0 0 2rpx rgba(251, 191, 36, 0.42),
    0 0 30rpx rgba(245, 158, 11, 0.34),
    0 22rpx 52rpx rgba(180, 83, 9, 0.28);
}

.model-large-card--sky {
  border: 5rpx solid transparent;
  background:
    radial-gradient(circle at 92% 0%, rgba(236, 72, 153, 0.3) 0, rgba(236, 72, 153, 0) 200rpx),
    radial-gradient(circle at 0% 12%, rgba(56, 189, 248, 0.24) 0, rgba(56, 189, 248, 0) 180rpx),
    linear-gradient(180deg, #f5f3ff 0%, #fff7fb 100%) padding-box,
    linear-gradient(135deg, #38bdf8, #a855f7 28%, #ec4899 58%, #f97316 82%, #7c3aed) border-box;
  box-shadow:
    0 0 0 2rpx rgba(192, 132, 252, 0.48),
    0 0 34rpx rgba(124, 58, 237, 0.38),
    0 0 52rpx rgba(236, 72, 153, 0.24),
    0 24rpx 58rpx rgba(88, 28, 135, 0.32);
}

.model-list-page .model-large-cover {
  background: linear-gradient(135deg, #fdf2f8, #eef2ff 52%, #fff7ed);
}

.model-large-card--crown .model-large-cover {
  background: linear-gradient(135deg, #78350f, #f59e0b 52%, #fde68a);
}

.model-large-card--sky .model-large-cover {
  background: linear-gradient(135deg, #020617, #4c1d95 48%, #ec4899);
}

.model-large-spotlight {
  position: absolute;
  left: -30rpx;
  top: -40rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  pointer-events: none;
}

.model-large-premium-aura {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 280rpx;
  height: 280rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.38) 0, rgba(255, 255, 255, 0) 66%);
  pointer-events: none;
}

.model-large-card--crown .model-large-premium-aura {
  background:
    radial-gradient(circle, rgba(255, 251, 235, 0.55) 0, rgba(251, 191, 36, 0.18) 42%, rgba(251, 191, 36, 0) 72%);
}

.model-large-card--sky .model-large-premium-aura {
  background:
    radial-gradient(circle, rgba(255, 255, 255, 0.42) 0, rgba(168, 85, 247, 0.22) 38%, rgba(56, 189, 248, 0.12) 58%, rgba(236, 72, 153, 0) 74%);
}

.model-list-page .model-large-gradient {
  height: 118rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(88, 28, 135, 0.64) 100%);
}

.model-large-card--crown .model-large-gradient {
  background: linear-gradient(180deg, rgba(120, 53, 15, 0) 0%, rgba(120, 53, 15, 0.72) 100%);
}

.model-large-card--sky .model-large-gradient {
  background: linear-gradient(180deg, rgba(2, 6, 23, 0) 0%, rgba(2, 6, 23, 0.78) 100%);
}

.model-list-page .model-large-count {
  top: 8rpx;
  right: 8rpx;
  bottom: auto;
  background: rgba(255, 255, 255, 0.82);
  color: #7c3aed;
}

.model-large-level-pill {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  z-index: 2;
  max-width: 190rpx;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-large-premium-badge {
  position: absolute;
  left: 8rpx;
  top: 48rpx;
  z-index: 2;
  max-width: 174rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 900;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.18);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-large-premium-badge--crown {
  color: #78350f;
  background: linear-gradient(135deg, #fef3c7, #fde68a 42%, #f59e0b);
  border: 2rpx solid rgba(251, 191, 36, 0.72);
  box-shadow: 0 0 16rpx rgba(245, 158, 11, 0.42);
}

.model-large-premium-badge--sky {
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #7c3aed 38%, #ec4899 72%, #38bdf8);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 0 18rpx rgba(124, 58, 237, 0.48);
}

.model-large-card--crown .model-large-price-pill {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  box-shadow: 0 6rpx 16rpx rgba(245, 158, 11, 0.34);
}

.model-large-card--sky .model-large-price-pill {
  background: linear-gradient(135deg, #7c3aed, #ec4899 58%, #38bdf8);
  box-shadow: 0 6rpx 18rpx rgba(124, 58, 237, 0.36);
}

.model-large-price-pill {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  max-width: 180rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #ec4899, #f97316);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.28);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-list-page .model-large-body {
  background: linear-gradient(180deg, #ffffff 0%, #fff7fb 100%);
}

.model-list-page .model-large-tags {
  flex-wrap: nowrap;
  height: 40rpx;
  max-height: 40rpx;
  overflow: hidden;
}

.model-list-page .model-large-name {
  color: #581c87;
}

.model-list-page .model-large-tag {
  flex-shrink: 0;
  color: #be185d;
  background: #fdf2f8;
}
