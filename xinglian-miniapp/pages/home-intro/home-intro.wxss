@import "../../styles/model-dash-page.wxss";
@import "../../styles/home-page.wxss";

.container {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.home-intro-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
}

.home-intro-register-btn {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 55%, #f97316 100%);
  box-shadow: 0 14rpx 36rpx rgba(236, 72, 153, 0.32);
}

.home-intro-register-btn::after {
  border: none;
}

.home-intro-register-btn--active {
  opacity: 0.92;
}
