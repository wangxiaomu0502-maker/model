<view class="home-page-root">
<view class="container home-page">
  <view class="model-dash home-dash">
    <view class="home-search-bar card" bindtap="goSearchPage">
      <text class="home-search-icon">⌕</text>
      <text class="home-search-placeholder">搜索模特 / 经纪人 / 商家</text>
    </view>

    <view class="home-quick-panel">
      <view class="home-quick-panel-head">
        <view class="home-quick-panel-accent"></view>
        <view class="home-quick-panel-titles">
          <text class="home-quick-panel-kicker">星链模库</text>
          <text class="home-quick-panel-title">探索更多</text>
        </view>
      </view>
      <view class="home-quick-nav">
        <view
          wx:for="{{quickEntries}}"
          wx:key="key"
          class="home-quick-item {{item.themeClass}}"
          data-key="{{item.key}}"
          bindtap="onQuickEntryTap"
          hover-class="home-quick-item--active"
          hover-stay-time="80"
        >
          <view class="home-quick-icon-wrap">
            <view class="home-quick-icon">{{item.icon}}</view>
          </view>
          <text class="home-quick-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="home-section-head">
      <view>
        <text class="home-section-title">推荐模特</text>
        <text class="home-section-sub">精选资料完整、可预约的模特</text>
      </view>
      <text class="home-section-more" bindtap="goModelList">全部</text>
    </view>
    <view wx:if="{{loading}}" class="stats-card merchant-empty-card">
      <text class="stats-hint merchant-empty-hint">首页内容加载中...</text>
    </view>
    <view wx:elif="{{loadError}}" class="stats-card merchant-empty-card">
      <text class="stats-hint merchant-empty-hint">{{loadError}}</text>
    </view>
    <view wx:else class="home-model-list">
      <view
        wx:for="{{featuredModels}}"
        wx:key="userNo"
        class="home-model-card {{item.modelLevel.level === 5 ? 'home-model-card--sky' : ''}} {{item.modelLevel.level === 4 ? 'home-model-card--crown' : ''}}"
        data-user-no="{{item.userNo}}"
        bindtap="goModelDetail"
      >
        <view class="home-model-cover">
          <image wx:if="{{item.showCoverImage}}" class="home-model-img" src="{{item.coverImageUrl}}" mode="aspectFill" />
          <view wx:else class="home-model-fallback">{{item.avatarText}}</view>
          <view wx:if="{{item.modelLevel.level >= 4}}" class="home-model-premium-aura"></view>
          <view class="home-model-gradient"></view>
          <text class="home-model-price">{{item.hourlyText}}/小时</text>
          <view wx:if="{{item.modelLevel.level >= 4}}" class="home-model-premium-badge {{item.modelLevel.level === 5 ? 'home-model-premium-badge--sky' : 'home-model-premium-badge--crown'}}">{{item.modelLevel.level === 5 ? "天幕优选" : "皇冠认证"}}</view>
        </view>
        <view class="home-model-body">
          <view class="home-model-name-row">
            <text class="home-model-name">{{item.nickname}}</text>
            <text class="model-level-pill {{item.modelLevel.level === 5 ? 'model-level-pill--sky' : ''}} {{item.modelLevel.level === 4 ? 'model-level-pill--crown' : ''}}">{{item.modelLevelText}}</text>
          </view>
          <text class="home-model-sub">{{item.city || "城市待完善"}}</text>
          <view class="home-model-tags" wx:if="{{item.categories && item.categories.length > 0}}">
            <text wx:for="{{item.categories}}" wx:for-item="tag" wx:key="*this" class="home-model-tag">{{tag}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showRegisterBar}}" class="home-intro-bottom-bar">
  <button class="home-intro-register-btn" hover-class="home-intro-register-btn--active" bindtap="goRegister">
    立即注册
  </button>
</view>
</view>
