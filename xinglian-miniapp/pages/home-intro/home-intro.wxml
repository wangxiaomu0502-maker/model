<view class="home-page-root">
  <view
    class="home-status-bar-shield {{homeScrolled ? 'home-status-bar-shield--solid' : ''}}"
    style="height: {{homeScrolled ? navBarHeight : statusBarHeight}}px; padding-top: {{homeScrolled ? navPaddingTop : 0}}px;"
  >
    <view
      wx:if="{{homeScrolled}}"
      class="home-status-bar-shield-nav"
      style="height: {{navRowHeight}}px;"
    >
      <text class="home-nav-title home-status-bar-shield-title">星链相连</text>
    </view>
  </view>
  <include src="../home/home-shared-content.wxml" />
  <view wx:if="{{showRegisterBar}}" class="home-intro-bottom-bar">
    <view class="home-section home-intro-bottom-bar-inner">
      <view
        class="home-intro-register-btn"
        hover-class="home-intro-register-btn--active"
        bindtap="goRegister"
      >
        立即注册
      </view>
    </view>
  </view>
  <include src="../home/home-banner-video-modal.wxml" />
</view>
