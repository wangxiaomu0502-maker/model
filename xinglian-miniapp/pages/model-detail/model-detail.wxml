<page-meta page-style="{{showBookingPopup || showPortfolioPopup ? 'overflow: hidden;' : ''}}"></page-meta>
<view
  class="page page-themed-root page-themed-root--bottombar detail-page {{showBookingPopup || showPortfolioPopup ? 'detail-page--modal-open' : ''}}"
>
  <view class="detail-fancy-bg detail-fancy-bg--pink"></view>
  <view class="detail-fancy-bg detail-fancy-bg--blue"></view>
  <view wx:if="{{loading}}" class="detail-state detail-state--loading">
    <text class="detail-state-text">加载中…</text>
  </view>

  <view wx:elif="{{loadError}}" class="detail-state detail-state--err">
    <text class="detail-state-text">{{loadError}}</text>
  </view>

  <scroll-view
    wx:elif="{{model}}"
    scroll-y="{{!showBookingPopup && !showPortfolioPopup}}"
    class="detail-scroll {{showBookingPopup || showPortfolioPopup ? 'detail-scroll--locked' : ''}}"
    show-scrollbar="{{false}}"
  >
    <view class="detail-stack">
      <!-- 顶部人物 -->
      <view class="detail-hero">
        <view class="detail-hero-orb detail-hero-orb--main"></view>
        <view class="detail-hero-orb detail-hero-orb--sub"></view>
        <image
          class="detail-hero-avatar"
          src="{{model.avatarUrl || '/assets/logo/logo.png'}}"
          mode="aspectFill"
          data-url="{{model.avatarUrl}}"
          bindtap="onPreviewImage"
        />
        <view class="detail-hero-text">
          <view class="detail-hero-kicker">
            <text class="detail-hero-kicker-dot"></text>
            <text>{{model.modelLevel ? model.modelLevel.code + " " + model.modelLevel.name : "STAR MODEL PICK"}}</text>
          </view>
          <text class="detail-hero-name">{{model.nickname}}</text>
          <text class="detail-hero-sub">{{model.city || "城市未填"}} · {{model.gender || "—"}}</text>
          <view class="detail-hero-tags">
            <text class="detail-hero-tag">{{model.modelLevel ? model.modelLevel.temperament : "高颜值"}}</text>
            <text wx:if="{{model.modelLevel && model.modelLevel.level === 5}}" class="detail-hero-tag detail-hero-tag--featured">平台优选</text>
            <text class="detail-hero-tag">可预约</text>
            <text class="detail-hero-tag">详情档案</text>
          </view>
        </view>
      </view>

      <!-- 报价 -->
      <view class="detail-panel">
        <view class="detail-panel-head">
          <view class="detail-panel-mark"></view>
          <text class="detail-panel-title">服务报价</text>
        </view>
        <view class="detail-price-grid">
          <view class="detail-price-item">
            <text class="detail-price-item-label">按小时</text>
            <text class="detail-price-item-val">{{model.price.hourly != null ? model.price.hourly + " 元" : "—"}}</text>
          </view>
          <view class="detail-price-item">
            <text class="detail-price-item-label">半天</text>
            <text class="detail-price-item-val">{{model.price.halfDay != null ? model.price.halfDay + " 元" : "—"}}</text>
          </view>
          <view class="detail-price-item">
            <text class="detail-price-item-label">全天</text>
            <text class="detail-price-item-val">{{model.price.fullDay != null ? model.price.fullDay + " 元" : "—"}}</text>
          </view>
        </view>
      </view>

      <!-- 模卡 -->
      <view class="detail-panel detail-panel--card" wx:if="{{showCardPanel}}">
        <view class="detail-card-glow detail-card-glow--top"></view>
        <view class="detail-card-glow detail-card-glow--bottom"></view>
        <view class="detail-card-head">
          <view class="detail-panel-head detail-card-title-wrap">
            <view class="detail-panel-mark detail-panel-mark--accent"></view>
            <view class="detail-panel-head-text">
              <text class="detail-panel-title">模卡</text>
              <text class="detail-panel-sub">身材数据 · 展示照片</text>
            </view>
          </view>
          <text wx:if="{{cardUrls.length}}" class="detail-card-count">{{cardUrls.length}} 张</text>
        </view>
        <view class="detail-card-swiper-wrap" wx:if="{{cardUrls.length}}">
          <swiper
            class="detail-card-swiper"
            current="{{cardSwiperIndex}}"
            bindchange="onCardSwiperChange"
            circular="{{cardUrls.length > 1}}"
            duration="300"
            easing-function="easeOutCubic"
          >
            <swiper-item wx:for="{{cardPhotoItems}}" wx:key="url">
              <view
                class="detail-card-slide"
                data-url="{{item.url}}"
                data-from="card"
                bindtap="onPreviewImage"
              >
                <image class="detail-card-slide-img" src="{{item.url}}" mode="aspectFill" />
                <view class="detail-card-slide-mask">
                  <text class="detail-card-slide-hint">点击查看大图</text>
                </view>
              </view>
            </swiper-item>
          </swiper>
          <view class="detail-card-swiper-foot" wx:if="{{cardUrls.length > 1}}">
            <view class="detail-card-dots">
              <view
                wx:for="{{cardUrls}}"
                wx:key="*this"
                class="detail-card-dot {{cardSwiperIndex === index ? 'detail-card-dot--on' : ''}}"
              ></view>
            </view>
            <text class="detail-card-page">{{cardSwiperPageText}}</text>
          </view>
        </view>
        <view class="detail-card-metrics" wx:if="{{cardPrimaryMetrics.length}}">
          <view class="detail-card-metric" wx:for="{{cardPrimaryMetrics}}" wx:key="label">
            <text class="detail-card-metric-label">{{item.label}}</text>
            <view class="detail-card-metric-value-row">
              <text class="detail-card-metric-value">{{item.value}}</text>
              <text wx:if="{{item.unit}}" class="detail-card-metric-unit">{{item.unit}}</text>
            </view>
          </view>
        </view>
        <view class="detail-pill-row detail-card-chip-row" wx:if="{{cardSecondaryMetrics.length || cardStyleTags.length}}">
          <text
            wx:for="{{cardSecondaryMetrics}}"
            wx:key="label"
            class="detail-card-chip"
          >{{item.label}} {{item.value}}{{item.unit}}</text>
          <text
            wx:for="{{cardStyleTags}}"
            wx:for-item="tag"
            wx:key="*this"
            class="detail-card-chip detail-card-chip--tone"
          >{{tag}}</text>
        </view>
      </view>

      <!-- 风格定位 -->
      <view class="detail-panel detail-panel--style" wx:if="{{showStylePanel}}">
        <view class="detail-panel-head">
          <view class="detail-panel-mark detail-panel-mark--accent"></view>
          <view class="detail-panel-head-text">
            <text class="detail-panel-title">风格定位</text>
            <text class="detail-panel-sub">个人风格与拍摄方向</text>
          </view>
          <text class="detail-section-count">{{stylePositionPhotos.length}} 张</text>
        </view>
        <scroll-view
          scroll-x
          class="detail-style-strip"
          show-scrollbar="{{false}}"
        >
          <image
            wx:for="{{stylePositionPhotos}}"
            wx:for-index="idx"
            wx:key="idx"
            class="detail-style-photo"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            data-from="stylePosition"
            bindtap="onPreviewImage"
          />
        </scroll-view>
        <text class="detail-strip-hint" wx:if="{{stylePositionPhotos.length > 1}}">左右滑动查看更多</text>
      </view>

      <!-- 荣誉展示 -->
      <view class="detail-panel detail-panel--honors" wx:if="{{showHonorsPanel}}">
        <view class="detail-panel-head">
          <view class="detail-panel-mark detail-panel-mark--accent"></view>
          <view class="detail-panel-head-text">
            <text class="detail-panel-title">荣誉展示</text>
            <text class="detail-panel-sub">个人荣誉与奖项</text>
          </view>
          <text class="detail-section-count">{{honors.length}} 项</text>
        </view>
        <view class="detail-honor-list">
          <view class="detail-honor-item" wx:for="{{honors}}" wx:key="id">
            <image
              wx:if="{{item.imageUrl}}"
              class="detail-honor-thumb"
              src="{{item.imageUrl}}"
              mode="aspectFill"
              data-url="{{item.imageUrl}}"
              data-from="honor"
              bindtap="onPreviewImage"
            />
            <view wx:else class="detail-honor-thumb detail-honor-thumb--empty">
              <text class="detail-honor-mark">奖</text>
            </view>
            <text class="detail-honor-title">{{item.title}}</text>
          </view>
        </view>
      </view>

      <!-- 作品集 -->
      <view class="detail-panel detail-panel--portfolio" wx:if="{{showPortfolioPanel}}">
        <view class="detail-panel-head">
          <view class="detail-panel-mark"></view>
          <view class="detail-panel-head-text">
            <text class="detail-panel-title">作品集</text>
            <text class="detail-panel-sub">按文件夹分类展示</text>
          </view>
          <text class="detail-section-count">{{portfolioPhotoCount}} 张</text>
        </view>
        <view
          class="detail-portfolio-folder"
          wx:for="{{portfolioSections}}"
          wx:for-item="folder"
          wx:key="id"
        >
          <view class="detail-portfolio-folder-head">
            <text class="detail-portfolio-folder-name">{{folder.name}}</text>
            <text class="detail-portfolio-folder-meta">{{folder.urls.length}} 张</text>
          </view>
          <scroll-view
            scroll-x
            class="detail-media-strip"
            show-scrollbar="{{false}}"
          >
            <image
              wx:for="{{folder.urls}}"
              wx:for-item="photoUrl"
              wx:for-index="pidx"
              wx:key="pidx"
              class="detail-media-thumb"
              src="{{photoUrl}}"
              mode="aspectFill"
              data-url="{{photoUrl}}"
              data-section-id="{{folder.id}}"
              bindtap="onPreviewImage"
            />
          </scroll-view>
        </view>
        <view class="detail-portfolio-more" bindtap="onOpenPortfolioPopup">
          <text class="detail-portfolio-more-text">查看全部作品集</text>
          <text class="detail-portfolio-more-arrow">›</text>
        </view>
      </view>

      <!-- 接单说明 -->
      <view class="detail-panel" wx:if="{{model.orderSettings}}">
        <view class="detail-panel-head">
          <view class="detail-panel-mark"></view>
          <text class="detail-panel-title">接单说明</text>
        </view>
        <view class="order-brief">
          <view class="order-brief-line">
            <text class="order-brief-label">接单状态</text>
            <text class="order-brief-val">{{model.orderSettings.orderEnabled ? "开放预约" : "暂停接单"}}</text>
          </view>
          <view class="order-brief-line">
            <text class="order-brief-label">地域</text>
            <text class="order-brief-val">{{model.orderSettings.onlyLocal ? "仅本地单" : "可接异地单"}}</text>
          </view>
          <view class="order-brief-line">
            <text class="order-brief-label">客户</text>
            <text class="order-brief-val">{{model.orderSettings.onlyFemale ? "仅女性客户" : "不限客户性别"}}</text>
          </view>
        </view>
      </view>

      <!-- 简介 -->
      <view class="detail-panel detail-panel--intro">
        <view class="detail-panel-head">
          <view class="detail-panel-mark"></view>
          <text class="detail-panel-title">简介</text>
        </view>
        <text class="detail-intro-body">{{model.intro || "暂无简介"}}</text>
      </view>

      <view wx:if="{{isVisitor}}" class="detail-panel visitor-detail-cta">
        <view class="visitor-detail-cta-text">
          <text class="visitor-detail-cta-title">喜欢这位模特？</text>
          <text class="visitor-detail-cta-desc">注册成为客户后即可发起预约、查看订单进度。</text>
        </view>
        <button class="visitor-detail-cta-btn" size="mini" bindtap="goRegister">去注册</button>
      </view>

      <view class="detail-scroll-pad" style="height: calc(128rpx + {{safeAreaBottomPx}}px);"></view>
    </view>
  </scroll-view>

  <view class="bottom-bar bottom-bar--detail" style="padding-bottom: calc(16rpx + {{safeAreaBottomPx}}px);">
    <view wx:if="{{quoteLine}}" class="bottom-quote">
      <text class="bottom-quote-line">{{quoteLine}}</text>
    </view>
    <button
      class="save-btn detail-order-btn {{bookingRestricted ? 'detail-order-btn--restricted' : ''}}"
      bindtap="onPlaceOrder"
      disabled="{{!model || bookingRestricted}}"
    >
      {{orderBtnTitle}}
    </button>
  </view>

  <view
    wx:if="{{showBookingPopup || showPortfolioPopup}}"
    class="detail-scroll-lock"
    catchtouchmove="preventTouchMove"
  ></view>

  <view wx:if="{{showBookingPopup}}" class="popup-mask" bindtap="onCloseBookingPopup" catchtouchmove="preventTouchMove">
    <view class="popup-panel popup-panel--booking" style="padding-bottom: calc(28rpx + {{safeAreaBottomPx}}px);" catchtap="preventPopupTapBubble">
      <view class="popup-head">
        <text class="popup-title">预约模特</text>
        <text class="popup-close" bindtap="onCloseBookingPopup">关闭</text>
      </view>

      <scroll-view scroll-y class="booking-popup-scroll" show-scrollbar="{{false}}">
      <view class="popup-section">
        <text class="popup-section-title">1. 选择预约日期</text>
        <view wx:if="{{bookableDateOptions.length === 0}}" class="empty-hint">暂无可预约日期，请稍后再试。</view>
        <view wx:else class="date-list">
          <view
            wx:for="{{bookableDateOptions}}"
            wx:key="dateKey"
            class="date-row {{selectedDateKey === item.dateKey ? 'date-row-on' : ''}}"
            data-key="{{item.dateKey}}"
            bindtap="onPickDate"
          >
            <text class="date-row-main">{{item.label}}</text>
            <text class="date-row-check" wx:if="{{selectedDateKey === item.dateKey}}">已选</text>
          </view>
        </view>
      </view>

      <view class="popup-section">
        <text class="popup-section-title">2. 选择服务类型</text>
        <view class="seg">
          <view
            class="seg-item {{serviceType === 'ordinary' ? 'seg-on' : ''}}"
            data-service-type="ordinary"
            bindtap="onPickServiceType"
          >普通服务</view>
          <view
            class="seg-item {{serviceType === 'agent' ? 'seg-on' : ''}}"
            data-service-type="agent"
            bindtap="onPickServiceType"
          >代理服务</view>
        </view>
        <view class="empty-hint">代理服务表示本次服务由代理方提供影棚。</view>
      </view>

      <view class="popup-section">
        <text class="popup-section-title">3. 选择服务时长</text>
        <view class="seg">
          <view
            wx:if="{{model.price.fullDay != null}}"
            class="seg-item {{durationKind === 'fullDay' ? 'seg-on' : ''}}"
            data-kind="fullDay"
            bindtap="onPickDuration"
          >全天</view>
          <view
            wx:if="{{model.price.halfDay != null}}"
            class="seg-item {{durationKind === 'halfDay' ? 'seg-on' : ''}}"
            data-kind="halfDay"
            bindtap="onPickDuration"
          >半天</view>
          <view
            wx:if="{{model.price.hourly != null}}"
            class="seg-item {{durationKind === 'hourly' ? 'seg-on' : ''}}"
            data-kind="hourly"
            bindtap="onPickDuration"
          >按小时</view>
        </view>
        <view wx:if="{{durationKind === 'hourly'}}" class="hour-block">
          <text class="hour-label">预约小时数（1–{{hourLabels.length}} 小时）</text>
          <picker mode="selector" range="{{hourLabels}}" value="{{hourIndex}}" bindchange="onHourPickerChange">
            <view class="hour-picker">{{hourLabels[hourIndex]}}</view>
          </picker>
        </view>
      </view>

      <view class="popup-section">
        <text class="popup-section-title">4. 备注信息（选填）</text>
        <textarea
          class="booking-remark-input"
          value="{{merchantRemark}}"
          maxlength="500"
          placeholder="可填写拍摄需求、到场时间、联系人等备注"
          placeholder-class="booking-remark-placeholder"
          auto-height="{{false}}"
          bindinput="onMerchantRemarkInput"
        />
        <text class="booking-remark-count">{{merchantRemark.length}}/500</text>
      </view>
      </scroll-view>

      <button class="save-btn popup-btn" bindtap="onConfirmBooking" disabled="{{!canSubmit}}">{{orderBtnTitle}}</button>
    </view>
  </view>

  <view wx:if="{{showPortfolioPopup}}" class="popup-mask" bindtap="onClosePortfolioPopup" catchtouchmove="preventTouchMove">
    <view class="popup-panel popup-panel--portfolio" catchtap="preventPopupTapBubble">
      <view class="popup-head">
        <view class="popup-head-text">
          <text class="popup-title">作品集</text>
          <text class="popup-sub">共 {{portfolioPhotoCount}} 张</text>
        </view>
        <text class="popup-close" bindtap="onClosePortfolioPopup">关闭</text>
      </view>
      <scroll-view scroll-y class="portfolio-popup-scroll" show-scrollbar="{{false}}">
        <view class="portfolio-popup-body">
          <view class="portfolio-folder" wx:for="{{portfolioSections}}" wx:for-item="folder" wx:key="id">
            <text class="portfolio-folder-name">{{folder.name}}</text>
            <view class="portfolio-popup-grid">
              <image
                wx:for="{{folder.urls}}"
                wx:for-item="photoUrl"
                wx:for-index="pidx"
                wx:key="pidx"
                class="portfolio-popup-thumb"
                src="{{photoUrl}}"
                mode="aspectFill"
                data-url="{{photoUrl}}"
                data-section-id="{{folder.id}}"
                bindtap="onPreviewImage"
              />
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
