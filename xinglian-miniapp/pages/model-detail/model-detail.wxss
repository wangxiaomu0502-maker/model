@import "../../styles/xl-theme.wxss";

/* 详情页字体层级（rpx） */
/* 弹窗打开：固定页面，避免底层原生 scroll-view 仍可滑动 */
.detail-page--modal-open {
  overflow: hidden;
  height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

/* 透明挡层：拦截滑动，不遮挡背后内容（遮罩负责变暗） */
.detail-scroll-lock {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1090;
  background: transparent;
}

.detail-page {
  --detail-font-xs: 22rpx;
  --detail-font-sm: 24rpx;
  --detail-font-base: 28rpx;
  --detail-font-md: 30rpx;
  --detail-font-lg: 34rpx;
  --detail-font-xl: 42rpx;
  --detail-color-title: #0f172a;
  --detail-color-body: #334155;
  --detail-color-muted: #64748b;
  --detail-color-hint: #94a3b8;
  --detail-color-brand: #4338ca;
  --detail-lh-tight: 1.25;
  --detail-lh-normal: 1.5;
  --detail-lh-loose: 1.7;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
  color: var(--detail-color-body);
}

.detail-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.detail-scroll--locked {
  pointer-events: none;
}

/* 垂直栈：统一间距 */
.detail-stack {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-bottom: 8rpx;
}

.detail-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

.detail-state-text {
  font-size: var(--detail-font-base);
  color: var(--detail-color-muted);
  text-align: center;
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
}

.detail-state--err .detail-state-text {
  color: #b91c1c;
}

.detail-state--loading .detail-state-text {
  color: #64748b;
}

/* ---------- 顶部人物 ---------- */
.detail-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #312e81 0%, #4338ca 42%, #6366f1 100%);
  box-shadow: 0 16rpx 40rpx rgba(67, 56, 202, 0.32);
}

.detail-hero-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.22);
  background: rgba(255, 255, 255, 0.15);
}

.detail-hero-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-hero-name {
  font-size: var(--detail-font-xl);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.04em;
  line-height: var(--detail-lh-tight);
}

.detail-hero-sub {
  font-size: var(--detail-font-sm);
  line-height: var(--detail-lh-normal);
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 0.02em;
  word-break: break-all;
}

.detail-hero-portfolio-btn {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-width: 96rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.detail-hero-portfolio-btn:active {
  opacity: 0.88;
  transform: scale(0.97);
}

.detail-hero-portfolio-btn-text {
  font-size: var(--detail-font-sm);
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.08em;
  line-height: var(--detail-lh-tight);
}

.detail-hero-portfolio-btn-count {
  font-size: var(--detail-font-xs);
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  font-variant-numeric: tabular-nums;
  line-height: var(--detail-lh-tight);
}

/* ---------- 通用区块 ---------- */
.detail-panel {
  padding: 26rpx 26rpx 28rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 250, 255, 0.96) 100%);
  border: 1rpx solid rgba(129, 140, 248, 0.18);
  box-shadow: 0 10rpx 36rpx rgba(79, 70, 229, 0.06);
}

.detail-panel--intro {
  background: linear-gradient(180deg, #ffffff 0%, rgba(249, 250, 255, 0.98) 100%);
}

.detail-panel--card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f7f8ff 48%, #eef2ff 100%);
  border-color: rgba(99, 102, 241, 0.2);
  box-shadow: 0 18rpx 44rpx rgba(67, 56, 202, 0.1);
}

.detail-panel--style {
  background: linear-gradient(180deg, #ffffff 0%, rgba(245, 243, 255, 0.96) 100%);
}

.detail-panel--portfolio {
  background: linear-gradient(180deg, #ffffff 0%, rgba(248, 250, 255, 0.98) 100%);
}

.detail-section-count {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--detail-font-xs);
  font-weight: 600;
  color: #4f46e5;
  line-height: var(--detail-lh-tight);
  letter-spacing: 0.04em;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(99, 102, 241, 0.18);
  box-shadow: 0 8rpx 18rpx rgba(79, 70, 229, 0.08);
}

.detail-strip-hint {
  display: block;
  margin-top: 14rpx;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  text-align: center;
  letter-spacing: 0.04em;
}

.detail-portfolio-folder {
  margin-bottom: 22rpx;
}

.detail-portfolio-folder:last-of-type {
  margin-bottom: 0;
}

.detail-portfolio-folder-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.detail-portfolio-folder-name {
  font-size: var(--detail-font-sm);
  font-weight: 700;
  color: var(--detail-color-title);
  letter-spacing: 0.04em;
}

.detail-portfolio-folder-meta {
  flex-shrink: 0;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  font-variant-numeric: tabular-nums;
}

.detail-portfolio-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 22rpx;
  padding: 18rpx 0 4rpx;
  border-top: 1rpx solid rgba(129, 140, 248, 0.14);
}

.detail-portfolio-more-text {
  font-size: var(--detail-font-sm);
  font-weight: 600;
  color: #4338ca;
  letter-spacing: 0.04em;
}

.detail-portfolio-more-arrow {
  font-size: 32rpx;
  font-weight: 600;
  color: #6366f1;
  line-height: 1;
}

.detail-card-glow {
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(2rpx);
}

.detail-card-glow--top {
  top: -142rpx;
  right: -118rpx;
  background: rgba(129, 140, 248, 0.22);
}

.detail-card-glow--bottom {
  left: -150rpx;
  bottom: 84rpx;
  background: rgba(236, 72, 153, 0.1);
}

.detail-card-head,
.detail-card-swiper-wrap,
.detail-card-metrics,
.detail-card-chip-row {
  position: relative;
  z-index: 1;
}

.detail-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.detail-card-title-wrap {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.detail-card-count {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--detail-font-xs);
  font-weight: 600;
  color: #4f46e5;
  line-height: var(--detail-lh-tight);
  letter-spacing: 0.04em;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(99, 102, 241, 0.18);
  box-shadow: 0 8rpx 18rpx rgba(79, 70, 229, 0.08);
}

.detail-card-swiper-wrap {
  border-radius: 28rpx;
  overflow: hidden;
  background: #e8ecf4;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.13);
}

.detail-card-swiper {
  width: 100%;
  height: 430rpx;
}

.detail-card-slide {
  position: relative;
  width: 100%;
  height: 100%;
}

.detail-card-slide-img {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-card-slide-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  padding: 76rpx 24rpx 22rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.68) 100%);
  pointer-events: none;
}

.detail-card-slide-label,
.detail-card-slide-hint {
  color: #ffffff;
  text-shadow: 0 3rpx 10rpx rgba(15, 23, 42, 0.32);
}

.detail-card-slide-label {
  font-size: var(--detail-font-xs);
  font-weight: 600;
  letter-spacing: 0.08em;
  opacity: 0.88;
}

.detail-card-slide-hint {
  flex-shrink: 0;
  font-size: var(--detail-font-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
}

.detail-card-swiper-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 18rpx 16rpx;
  background: rgba(255, 255, 255, 0.72);
  border-top: 1rpx solid rgba(99, 102, 241, 0.1);
}

.detail-card-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.detail-card-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(99, 102, 241, 0.22);
}

.detail-card-dot--on {
  width: 24rpx;
  background: #4f46e5;
}

.detail-card-page {
  flex-shrink: 0;
  font-size: var(--detail-font-xs);
  font-weight: 600;
  color: #4f46e5;
  letter-spacing: 0.06em;
}

.detail-card-swipe-hint {
  display: block;
  padding: 12rpx 18rpx 14rpx;
  font-size: var(--detail-font-xs);
  color: #64748b;
  text-align: center;
  background: rgba(255, 255, 255, 0.72);
  border-top: 1rpx solid rgba(99, 102, 241, 0.1);
}

.detail-card-metrics {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-card-metric {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(99, 102, 241, 0.14);
  box-shadow: 0 8rpx 22rpx rgba(79, 70, 229, 0.06);
}

.detail-card-metric-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  font-weight: 500;
  letter-spacing: 0.06em;
}

.detail-card-metric-value-row {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}

.detail-card-metric-value {
  min-width: 0;
  font-size: 34rpx;
  font-weight: 800;
  color: #312e81;
  line-height: var(--detail-lh-tight);
  letter-spacing: -0.02em;
  font-variant-numeric: tabular-nums;
  word-break: break-all;
}

.detail-card-metric-unit {
  padding-bottom: 3rpx;
  font-size: 20rpx;
  color: #6366f1;
  font-weight: 600;
  line-height: var(--detail-lh-tight);
}

.detail-card-chip-row {
  gap: 10rpx;
  margin-top: 16rpx;
}

.detail-card-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--detail-font-sm);
  color: #475569;
  font-weight: 600;
  line-height: var(--detail-lh-tight);
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
}

.detail-card-chip--tone {
  color: #4338ca;
  background: rgba(238, 242, 255, 0.86);
  border-color: rgba(99, 102, 241, 0.2);
}

.detail-panel-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.detail-panel--style .detail-panel-head,
.detail-panel--portfolio .detail-panel-head {
  align-items: center;
}

.detail-panel-mark {
  width: 8rpx;
  min-height: 36rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #6366f1 0%, #4338ca 100%);
}

.detail-panel-mark--accent {
  background: linear-gradient(180deg, #818cf8 0%, #6366f1 100%);
}

.detail-panel-head-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-panel-title {
  font-size: var(--detail-font-md);
  font-weight: 700;
  color: var(--detail-color-title);
  letter-spacing: 0.04em;
  line-height: var(--detail-lh-tight);
}

.detail-panel-sub {
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  font-weight: 400;
  letter-spacing: 0.02em;
  line-height: var(--detail-lh-normal);
}

/* ---------- 报价三列 ---------- */
.detail-price-grid {
  display: flex;
  align-items: stretch;
  gap: 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(99, 102, 241, 0.06);
  border: 1rpx solid rgba(129, 140, 248, 0.16);
}

.detail-price-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 12rpx;
  box-sizing: border-box;
}

.detail-price-item + .detail-price-item {
  border-left: 1rpx solid rgba(129, 140, 248, 0.14);
}

.detail-price-item-label {
  font-size: var(--detail-font-xs);
  color: var(--detail-color-muted);
  font-weight: 400;
  letter-spacing: 0.06em;
}

.detail-price-item-val {
  font-size: var(--detail-font-md);
  font-weight: 700;
  color: var(--detail-color-brand);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  line-height: var(--detail-lh-tight);
}

.detail-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-pill-row--dense {
  margin-bottom: 18rpx;
}

.detail-pill {
  font-size: var(--detail-font-sm);
  font-weight: 500;
  color: var(--detail-color-body);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(148, 163, 184, 0.35);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  line-height: var(--detail-lh-tight);
}

.detail-pill--accent {
  color: var(--detail-color-brand);
  font-weight: 600;
  border-color: rgba(99, 102, 241, 0.28);
  background: rgba(255, 255, 255, 0.92);
}

.detail-pill--rule {
  padding: 14rpx 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.order-brief {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 4rpx 0 2rpx;
}

.order-brief-line {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.7);
  box-sizing: border-box;
}

.order-brief-line:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.order-brief-label {
  flex-shrink: 0;
  font-size: var(--detail-font-sm);
  color: var(--detail-color-hint);
  font-weight: 400;
  letter-spacing: 0.04em;
}

.order-brief-val {
  flex: 1;
  text-align: right;
  font-size: var(--detail-font-sm);
  color: var(--detail-color-title);
  font-weight: 600;
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
}

.detail-intro-body {
  display: block;
  font-size: var(--detail-font-base);
  color: var(--detail-color-body);
  line-height: var(--detail-lh-loose);
  letter-spacing: 0.03em;
  text-align: justify;
}

/* ---------- 横向图片 ---------- */
.detail-media-strip {
  white-space: nowrap;
  width: 100%;
}

.detail-media-thumb {
  display: inline-block;
  vertical-align: top;
  width: 210rpx;
  height: 210rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: #e8ecf4;
  border: 1rpx solid rgba(129, 140, 248, 0.12);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.portfolio-folder {
  margin-bottom: 26rpx;
}

.portfolio-folder:last-child {
  margin-bottom: 0;
}

.portfolio-folder-name {
  display: block;
  font-size: var(--detail-font-sm);
  font-weight: 600;
  color: var(--detail-color-brand);
  margin-bottom: 14rpx;
  letter-spacing: 0.04em;
}

.detail-scroll-pad {
  height: calc(128rpx + env(safe-area-inset-bottom));
}

.detail-style-strip {
  white-space: nowrap;
  width: 100%;
}

.detail-style-photo {
  display: inline-block;
  width: 220rpx;
  height: 280rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: #e5e7eb;
  border: 1rpx solid rgba(129, 140, 248, 0.12);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.detail-style-photo:last-child {
  margin-right: 0;
}

.visitor-detail-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef2ff 100%);
  border-color: rgba(99, 102, 241, 0.22);
}

.visitor-detail-cta-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.visitor-detail-cta-title {
  font-size: var(--detail-font-md);
  font-weight: 700;
  color: #312e81;
  line-height: var(--detail-lh-tight);
}

.visitor-detail-cta-desc {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-muted);
  line-height: var(--detail-lh-normal);
}

.visitor-detail-cta-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 26rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4338ca 0%, #6366f1 100%);
  color: #ffffff;
  font-size: var(--detail-font-sm);
  font-weight: 700;
}

.visitor-detail-cta-btn::after {
  border: 0;
}

/* ---------- 底栏 ---------- */
.bottom-bar--detail .bottom-quote {
  margin-bottom: 14rpx;
}

.bottom-quote-line {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-muted);
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

.detail-order-btn::after {
  border: none;
}

/* 未激活/禁用：白底深字，避免紫底 + 半透明导致看不清 */
.bottom-bar--detail .detail-order-btn[disabled] {
  opacity: 1;
  color: #334155;
  font-weight: 600;
  background: #ffffff;
  border: 1rpx solid rgba(99, 102, 241, 0.32);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.detail-order-btn--restricted {
  font-size: var(--detail-font-sm);
  letter-spacing: 0.02em;
  line-height: 1.35;
  padding: 0 24rpx;
  white-space: normal;
  height: auto;
  min-height: 88rpx;
}

/* ---------- 弹层 ---------- */
.empty-hint {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-hint);
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
  margin: 24rpx 0;
}

.popup-section-title {
  display: block;
  font-size: var(--detail-font-base);
  font-weight: 600;
  color: var(--detail-color-title);
  letter-spacing: 0.03em;
  margin-bottom: 14rpx;
}

.date-list,
.date-scroll {
  margin-top: 8rpx;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 18rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(129, 140, 248, 0.22);
  background: rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.date-row-on {
  border-color: rgba(79, 70, 229, 0.45);
  background: rgba(99, 102, 241, 0.1);
}

.date-row-main {
  font-size: var(--detail-font-base);
  color: var(--detail-color-title);
  font-weight: 500;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

.date-row-check {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-brand);
  font-weight: 600;
  letter-spacing: 0.04em;
}

.seg {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 4rpx;
}

.seg-item {
  flex: 1;
  min-width: 160rpx;
  text-align: center;
  padding: 22rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(129, 140, 248, 0.25);
  font-size: var(--detail-font-sm);
  font-weight: 500;
  color: var(--detail-color-muted);
  letter-spacing: 0.04em;
  background: rgba(255, 255, 255, 0.88);
  box-sizing: border-box;
}

.seg-on {
  color: #ffffff;
  border-color: transparent;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  box-shadow: 0 6rpx 16rpx rgba(79, 70, 229, 0.35);
}

.hour-block {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(129, 140, 248, 0.15);
}

.hour-label {
  display: block;
  font-size: var(--detail-font-sm);
  color: var(--detail-color-muted);
  font-weight: 400;
  letter-spacing: 0.02em;
  margin-bottom: 12rpx;
}

.hour-picker {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(129, 140, 248, 0.35);
  font-size: var(--detail-font-base);
  font-weight: 600;
  color: var(--detail-color-title);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 248, 255, 0.92) 100%);
}

.booking-remark-input {
  width: 100%;
  height: 150rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(129, 140, 248, 0.28);
  box-sizing: border-box;
  font-size: var(--detail-font-base);
  line-height: var(--detail-lh-normal);
  color: var(--detail-color-title);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 248, 255, 0.92) 100%);
}

.booking-remark-placeholder {
  color: var(--detail-color-hint);
}

.booking-remark-count {
  display: block;
  margin-top: 8rpx;
  text-align: right;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
}

.popup-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.48);
  z-index: 1110;
  display: flex;
  align-items: flex-end;
}

.popup-panel {
  display: flex;
  flex-direction: column;
  width: 100%;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 82vh;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(129, 140, 248, 0.22);
  box-shadow: 0 -18rpx 48rpx rgba(79, 70, 229, 0.12);
}

.popup-panel--booking {
  height: 82vh;
}

.popup-head {
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.booking-popup-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
}

.popup-title {
  font-size: var(--detail-font-lg);
  color: var(--detail-color-title);
  font-weight: 700;
  letter-spacing: 0.03em;
  line-height: var(--detail-lh-tight);
}

.popup-close {
  font-size: var(--detail-font-sm);
  color: #6366f1;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.popup-section {
  margin-top: 8rpx;
}

.popup-btn {
  flex-shrink: 0;
  margin-top: 20rpx;
}

.popup-btn[disabled] {
  opacity: 1;
  color: #334155;
  font-weight: 600;
  background: #ffffff;
  border: 1rpx solid rgba(99, 102, 241, 0.32);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.popup-btn::after {
  border: none;
}

.popup-panel--portfolio {
  max-height: 88vh;
  display: flex;
  flex-direction: column;
}

.popup-head-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.popup-sub {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-hint);
  font-weight: 400;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

.portfolio-popup-scroll {
  height: 62vh;
  max-height: calc(88vh - 140rpx);
  width: 100%;
  box-sizing: border-box;
}

.portfolio-popup-body {
  padding-bottom: 12rpx;
}

.portfolio-popup-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.portfolio-popup-thumb {
  width: calc((100% - 28rpx) / 3);
  height: 210rpx;
  border-radius: 16rpx;
  background: #e8ecf4;
  border: 1rpx solid rgba(129, 140, 248, 0.14);
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}
