@import "../../styles/xl-theme.wxss";

/* 详情页字体层级（rpx） */
/* 弹窗打开：固定页面，避免底层原生 scroll-view 仍可滑动 */
.detail-page--modal-open {
  overflow: hidden;
  height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

/* 透明挡层：拦截滑动，不遮挡背后内容（遮罩负责变暗） */
.detail-scroll-lock {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1090;
  background: transparent;
}

.detail-page {
  --detail-font-xs: 22rpx;
  --detail-font-sm: 24rpx;
  --detail-font-base: 28rpx;
  --detail-font-md: 30rpx;
  --detail-font-lg: 34rpx;
  --detail-font-xl: 42rpx;
  --detail-color-title: #0f172a;
  --detail-color-body: #334155;
  --detail-color-muted: #64748b;
  --detail-color-hint: #94a3b8;
  --detail-color-brand: #db2777;
  --detail-color-purple: #7c3aed;
  --detail-color-orange: #f97316;
  --detail-lh-tight: 1.25;
  --detail-lh-normal: 1.5;
  --detail-lh-loose: 1.7;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
  color: var(--detail-color-body);
  background:
    radial-gradient(circle at 12% 3%, rgba(244, 114, 182, 0.34) 0, rgba(244, 114, 182, 0) 240rpx),
    radial-gradient(circle at 90% 12%, rgba(56, 189, 248, 0.28) 0, rgba(56, 189, 248, 0) 260rpx),
    linear-gradient(180deg, #fff1fb 0%, #eef4ff 340rpx, #f8fbff 100%);
}

.detail-fancy-bg {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  pointer-events: none;
}

.detail-fancy-bg--pink {
  top: 170rpx;
  left: -92rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(236, 72, 153, 0.22);
}

.detail-fancy-bg--blue {
  top: 620rpx;
  right: -116rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(99, 102, 241, 0.18);
}

.detail-scroll {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

.detail-scroll--locked {
  pointer-events: none;
}

/* 垂直栈：统一间距 */
.detail-stack {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-bottom: 8rpx;
}

.detail-state {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

.detail-state-text {
  font-size: var(--detail-font-base);
  color: var(--detail-color-muted);
  text-align: center;
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
}

.detail-state--err .detail-state-text {
  color: #b91c1c;
}

.detail-state--loading .detail-state-text {
  color: #64748b;
}

/* ---------- 顶部人物 ---------- */
.detail-hero {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0) 170rpx),
    linear-gradient(135deg, #7c3aed 0%, #ec4899 48%, #f97316 100%);
  box-shadow: 0 18rpx 46rpx rgba(236, 72, 153, 0.32);
}

.detail-hero-orb {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.detail-hero-orb--main {
  top: -88rpx;
  right: -54rpx;
  width: 250rpx;
  height: 250rpx;
  background: rgba(255, 255, 255, 0.22);
}

.detail-hero-orb--sub {
  left: 34rpx;
  bottom: -82rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(254, 240, 138, 0.14);
}

.detail-hero-avatar {
  position: relative;
  z-index: 1;
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 5rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 14rpx 32rpx rgba(124, 58, 237, 0.24);
  background: rgba(255, 255, 255, 0.15);
}

.detail-hero-text {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-hero-kicker {
  align-self: flex-start;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.94);
  letter-spacing: 0.08em;
  background: rgba(255, 255, 255, 0.18);
}

.detail-hero-kicker-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fef08a;
  box-shadow: 0 0 18rpx rgba(254, 240, 138, 0.95);
}

.detail-hero-name {
  font-size: var(--detail-font-xl);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.04em;
  line-height: var(--detail-lh-tight);
}

.detail-hero-sub {
  font-size: var(--detail-font-sm);
  line-height: var(--detail-lh-normal);
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 0.02em;
  word-break: break-all;
}

.detail-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-hero-tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.detail-hero-tag--featured {
  color: #92400e;
  background: #fef3c7;
  border-color: rgba(245, 158, 11, 0.32);
}

.detail-hero-portfolio-btn {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-width: 96rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.detail-hero-portfolio-btn:active {
  opacity: 0.88;
  transform: scale(0.97);
}

.detail-hero-portfolio-btn-text {
  font-size: var(--detail-font-sm);
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.08em;
  line-height: var(--detail-lh-tight);
}

.detail-hero-portfolio-btn-count {
  font-size: var(--detail-font-xs);
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  font-variant-numeric: tabular-nums;
  line-height: var(--detail-lh-tight);
}

/* ---------- 通用区块 ---------- */
.detail-panel {
  padding: 26rpx 26rpx 28rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(255, 247, 251, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 38rpx rgba(148, 163, 184, 0.16);
}

.detail-panel--intro {
  background: linear-gradient(180deg, #ffffff 0%, rgba(255, 247, 251, 0.98) 100%);
}

.detail-panel--card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fdf2f8 48%, #eef2ff 100%);
  border-color: rgba(236, 72, 153, 0.16);
  box-shadow: 0 18rpx 44rpx rgba(236, 72, 153, 0.12);
}

.detail-panel--style {
  background: linear-gradient(180deg, #ffffff 0%, rgba(253, 242, 248, 0.96) 100%);
}

.detail-panel--portfolio {
  background: linear-gradient(180deg, #ffffff 0%, rgba(255, 247, 237, 0.96) 100%);
}

.detail-section-count {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--detail-font-xs);
  font-weight: 600;
  color: #be185d;
  line-height: var(--detail-lh-tight);
  letter-spacing: 0.04em;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(244, 114, 182, 0.24);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.1);
}

.detail-strip-hint {
  display: block;
  margin-top: 14rpx;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  text-align: center;
  letter-spacing: 0.04em;
}

.detail-portfolio-folder {
  margin-bottom: 22rpx;
}

.detail-portfolio-folder:last-of-type {
  margin-bottom: 0;
}

.detail-portfolio-folder-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.detail-portfolio-folder-name {
  font-size: var(--detail-font-sm);
  font-weight: 700;
  color: var(--detail-color-title);
  letter-spacing: 0.04em;
}

.detail-portfolio-folder-meta {
  flex-shrink: 0;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  font-variant-numeric: tabular-nums;
}

.detail-portfolio-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 22rpx;
  padding: 18rpx 0 4rpx;
  border-top: 1rpx solid rgba(244, 114, 182, 0.14);
}

.detail-portfolio-more-text {
  font-size: var(--detail-font-sm);
  font-weight: 600;
  color: #be185d;
  letter-spacing: 0.04em;
}

.detail-portfolio-more-arrow {
  font-size: 32rpx;
  font-weight: 600;
  color: #f97316;
  line-height: 1;
}

.detail-card-glow {
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(2rpx);
}

.detail-card-glow--top {
  top: -142rpx;
  right: -118rpx;
  background: rgba(236, 72, 153, 0.2);
}

.detail-card-glow--bottom {
  left: -150rpx;
  bottom: 84rpx;
  background: rgba(249, 115, 22, 0.12);
}

.detail-card-head,
.detail-card-swiper-wrap,
.detail-card-metrics,
.detail-card-chip-row {
  position: relative;
  z-index: 1;
}

.detail-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.detail-card-title-wrap {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.detail-card-count {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--detail-font-xs);
  font-weight: 600;
  color: #be185d;
  line-height: var(--detail-lh-tight);
  letter-spacing: 0.04em;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(244, 114, 182, 0.24);
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.1);
}

.detail-card-swiper-wrap {
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff);
  box-shadow: 0 16rpx 36rpx rgba(124, 58, 237, 0.14);
}

.detail-card-swiper {
  width: 100%;
  height: 430rpx;
}

.detail-card-slide {
  position: relative;
  width: 100%;
  height: 100%;
}

.detail-card-slide-img {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-card-slide-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  padding: 76rpx 24rpx 22rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(88, 28, 135, 0.68) 100%);
  pointer-events: none;
}

.detail-card-slide-hint {
  color: #ffffff;
  text-shadow: 0 3rpx 10rpx rgba(15, 23, 42, 0.32);
  flex-shrink: 0;
  font-size: var(--detail-font-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
}

.detail-card-swiper-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 18rpx 16rpx;
  background: rgba(255, 247, 251, 0.82);
  border-top: 1rpx solid rgba(236, 72, 153, 0.1);
}

.detail-card-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.detail-card-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(236, 72, 153, 0.22);
}

.detail-card-dot--on {
  width: 24rpx;
  background: linear-gradient(135deg, #ec4899, #f97316);
}

.detail-card-page {
  flex-shrink: 0;
  font-size: var(--detail-font-xs);
  font-weight: 600;
  color: #be185d;
  letter-spacing: 0.06em;
}

.detail-card-swipe-hint {
  display: block;
  padding: 12rpx 18rpx 14rpx;
  font-size: var(--detail-font-xs);
  color: #64748b;
  text-align: center;
  background: rgba(255, 255, 255, 0.72);
  border-top: 1rpx solid rgba(244, 114, 182, 0.1);
}

.detail-card-metrics {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-card-metric {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(244, 114, 182, 0.16);
  box-shadow: 0 8rpx 22rpx rgba(236, 72, 153, 0.08);
}

.detail-card-metric-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  font-weight: 500;
  letter-spacing: 0.06em;
}

.detail-card-metric-value-row {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}

.detail-card-metric-value {
  min-width: 0;
  font-size: 34rpx;
  font-weight: 800;
  color: #be185d;
  line-height: var(--detail-lh-tight);
  letter-spacing: -0.02em;
  font-variant-numeric: tabular-nums;
  word-break: break-all;
}

.detail-card-metric-unit {
  padding-bottom: 3rpx;
  font-size: 20rpx;
  color: #f97316;
  font-weight: 600;
  line-height: var(--detail-lh-tight);
}

.detail-card-chip-row {
  gap: 10rpx;
  margin-top: 16rpx;
}

.detail-card-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--detail-font-sm);
  color: #475569;
  font-weight: 600;
  line-height: var(--detail-lh-tight);
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
}

.detail-card-chip--tone {
  color: #be185d;
  background: rgba(253, 242, 248, 0.9);
  border-color: rgba(244, 114, 182, 0.24);
}

.detail-panel-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.detail-panel--style .detail-panel-head,
.detail-panel--portfolio .detail-panel-head {
  align-items: center;
}

.detail-panel-mark {
  width: 8rpx;
  min-height: 36rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #ec4899 0%, #f97316 100%);
}

.detail-panel-mark--accent {
  background: linear-gradient(180deg, #7c3aed 0%, #ec4899 100%);
}

.detail-panel-head-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-panel-title {
  font-size: var(--detail-font-md);
  font-weight: 700;
  color: var(--detail-color-title);
  letter-spacing: 0.04em;
  line-height: var(--detail-lh-tight);
}

.detail-panel-sub {
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
  font-weight: 400;
  letter-spacing: 0.02em;
  line-height: var(--detail-lh-normal);
}

/* ---------- 报价三列 ---------- */
.detail-price-grid {
  display: flex;
  align-items: stretch;
  gap: 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(253, 242, 248, 0.92), rgba(255, 247, 237, 0.92));
  border: 1rpx solid rgba(244, 114, 182, 0.18);
}

.detail-price-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 12rpx;
  box-sizing: border-box;
}

.detail-price-item + .detail-price-item {
  border-left: 1rpx solid rgba(244, 114, 182, 0.14);
}

.detail-price-item-label {
  font-size: var(--detail-font-xs);
  color: var(--detail-color-muted);
  font-weight: 400;
  letter-spacing: 0.06em;
}

.detail-price-item-val {
  font-size: var(--detail-font-md);
  font-weight: 700;
  color: #be185d;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  line-height: var(--detail-lh-tight);
}

.detail-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-pill-row--dense {
  margin-bottom: 18rpx;
}

.detail-pill {
  font-size: var(--detail-font-sm);
  font-weight: 500;
  color: var(--detail-color-body);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(148, 163, 184, 0.35);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  line-height: var(--detail-lh-tight);
}

.detail-pill--accent {
  color: var(--detail-color-brand);
  font-weight: 600;
  border-color: rgba(244, 114, 182, 0.28);
  background: rgba(255, 255, 255, 0.92);
}

.detail-pill--rule {
  padding: 14rpx 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.order-brief {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 4rpx 0 2rpx;
}

.order-brief-line {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.7);
  box-sizing: border-box;
}

.order-brief-line:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.order-brief-label {
  flex-shrink: 0;
  font-size: var(--detail-font-sm);
  color: var(--detail-color-hint);
  font-weight: 400;
  letter-spacing: 0.04em;
}

.order-brief-val {
  flex: 1;
  text-align: right;
  font-size: var(--detail-font-sm);
  color: var(--detail-color-title);
  font-weight: 600;
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
}

.detail-intro-body {
  display: block;
  font-size: var(--detail-font-base);
  color: var(--detail-color-body);
  line-height: var(--detail-lh-loose);
  letter-spacing: 0.03em;
  text-align: justify;
}

/* ---------- 横向图片 ---------- */
.detail-media-strip {
  white-space: nowrap;
  width: 100%;
}

.detail-media-thumb {
  display: inline-block;
  vertical-align: top;
  width: 210rpx;
  height: 210rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(236, 72, 153, 0.12);
}

.portfolio-folder {
  margin-bottom: 26rpx;
}

.portfolio-folder:last-child {
  margin-bottom: 0;
}

.portfolio-folder-name {
  display: block;
  font-size: var(--detail-font-sm);
  font-weight: 600;
  color: #be185d;
  margin-bottom: 14rpx;
  letter-spacing: 0.04em;
}

.detail-scroll-pad {
  height: calc(128rpx + env(safe-area-inset-bottom));
}

.detail-style-strip {
  white-space: nowrap;
  width: 100%;
}

.detail-style-photo {
  display: inline-block;
  width: 220rpx;
  height: 280rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(124, 58, 237, 0.12);
}

.detail-style-photo:last-child {
  margin-right: 0;
}

.detail-honor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-honor-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(253, 242, 248, 0.92), rgba(238, 242, 255, 0.92));
  border: 1rpx solid rgba(236, 72, 153, 0.12);
}

.detail-honor-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #fff;
}

.detail-honor-thumb--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.detail-honor-mark {
  font-size: 30rpx;
  font-weight: 900;
  color: #be185d;
}

.detail-honor-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #334155;
  line-height: 1.45;
}

.visitor-detail-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fdf2f8 48%, #eef2ff 100%);
  border-color: rgba(236, 72, 153, 0.16);
}

.visitor-detail-cta-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.visitor-detail-cta-title {
  font-size: var(--detail-font-md);
  font-weight: 700;
  color: #be185d;
  line-height: var(--detail-lh-tight);
}

.visitor-detail-cta-desc {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-muted);
  line-height: var(--detail-lh-normal);
}

.visitor-detail-cta-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 26rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 55%, #f97316 100%);
  color: #ffffff;
  font-size: var(--detail-font-sm);
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(236, 72, 153, 0.3);
}

.visitor-detail-cta-btn::after {
  border: 0;
}

/* ---------- 底栏 ---------- */
.bottom-bar--detail .bottom-quote {
  margin-bottom: 14rpx;
}

.bottom-bar--detail {
  z-index: 2;
  background: rgba(255, 255, 255, 0.92);
  border-top: 1rpx solid rgba(244, 114, 182, 0.12);
  box-shadow: 0 -12rpx 30rpx rgba(236, 72, 153, 0.08);
}

.page-themed-root .detail-order-btn,
.page-themed-root .popup-btn {
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 55%, #f97316 100%);
  box-shadow: 0 16rpx 36rpx rgba(236, 72, 153, 0.3);
}

.bottom-quote-line {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-muted);
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

.detail-order-btn::after {
  border: none;
}

/* 未激活/禁用：白底深字，避免紫底 + 半透明导致看不清 */
.bottom-bar--detail .detail-order-btn[disabled] {
  opacity: 1;
  color: #334155;
  font-weight: 600;
  background: #ffffff;
  border: 1rpx solid rgba(244, 114, 182, 0.32);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.detail-order-btn--restricted {
  font-size: var(--detail-font-sm);
  letter-spacing: 0.02em;
  line-height: 1.35;
  padding: 0 24rpx;
  white-space: normal;
  height: auto;
  min-height: 88rpx;
}

/* ---------- 弹层 ---------- */
.empty-hint {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-hint);
  line-height: var(--detail-lh-normal);
  letter-spacing: 0.02em;
  margin: 24rpx 0;
}

.popup-section-title {
  display: block;
  font-size: var(--detail-font-base);
  font-weight: 600;
  color: var(--detail-color-title);
  letter-spacing: 0.03em;
  margin-bottom: 14rpx;
}

.date-list,
.date-scroll {
  margin-top: 8rpx;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 18rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(244, 114, 182, 0.22);
  background: rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.date-row-on {
  border-color: rgba(236, 72, 153, 0.45);
  background: rgba(253, 242, 248, 0.92);
}

.date-row-main {
  font-size: var(--detail-font-base);
  color: var(--detail-color-title);
  font-weight: 500;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

.date-row-check {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-brand);
  font-weight: 600;
  letter-spacing: 0.04em;
}

.seg {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 4rpx;
}

.seg-item {
  flex: 1;
  min-width: 160rpx;
  text-align: center;
  padding: 22rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(244, 114, 182, 0.24);
  font-size: var(--detail-font-sm);
  font-weight: 500;
  color: var(--detail-color-muted);
  letter-spacing: 0.04em;
  background: rgba(255, 255, 255, 0.88);
  box-sizing: border-box;
}

.seg-on {
  color: #ffffff;
  border-color: transparent;
  background: linear-gradient(135deg, #7c3aed, #ec4899 58%, #f97316);
  box-shadow: 0 8rpx 22rpx rgba(236, 72, 153, 0.3);
}

.hour-block {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(244, 114, 182, 0.15);
}

.hour-label {
  display: block;
  font-size: var(--detail-font-sm);
  color: var(--detail-color-muted);
  font-weight: 400;
  letter-spacing: 0.02em;
  margin-bottom: 12rpx;
}

.hour-picker {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(244, 114, 182, 0.28);
  font-size: var(--detail-font-base);
  font-weight: 600;
  color: var(--detail-color-title);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 247, 251, 0.92) 100%);
}

.booking-remark-input {
  width: 100%;
  height: 150rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(244, 114, 182, 0.28);
  box-sizing: border-box;
  font-size: var(--detail-font-base);
  line-height: var(--detail-lh-normal);
  color: var(--detail-color-title);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 247, 251, 0.92) 100%);
}

.booking-remark-placeholder {
  color: var(--detail-color-hint);
}

.booking-remark-count {
  display: block;
  margin-top: 8rpx;
  text-align: right;
  font-size: var(--detail-font-xs);
  color: var(--detail-color-hint);
}

.popup-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.48);
  z-index: 1110;
  display: flex;
  align-items: flex-end;
}

.popup-panel {
  display: flex;
  flex-direction: column;
  width: 100%;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 82vh;
  background: linear-gradient(180deg, #ffffff 0%, #fff7fb 100%);
  border-top: 1rpx solid rgba(244, 114, 182, 0.22);
  box-shadow: 0 -18rpx 48rpx rgba(236, 72, 153, 0.14);
}

.popup-panel--booking {
  height: 82vh;
}

.popup-head {
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.booking-popup-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

.popup-title {
  font-size: var(--detail-font-lg);
  color: var(--detail-color-title);
  font-weight: 700;
  letter-spacing: 0.03em;
  line-height: var(--detail-lh-tight);
}

.popup-close {
  font-size: var(--detail-font-sm);
  color: #db2777;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.popup-section {
  margin-top: 8rpx;
}

.popup-btn {
  flex-shrink: 0;
  margin-top: 20rpx;
}

.popup-btn[disabled] {
  opacity: 1;
  color: #334155;
  font-weight: 600;
  background: #ffffff;
  border: 1rpx solid rgba(244, 114, 182, 0.32);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.popup-btn::after {
  border: none;
}

.popup-panel--portfolio {
  max-height: 88vh;
  display: flex;
  flex-direction: column;
}

.popup-head-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.popup-sub {
  font-size: var(--detail-font-sm);
  color: var(--detail-color-hint);
  font-weight: 400;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

.portfolio-popup-scroll {
  height: 62vh;
  max-height: calc(88vh - 140rpx);
  width: 100%;
  box-sizing: border-box;
}

.portfolio-popup-body {
  padding-bottom: 12rpx;
}

.portfolio-popup-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.portfolio-popup-thumb {
  width: calc((100% - 28rpx) / 3);
  height: 210rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fdf2f8, #eef2ff);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 8rpx 20rpx rgba(236, 72, 153, 0.12);
  box-sizing: border-box;
}
