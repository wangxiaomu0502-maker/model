.shoot-page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #eef2ff 0%, #f4f6fb 220rpx, #f8fafc 100%);
}

.shoot-content {
  padding: 20rpx 24rpx calc(44rpx + env(safe-area-inset-bottom));
}

/* Hero */
.shoot-hero {
  position: relative;
  overflow: hidden;
  padding: 38rpx 32rpx 34rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.28) 0, rgba(255, 255, 255, 0) 180rpx),
    linear-gradient(135deg, #0ea5e9 0%, #2563eb 38%, #7c3aed 72%, #db2777 100%);
  box-shadow:
    0 20rpx 48rpx rgba(37, 99, 235, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.25);
}

.shoot-hero-shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.65), transparent);
}

.shoot-hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.22;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.85) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.85) 1rpx, transparent 1rpx);
  background-size: 32rpx 32rpx;
}

.shoot-hero-inner {
  position: relative;
  z-index: 1;
}

.shoot-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shoot-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.shoot-hero-chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #312e81;
  background: linear-gradient(135deg, #ffffff, #e0e7ff);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.15);
}

.shoot-title,
.shoot-desc,
.shoot-stat-num,
.shoot-stat-label,
.venue-name,
.venue-meta-key,
.venue-meta-val,
.venue-intro-label,
.venue-intro-text,
.pkg-name,
.pkg-remark,
.venue-price-label,
.venue-price-value {
  display: block;
}

.shoot-title {
  margin-top: 20rpx;
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #ffffff;
  text-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.2);
}

.shoot-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.86);
}

.shoot-stats {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.shoot-stat-item {
  flex: 1;
  text-align: center;
}

.shoot-stat-num {
  font-size: 36rpx;
  font-weight: 900;
  color: #ffffff;
}

.shoot-stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.shoot-stat-line {
  width: 1rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.25);
}

/* States */
.shoot-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  font-size: 26rpx;
  color: #94a3b8;
}

.shoot-state-ring {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  border: 4rpx solid rgba(37, 99, 235, 0.15);
  border-top-color: #2563eb;
  animation: spin 0.85s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.shoot-state-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #475569;
}

.shoot-state-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

/* Venue card */
.venue-card {
  position: relative;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow:
    0 16rpx 40rpx rgba(37, 99, 235, 0.1),
    0 0 0 1rpx rgba(226, 232, 240, 0.8);
}

.venue-rank {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 4;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  color: #ffffff;
  background: rgba(15, 23, 42, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.venue-media {
  position: relative;
}

.venue-swiper,
.venue-media-empty {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #dbeafe, #ede9fe, #fce7f3);
}

.venue-swiper-img {
  width: 100%;
  height: 100%;
}

.venue-media-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #94a3b8;
}

.venue-media-shade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  background: linear-gradient(180deg, transparent, rgba(15, 23, 42, 0.62));
  pointer-events: none;
}

.venue-media-foot {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 22rpx 22rpx;
}

.venue-price-badge {
  padding: 12rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.14);
  border-left: 6rpx solid #2563eb;
}

.venue-price-badge-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
}

.venue-price-badge-value {
  display: block;
  margin-top: 2rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #1d4ed8;
}

.venue-photo-num {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.venue-body {
  padding: 24rpx 24rpx 28rpx;
}

.venue-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.venue-name-line {
  flex-shrink: 0;
  width: 8rpx;
  height: 36rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2563eb, #db2777);
}

.venue-name {
  flex: 1;
  min-width: 0;
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 900;
  color: #0f172a;
}

/* Packages */
.venue-packages {
  margin-top: 24rpx;
  padding: 22rpx 20rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #f5f7ff, #faf5ff);
  border: 1rpx solid rgba(199, 210, 254, 0.45);
}

.venue-section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.venue-section-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.venue-section-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2563eb, #a855f7);
}

.venue-section-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #1e293b;
}

.venue-section-count {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #6366f1;
  background: rgba(99, 102, 241, 0.1);
}

.pkg-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pkg-item {
  overflow: hidden;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.08);
}

.pkg-cover {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.pkg-cover-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, #dbeafe, #ede9fe);
}

.pkg-cover-img--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
}

.pkg-price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 12rpx;
  padding-left: 58rpx;
}

.pkg-fee-wrap,
.pkg-origin-wrap {
  min-width: 0;
}

.pkg-fee-label,
.pkg-fee-value,
.pkg-origin-label,
.pkg-origin-value {
  display: block;
}

.pkg-fee-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #94a3b8;
}

.pkg-fee-value {
  margin-top: 4rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #1d4ed8;
}

.pkg-origin-wrap {
  flex-shrink: 0;
  text-align: right;
}

.pkg-origin-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #cbd5e1;
}

.pkg-origin-value {
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #94a3b8;
  text-decoration: line-through;
}

.pkg-info {
  padding: 18rpx 20rpx 22rpx;
}

.pkg-info-top {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.pkg-index {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #9333ea);
  box-shadow: 0 6rpx 16rpx rgba(99, 102, 241, 0.3);
}

.pkg-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #0f172a;
}

.pkg-remark-block {
  margin-top: 14rpx;
  padding: 16rpx 18rpx 14rpx;
  margin-left: 58rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
}

.pkg-remark-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
}

.pkg-remark-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.pkg-remark-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #475569;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.pkg-remark {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #64748b;
}

/* Meta */
.venue-meta {
  margin-top: 24rpx;
  padding-top: 8rpx;
}

.venue-meta-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx 0;
}

.venue-meta-row + .venue-meta-row {
  border-top: 1rpx solid #f1f5f9;
}

.venue-meta-row--phone {
  align-items: center;
}

.venue-meta-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
}

.venue-meta-row--phone .venue-meta-dot {
  margin-top: 0;
}

.venue-meta-dot--blue {
  background: #3b82f6;
  box-shadow: 0 0 12rpx rgba(59, 130, 246, 0.5);
}

.venue-meta-dot--violet {
  background: #8b5cf6;
  box-shadow: 0 0 12rpx rgba(139, 92, 246, 0.5);
}

.venue-meta-dot--cyan {
  background: #06b6d4;
  box-shadow: 0 0 12rpx rgba(6, 182, 212, 0.5);
}

.venue-meta-main {
  flex: 1;
  min-width: 0;
}

.venue-meta-key {
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
}

.venue-meta-val {
  margin-top: 4rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #334155;
  word-break: break-all;
}

.venue-call-btn {
  flex-shrink: 0;
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 55%, #db2777 100%);
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.28);
}

.venue-intro {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.95), rgba(245, 243, 255, 0.92));
  border: 1rpx solid rgba(199, 210, 254, 0.4);
}

.venue-intro-label {
  font-size: 22rpx;
  font-weight: 800;
  color: #4338ca;
}

.venue-intro-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #475569;
}

.shoot-foot {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 0 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.shoot-foot-pulse {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #2563eb;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 0.35;
    transform: scale(0.85);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

.shoot-foot--end {
  font-size: 22rpx;
  letter-spacing: 2rpx;
}
