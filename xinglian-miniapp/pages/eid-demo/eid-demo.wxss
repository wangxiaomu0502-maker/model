.page-root {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef4ff 0%, #f7f9fd 32%, #f3f6fc 100%);
}

.hero-card {
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #4338ca 52%, #7c3aed 100%);
  box-shadow: 0 18rpx 44rpx rgba(67, 56, 202, 0.26);
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.hero-title {
  display: block;
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
  line-height: 1.55;
}

.card {
  margin-top: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.label {
  display: block;
  color: #334155;
  font-size: 26rpx;
  font-weight: 700;
}

.label-gap {
  margin-top: 22rpx;
}

.api-text {
  display: block;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.input {
  margin-top: 14rpx;
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(199, 210, 254, 0.95);
  background: #f8fafc;
  color: #0f172a;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #94a3b8;
}

.primary-btn {
  margin-top: 30rpx;
  height: 88rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 48%, #7c3aed 100%);
  box-shadow: 0 14rpx 34rpx rgba(79, 70, 229, 0.3);
}

.primary-btn::after {
  border: none;
}

.primary-btn-hover {
  opacity: 0.92;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #94a3b8;
}

.status-dot-ok {
  background: #16a34a;
}

.status-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.result-text {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.result-ok {
  color: #15803d;
}

.result-error {
  color: #dc2626;
}

.token-box {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.token-label {
  display: block;
  color: #64748b;
  font-size: 23rpx;
}

.token-text {
  display: block;
  margin-top: 10rpx;
  color: #334155;
  font-size: 23rpx;
  line-height: 1.45;
  word-break: break-all;
}

.tips {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.tips-title {
  display: block;
  color: #334155;
  font-size: 25rpx;
  font-weight: 700;
}

.tips-line {
  display: block;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}
