<view class="page broker-page">
  <view class="broker-dash-hero">
    <view class="broker-hero-blob broker-hero-blob-1"></view>
    <view class="broker-hero-blob broker-hero-blob-2"></view>
    <view class="broker-hero-grid"></view>
    <view class="broker-dash-hero-inner">
      <view class="broker-dash-hero-main">
        <text class="broker-dash-eyebrow">常用功能</text>
        <text class="broker-dash-title">{{pageTitle}}</text>
        <text class="broker-dash-desc">通过您的推荐码绑定的模特</text>
      </view>
      <view class="broker-dash-stat">
        <text class="broker-dash-stat-num">{{total}}</text>
        <text class="broker-dash-stat-unit">位</text>
      </view>
    </view>
  </view>

  <view class="search card broker-toolbar">
    <input
      class="search-input"
      placeholder="搜索昵称或用户 ID"
      value="{{searchDraft}}"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
    <text wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">清除</text>
    <text wx:else class="search-go" bindtap="onSearchConfirm">搜索</text>
  </view>

  <scroll-view
    scroll-y
    class="scroll"
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onReachBottom"
    lower-threshold="120"
  >
    <view wx:if="{{loading && list.length === 0}}" class="hint">加载中…</view>
    <view wx:elif="{{!loading && list.length === 0}}" class="hint empty">{{emptyHint}}</view>

    <view
      wx:for="{{list}}"
      wx:key="userId"
      class="card item-card"
      data-user-no="{{item.userNo}}"
      data-audit="{{item.profileAuditStatus}}"
      bindtap="onModelCardTap"
    >
      <view class="item-head">
        <view class="av">
          <image wx:if="{{item.showAvatarImg}}" class="av-img" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="av-fallback">{{item.avatarText}}</text>
        </view>
        <view class="item-meta">
          <text class="item-name">{{item.nickname}}</text>
          <text class="item-sub">ID {{item.userNo}}</text>
          <text class="item-sub">绑定于 {{item.boundAt}} · {{item.city || "城市未填"}}</text>
        </view>
      </view>
      <view class="tag-row">
        <text class="tag tag--audit-{{item.auditTone}}">{{item.profileAuditStatusText}}</text>
        <text class="tag tag--contract-{{item.contractTone}}">{{item.contractSignedText}}</text>
        <text class="tag tag--order">{{item.orderEnabledText}}</text>
      </view>
      <view class="item-foot">
        <text class="item-foot-k">{{item.verifiedStatusText}}</text>
        <text wx:if="{{item.phoneMasked}}" class="item-foot-k">{{item.phoneMasked}}</text>
        <text class="item-more">查看资料 ›</text>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="hint foot">加载更多…</view>
    <view wx:elif="{{list.length > 0 && list.length >= total}}" class="hint foot">没有更多了</view>
    <view class="bottom-space"></view>
  </scroll-view>
</view>
