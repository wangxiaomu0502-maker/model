<view class="page page-themed-root page-themed-root--bottombar">
  <view wx:if="{{reviewBannerText}}" class="content-review-banner content-review-banner--{{reviewBannerType}}">
    {{reviewBannerText}}
  </view>

  <import src="../../templates/model-activation-banner.wxml" />
  <template is="modelActivationBanner" data="{{isActivated: isActivated}}" />

  <view class="section">
    <view class="section-head">
      <view class="section-title-wrap">
        <view class="section-title">身材比例卡图集</view>
        <text class="section-tag section-tag--required">需上传 1 张</text>
      </view>
    </view>
    <text class="hint">请上传包含正面、侧面、背面三视图及身材比例卡整张的合成图或标准图。纯色背景、光线均匀，单张不能超过 10M。</text>
    <view class="photo-grid photo-grid--single">
      <view
        class="photo-item photo-item--featured"
        wx:for="{{photoAngles}}"
        wx:key="key"
        wx:if="{{item.slotType === 'threeView'}}"
      >
        <text class="photo-slot-label">身材比例卡图集</text>
        <view class="photo-item-inner" data-key="{{item.key}}" bindtap="onPhotoTileTap">
          <image wx:if="{{item.url}}" class="photo photo--tall" src="{{item.url}}" mode="aspectFill"></image>
          <view wx:else class="photo-placeholder photo--tall">+</view>
          <view
            wx:if="{{item.url}}"
            class="photo-more-hit"
            catchtap="onCardPhotoMore"
            data-key="{{item.key}}"
          >
            <text class="photo-more-dots">···</text>
          </view>
          <view
            wx:if="{{item.url && item.reviewBadgeText}}"
            class="photo-review-badge photo-review-badge--{{item.reviewBadgeType}}"
          >
            {{item.reviewBadgeText}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title-wrap">
        <view class="section-title">身材比例卡单片展示</view>
        <text class="section-tag">最多 {{galleryMax}} 张</text>
      </view>
      <view class="batch-upload-btn" bindtap="chooseGalleryBatchPhotos">批量上传</view>
    </view>
    <text class="hint">上传身材比例卡单片展示图。点击空位上传；已上传照片点击预览，「···」可调整顺序或删除。一次最多选 {{galleryMax}} 张，单张不能超过 10M。</text>
    <view class="photo-grid">
      <view
        class="photo-item"
        wx:for="{{photoAngles}}"
        wx:key="key"
        wx:if="{{item.slotType === 'gallery'}}"
      >
        <text class="photo-slot-label">{{item.label}}</text>
        <view class="photo-item-inner" data-key="{{item.key}}" bindtap="onPhotoTileTap">
          <image wx:if="{{item.url}}" class="photo" src="{{item.url}}" mode="aspectFill"></image>
          <view wx:else class="photo-placeholder">+</view>
          <view
            wx:if="{{item.url}}"
            class="photo-more-hit"
            catchtap="onCardPhotoMore"
            data-key="{{item.key}}"
          >
            <text class="photo-more-dots">···</text>
          </view>
          <view
            wx:if="{{item.url && item.reviewBadgeText}}"
            class="photo-review-badge photo-review-badge--{{item.reviewBadgeType}}"
          >
            {{item.reviewBadgeText}}
          </view>
        </view>
      </view>
    </view>
    <text class="upload-count-hint">已上传 {{galleryUploadCount}} / {{galleryMax}} 张</text>
  </view>

  <view class="section">
    <view class="section-title">身材数据（必填）</view>
    <view class="field-row">
      <view class="field half">
        <text class="label">身高</text>
        <picker
          mode="selector"
          range="{{measureOptions.height}}"
          value="{{measureIndexes.height}}"
          data-field="height"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.height}} cm</view>
        </picker>
      </view>
      <view class="field half">
        <text class="label">体重</text>
        <picker
          mode="selector"
          range="{{measureOptions.weight}}"
          value="{{measureIndexes.weight}}"
          data-field="weight"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.weight}} kg</view>
        </picker>
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">胸围</text>
        <picker
          mode="selector"
          range="{{measureOptions.bust}}"
          value="{{measureIndexes.bust}}"
          data-field="bust"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.bust}} cm</view>
        </picker>
      </view>
      <view class="field half">
        <text class="label">腰围</text>
        <picker
          mode="selector"
          range="{{measureOptions.waist}}"
          value="{{measureIndexes.waist}}"
          data-field="waist"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.waist}} cm</view>
        </picker>
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">臀围</text>
        <picker
          mode="selector"
          range="{{measureOptions.hip}}"
          value="{{measureIndexes.hip}}"
          data-field="hip"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.hip}} cm</view>
        </picker>
      </view>
      <view class="field half">
        <text class="label">鞋码</text>
        <picker
          mode="selector"
          range="{{measureOptions.shoeSize}}"
          value="{{measureIndexes.shoeSize}}"
          data-field="shoeSize"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.shoeSize}} 码</view>
        </picker>
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">肩宽</text>
        <picker
          mode="selector"
          range="{{measureOptions.shoulder}}"
          value="{{measureIndexes.shoulder}}"
          data-field="shoulder"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.shoulder}} cm</view>
        </picker>
      </view>
      <view class="field half">
        <text class="label">臂展</text>
        <picker
          mode="selector"
          range="{{measureOptions.armSpan}}"
          value="{{measureIndexes.armSpan}}"
          data-field="armSpan"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.armSpan}} cm</view>
        </picker>
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">腿长</text>
        <picker
          mode="selector"
          range="{{measureOptions.legLength}}"
          value="{{measureIndexes.legLength}}"
          data-field="legLength"
          bindchange="onMeasurePick"
        >
          <view class="picker-value">{{measurements.legLength}} cm</view>
        </picker>
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">发色</text>
        <picker
          mode="selector"
          range="{{hairColorOptions}}"
          value="{{hairColorIndex}}"
          bindchange="onHairColorPick"
        >
          <view class="picker-value">{{hairColor}}</view>
        </picker>
      </view>
      <view class="field half">
        <text class="label">肤色</text>
        <picker
          mode="selector"
          range="{{skinColorOptions}}"
          value="{{skinColorIndex}}"
          bindchange="onSkinColorPick"
        >
          <view class="picker-value">{{skinColor}}</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="save-btn" bindtap="saveModelCard">保存模卡</button>
  </view>

  <import src="../../templates/model-activation-modal.wxml" />
  <template
    is="modelActivationModal"
    data="{{
      showActivationModal: showActivationModal,
      activationCodeInput: activationCodeInput,
      activationError: activationError,
      activationLoading: activationLoading
    }}"
  />
</view>
