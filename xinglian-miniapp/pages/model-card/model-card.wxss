@import "../../styles/xl-theme.wxss";
@import "../../styles/model-activation-modal.wxss";

.section {
  margin-bottom: 24rpx;
  padding: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.batch-upload-btn {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
}

.hint {
  margin-top: 10rpx;
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.section-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #4338ca;
  background: #eef2ff;
}

.section-tag--required {
  color: #b45309;
  background: #fff7ed;
}

.upload-count-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.photo-grid--single {
  grid-template-columns: 1fr;
}

.photo-item--featured {
  border-color: #fcd34d;
  background: #fffbeb;
}

.photo-slot-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #374151;
}

.photo-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.photo-item {
  position: relative;
  padding: 10rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  background: #f8fafc;
}

.photo-item-inner {
  position: relative;
}

.photo-more-hit {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  z-index: 2;
  width: 56rpx;
  height: 48rpx;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 4rpx 6rpx 0;
  box-sizing: border-box;
}

.photo-more-dots {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.55);
}

.photo {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  background: #e5e7eb;
}

.photo--tall {
  height: 320rpx;
}

.photo-placeholder {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  font-weight: 400;
}

.photo-placeholder.photo--tall {
  height: 320rpx;
}

.field-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.field {
  margin-bottom: 8rpx;
}

.half {
  flex: 1;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 23rpx;
  color: #4b5563;
}

.picker-value {
  width: 100%;
  height: 72rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  background: #fff;
}

.picker-placeholder {
  color: #9ca3af;
}
