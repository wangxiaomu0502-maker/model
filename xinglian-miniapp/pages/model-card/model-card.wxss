@import "../../styles/xl-theme.wxss";

.section {
  margin-bottom: 24rpx;
  padding: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.hint {
  margin-top: 10rpx;
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}

.photo-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.photo-item {
  padding: 10rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  background: #f8fafc;
}

.photo {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  background: #e5e7eb;
}

.photo-placeholder {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  font-weight: 400;
}

.field-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.field {
  margin-bottom: 8rpx;
}

.half {
  flex: 1;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 23rpx;
  color: #4b5563;
}

.picker-value {
  width: 100%;
  height: 72rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  background: #fff;
}

.picker-placeholder {
  color: #9ca3af;
}
