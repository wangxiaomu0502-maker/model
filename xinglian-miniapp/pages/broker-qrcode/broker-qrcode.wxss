@import "../../styles/broker-page-hero.wxss";

.broker-qrcode-page .broker-dash-hero-inner {
  display: block;
}

.hint {
  padding: 48rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}

.qr-card {
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.qr-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.qr-card-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}

.qr-frame {
  margin: 28rpx auto 24rpx;
  width: 520rpx;
  height: 520rpx;
  padding: 20rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #f8fafc 0%, #eef2ff 100%);
  border: 1rpx solid rgba(129, 140, 248, 0.28);
  box-shadow: 0 16rpx 40rpx rgba(79, 70, 229, 0.1);
  box-sizing: border-box;
}

.qr-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 24rpx;
}

.qr-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.qr-btn {
  flex: 1;
  max-width: 280rpx;
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 0;
}

.qr-btn::after {
  border: none;
}

.qr-btn--ghost {
  color: #4338ca;
  background: rgba(99, 102, 241, 0.1);
  border: 1rpx solid rgba(129, 140, 248, 0.35);
}

.qr-btn--primary {
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 52%, #7c3aed 100%);
  box-shadow: 0 12rpx 28rpx rgba(79, 70, 229, 0.32);
}

.id-card {
  padding: 28rpx 26rpx;
  margin-bottom: 20rpx;
}

.id-head {
  margin-bottom: 20rpx;
}

.id-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.id-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}

.id-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.id-row--last {
  border-bottom: none;
  padding-bottom: 8rpx;
}

.id-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #94a3b8;
}

.id-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  word-break: break-all;
}

.id-mono {
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.04em;
}

.id-copy-btn {
  width: 100%;
  margin-top: 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
  border-radius: 999rpx;
  border: none;
  padding: 0;
}

.id-copy-btn::after {
  border: none;
}

.id-copy-btn[disabled] {
  opacity: 0.45;
}

.tips {
  padding: 26rpx 24rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #475569;
  margin-bottom: 12rpx;
}

.tips-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: #64748b;
  margin-top: 8rpx;
}

.bottom-space {
  height: 32rpx;
}
