<view class="page-root">
  <view class="content">
    <view class="hero">
      <view class="hero-blob hero-blob-1"></view>
      <view class="hero-blob hero-blob-2"></view>
      <view class="hero-grid"></view>
      <view class="hero-inner">
        <text class="hero-kicker">注册向导</text>
        <text class="title">选择注册身份</text>
        <text class="subtitle">注册后将使用该身份使用平台功能；游客仅可浏览。</text>
        <text class="hero-tip">选定身份后需完成实名核验，再完善资料。</text>
      </view>
    </view>

    <view class="list-head">
      <view class="list-accent"></view>
      <text class="list-title">请选择身份</text>
    </view>

    <view class="identity-list">
      <view
        wx:for="{{identityList}}"
        wx:for-index="cardIdx"
        wx:key="key"
        class="identity-item identity-tone-{{cardIdx % 4}} {{currentIdentity === item.name ? 'active' : ''}} {{item.disabled ? 'disabled' : ''}}"
        data-identity="{{item.name}}"
        data-role="{{item.role}}"
        data-disabled="{{item.disabled}}"
        bindtap="selectIdentity"
        hover-class="{{item.disabled ? 'identity-item-hover-none' : 'identity-item-hover'}}"
        hover-stay-time="70"
      >
        <view class="identity-main">
          <view class="identity-head">
            <view class="identity-icon-wrap">
              <text class="identity-icon">{{item.icon}}</text>
            </view>
            <view class="identity-name-row">
              <text class="identity-name">{{item.name}}</text>
              <text wx:if="{{item.disabled && item.tag}}" class="identity-tag">{{item.tag}}</text>
            </view>
          </view>
          <text class="identity-desc">{{item.desc}}</text>
        </view>
        <view wx:if="{{!item.disabled}}" class="check {{currentIdentity === item.name ? 'checked' : ''}}">
          <text class="check-inner">{{currentIdentity === item.name ? '✓' : ''}}</text>
        </view>
        <text wx:if="{{item.disabled}}" class="disabled-text">不可选</text>
      </view>
    </view>

    <view class="scroll-spacer"></view>
  </view>

  <view class="bottom-bar">
    <button
      class="confirm-btn"
      hover-class="confirm-btn-hover"
      hover-stay-time="70"
      bindtap="confirmIdentity"
    >
      下一步
    </button>
  </view>

  <view
    wx:if="{{showModelModal}}"
    class="identity-modal-mask"
    bindtap="closeModelModal"
    catchtouchmove="preventModalBubble"
  >
    <view class="identity-modal-panel" catchtap="preventModalBubble">
      <view class="identity-modal-head">
        <text class="identity-modal-title">模特注册方式</text>
        <text class="identity-modal-close" bindtap="closeModelModal">关闭</text>
      </view>

      <block wx:if="{{modelModalStep === 'choose'}}">
        <text class="identity-modal-desc">请选择您的入驻方式</text>
        <view class="identity-modal-option" bindtap="onModelSelfRegister">
          <view class="identity-modal-option-main">
            <text class="identity-modal-option-title">自行注册</text>
            <text class="identity-modal-option-sub">完成实名核验并提交资料审核</text>
          </view>
          <text class="identity-modal-option-arrow">›</text>
        </view>
        <view class="identity-modal-option" bindtap="onModelPlatformBind">
          <view class="identity-modal-option-main">
            <text class="identity-modal-option-title">平台已绑定</text>
            <text class="identity-modal-option-sub">使用后台预留手机号授权登录</text>
          </view>
          <text class="identity-modal-option-arrow">›</text>
        </view>
      </block>

      <block wx:else>
        <text class="identity-modal-back" bindtap="onModelModalBack">‹ 返回</text>
        <text class="identity-modal-desc">授权微信手机号，平台将核对是否已为您预绑定模特账号</text>
        <button
          class="identity-phone-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onPlatformBindGetPhone"
          loading="{{platformBindLoading}}"
          disabled="{{platformBindLoading}}"
        >
          授权手机号并绑定
        </button>
        <text wx:if="{{platformBindError}}" class="identity-modal-error">{{platformBindError}}</text>
      </block>
    </view>
  </view>
</view>
