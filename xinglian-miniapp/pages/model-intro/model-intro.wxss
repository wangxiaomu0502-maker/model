@import "../home/home.wxss";

.model-intro-page {
  min-height: 100vh;
  padding-top: 0;
  background: linear-gradient(180deg, #312e81 0%, #eef4ff 260rpx, #f7f9fd 100%);
}

.intro-immersive-hero {
  margin-left: -20rpx;
  margin-right: -20rpx;
  margin-top: 0;
  border-radius: 0 0 28rpx 28rpx;
  padding-left: 44rpx;
  padding-right: 44rpx;
  padding-bottom: 42rpx;
}

.visitor-tip-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef2ff 100%);
  border-color: rgba(99, 102, 241, 0.2);
}

.visitor-tip-main {
  flex: 1;
  min-width: 0;
}

.visitor-tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #312e81;
}

.visitor-tip-text {
  margin-top: 8rpx;
  color: #64748b;
}

.visitor-register-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4338ca 0%, #6366f1 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.visitor-register-btn::after {
  border: 0;
}
