@import "../../styles/xl-theme.wxss";

.page-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 4rpx 4rpx 0;
}

.page-head-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.page-head-count {
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 600;
}

.selected-panel {
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(129, 140, 248, 0.16);
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.04);
}

.selected-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.selected-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #334155;
}

.selected-tip,
.selected-empty {
  font-size: 22rpx;
  color: #94a3b8;
}

.selected-scroll {
  width: 100%;
  white-space: nowrap;
}

.selected-row {
  display: inline-flex;
  flex-direction: row;
  gap: 10rpx;
  padding: 2rpx 2rpx 4rpx;
}

.selected-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  max-width: 220rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #4338ca;
  background: rgba(99, 102, 241, 0.1);
  border: 1rpx solid rgba(99, 102, 241, 0.24);
}

.selected-chip text:first-child {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-chip-close {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1;
  color: #818cf8;
}

/* 类型：模特 / 风格 / 场景 */
.type-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.type-tab {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(148, 163, 184, 0.35);
}

.type-tab--on {
  color: #4338ca;
  font-weight: 600;
  border-color: rgba(99, 102, 241, 0.45);
  background: rgba(99, 102, 241, 0.1);
}

/* 大分类：顶部横向 */
.major-scroll {
  width: 100%;
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.major-row {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 4rpx 4rpx 12rpx;
}

.major-tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 20rpx 0 12rpx;
  font-size: 28rpx;
  color: #475569;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.major-tab--on {
  color: #fff;
  font-weight: 600;
  border-color: transparent;
  background: linear-gradient(135deg, #6366f1 0%, #7c3aed 100%);
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.28);
}

.major-tab--picked:not(.major-tab--on) {
  border-color: rgba(99, 102, 241, 0.45);
  background: rgba(99, 102, 241, 0.08);
}

.major-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 8rpx;
  border: 2rpx solid #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  background: #fff;
  box-sizing: border-box;
}

.major-tab--on .major-check {
  border-color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.16);
}

.major-check--all {
  border-color: #6366f1;
  background: #6366f1;
}

.major-tab--on .major-check--all {
  border-color: #fff;
  background: rgba(255, 255, 255, 0.92);
  color: #6366f1;
}

.major-check--partial {
  border-color: #6366f1;
  background: rgba(99, 102, 241, 0.18);
  color: #6366f1;
}

.parent-row,
.sub-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.parent-row {
  padding: 20rpx 22rpx 12rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.sub-head {
  margin-bottom: 16rpx;
}

.parent-check {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  border: 2rpx solid #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: #fff;
  box-sizing: border-box;
}

.parent-check--all {
  border-color: #6366f1;
  background: #6366f1;
}

.parent-check--partial {
  border-color: #6366f1;
  background: rgba(99, 102, 241, 0.14);
  color: #6366f1;
}

.parent-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #4338ca;
}

.body-scroll {
  height: calc(100vh - 472rpx - env(safe-area-inset-bottom));
  min-height: 400rpx;
}

.body-panel {
  padding: 8rpx 4rpx 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(129, 140, 248, 0.15);
  box-shadow: 0 10rpx 28rpx rgba(79, 70, 229, 0.05);
}

.sub-block {
  padding: 24rpx 22rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.sub-block:last-child {
  border-bottom: none;
}

.sub-block-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.body-panel > .chip-grid {
  padding: 24rpx 22rpx;
}

.chip {
  padding: 16rpx 26rpx;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.3;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.chip--on {
  color: #4338ca;
  font-weight: 600;
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(99, 102, 241, 0.35);
}

.empty-hint {
  padding: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #94a3b8;
}

.scroll-foot {
  height: 24rpx;
}
