<view class="container">
  <view class="model-dash">
    <view class="dash-hero">
      <view class="dash-hero-main">
        <text class="dash-title">推广概览</text>
        <text class="dash-desc">锁定客户与推广佣金按北京时间统计（已完成订单）</text>
      </view>
    </view>

    <view class="stats-card">
      <view class="stat-row">
        <view class="stat-block">
          <text class="stat-label">锁定客户</text>
          <view class="stat-value-row"><text class="stat-value">{{lockedMerchantCount}}</text><text class="stat-unit">位</text></view>
        </view>
      </view>
      <text class="stats-hint">统计口径：客户账号已启用且 referrer 指向当前经纪人。</text>
    </view>

    <view class="period-tabs">
      <view class="period-tab {{periodTab === 'today' ? 'period-tab-on' : ''}}" data-tab="today" bindtap="onPeriodTab">今日</view>
      <view class="period-tab {{periodTab === 'week' ? 'period-tab-on' : ''}}" data-tab="week" bindtap="onPeriodTab">本周</view>
      <view class="period-tab {{periodTab === 'month' ? 'period-tab-on' : ''}}" data-tab="month" bindtap="onPeriodTab">本月</view>
    </view>

    <view class="stats-card">
      <view class="stat-row">
        <view class="stat-block">
          <text class="stat-label">推广佣金</text>
          <view class="stat-value-row"><text class="stat-currency">¥</text><text class="stat-value stat-money">{{incomeStats.incomeYuan}}</text></view>
        </view>
      </view>
      <view class="stat-pending">
        <text class="stat-pending-label">已分账合计</text>
        <text class="stat-pending-value">¥{{incomeStats.totalYuan}}</text>
      </view>
      <view class="stat-pending stat-pending-secondary">
        <text class="stat-pending-label">待结算（预估）</text>
        <text class="stat-pending-value">¥{{incomeStats.pendingYuan}}</text>
      </view>
      <text class="stats-hint">已分账来自绑定客户订单分成；待结算为已支付待分账订单的佣金估算。</text>
    </view>

    <view class="trend-card">
      <text class="trend-head">近7日佣金趋势</text>
      <view wx:if="{{dashboardLoading}}" class="dash-loading">加载中…</view>
      <text wx:elif="{{dashboardError}}" class="dash-error">{{dashboardError}}</text>
      <view wx:else class="trend-chart">
        <view wx:for="{{trend7dDisplay}}" wx:key="date" class="trend-col">
          <text class="trend-amount">¥{{item.incomeText}}</text>
          <view class="trend-bar-track"><view class="trend-bar" style="height: {{item.barPct}}%;"></view></view>
          <text class="trend-day">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
